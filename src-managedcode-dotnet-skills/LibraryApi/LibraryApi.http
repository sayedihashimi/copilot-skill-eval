@baseUrl = http://localhost:5000

### ==============================
### AUTHORS
### ==============================

### Get all authors
GET {{baseUrl}}/api/authors?page=1&pageSize=10

### Get author by ID
GET {{baseUrl}}/api/authors/1

### Create a new author
POST {{baseUrl}}/api/authors
Content-Type: application/json

{
  "firstName": "Ernest",
  "lastName": "Hemingway",
  "biography": "American novelist known for The Old Man and the Sea.",
  "birthDate": "1899-07-21",
  "country": "United States"
}

### Update an author
PUT {{baseUrl}}/api/authors/1
Content-Type: application/json

{
  "firstName": "Harper",
  "lastName": "Lee",
  "biography": "American novelist, author of To Kill a Mockingbird and Go Set a Watchman.",
  "birthDate": "1926-04-28",
  "country": "United States"
}

### Delete an author (will fail if author has books)
DELETE {{baseUrl}}/api/authors/6

### ==============================
### CATEGORIES
### ==============================

### Get all categories
GET {{baseUrl}}/api/categories?page=1&pageSize=10

### Get category by ID (includes books)
GET {{baseUrl}}/api/categories/1

### Create a new category
POST {{baseUrl}}/api/categories
Content-Type: application/json

{
  "name": "Biography",
  "description": "Biographical works and memoirs"
}

### Update a category
PUT {{baseUrl}}/api/categories/1
Content-Type: application/json

{
  "name": "Fiction",
  "description": "Literary fiction, novels, and short stories"
}

### Delete a category (will fail if category has books)
DELETE {{baseUrl}}/api/categories/5

### ==============================
### BOOKS
### ==============================

### Get all books
GET {{baseUrl}}/api/books?page=1&pageSize=10

### Get book by ID
GET {{baseUrl}}/api/books/1

### Create a new book
POST {{baseUrl}}/api/books
Content-Type: application/json

{
  "title": "The Old Man and the Sea",
  "isbn": "978-0-684-80122-3",
  "publisher": "Charles Scribner's Sons",
  "publicationYear": 1952,
  "description": "A novella about an aging fisherman.",
  "pageCount": 127,
  "language": "English",
  "totalCopies": 3,
  "authorIds": [],
  "categoryIds": [1, 2]
}

### Update a book
PUT {{baseUrl}}/api/books/1
Content-Type: application/json

{
  "title": "To Kill a Mockingbird",
  "isbn": "978-0-06-112008-4",
  "publisher": "J. B. Lippincott & Co.",
  "publicationYear": 1960,
  "description": "A Pulitzer Prize-winning novel about racial injustice in the Deep South.",
  "pageCount": 281,
  "language": "English",
  "totalCopies": 6,
  "authorIds": [1],
  "categoryIds": [1, 2]
}

### Delete a book (will fail if book has active loans)
DELETE {{baseUrl}}/api/books/12

### Get loans for a book
GET {{baseUrl}}/api/books/1/loans?page=1&pageSize=10

### Get reservations for a book
GET {{baseUrl}}/api/books/2/reservations?page=1&pageSize=10

### ==============================
### PATRONS
### ==============================

### Get all patrons
GET {{baseUrl}}/api/patrons?page=1&pageSize=10

### Get patron by ID
GET {{baseUrl}}/api/patrons/1

### Create a new patron
POST {{baseUrl}}/api/patrons
Content-Type: application/json

{
  "firstName": "Grace",
  "lastName": "Taylor",
  "email": "grace.taylor@email.com",
  "phone": "555-0107",
  "address": "111 Birch Way, Springfield",
  "membershipType": "Standard"
}

### Update a patron
PUT {{baseUrl}}/api/patrons/2
Content-Type: application/json

{
  "firstName": "Bob",
  "lastName": "Smith",
  "email": "bob.smith@email.com",
  "phone": "555-0102",
  "address": "456 Oak Ave, Springfield",
  "membershipType": "Premium",
  "isActive": true
}

### Delete a patron (will fail if patron has active loans)
DELETE {{baseUrl}}/api/patrons/6

### Get patron loans
GET {{baseUrl}}/api/patrons/1/loans?page=1&pageSize=10

### Get patron reservations
GET {{baseUrl}}/api/patrons/3/reservations?page=1&pageSize=10

### Get patron fines
GET {{baseUrl}}/api/patrons/2/fines?page=1&pageSize=10

### ==============================
### LOANS
### ==============================

### Get all loans
GET {{baseUrl}}/api/loans?page=1&pageSize=10

### Get loan by ID
GET {{baseUrl}}/api/loans/1

### Checkout a book (create loan)
POST {{baseUrl}}/api/loans
Content-Type: application/json

{
  "bookId": 7,
  "patronId": 2
}

### Return a book
POST {{baseUrl}}/api/loans/1/return

### Renew a loan
POST {{baseUrl}}/api/loans/5/renew

### Get overdue loans
GET {{baseUrl}}/api/loans/overdue?page=1&pageSize=10

### ==============================
### BUSINESS RULE TESTS
### ==============================

### Test: Checkout fails - inactive patron (Patron 6 is inactive)
POST {{baseUrl}}/api/loans
Content-Type: application/json

{
  "bookId": 7,
  "patronId": 6
}

### Test: Checkout fails - no available copies (book 5 has 1 copy, 1 on loan)
### (First verify available copies by getting the book)
GET {{baseUrl}}/api/books/5

### Test: Renewal fails - overdue loan (Loan 4 is overdue)
POST {{baseUrl}}/api/loans/4/renew

### Test: Reservation fails - patron has active loan on book
POST {{baseUrl}}/api/reservations
Content-Type: application/json

{
  "bookId": 1,
  "patronId": 1
}

### ==============================
### RESERVATIONS
### ==============================

### Get all reservations
GET {{baseUrl}}/api/reservations?page=1&pageSize=10

### Get reservation by ID
GET {{baseUrl}}/api/reservations/1

### Create a reservation
POST {{baseUrl}}/api/reservations
Content-Type: application/json

{
  "bookId": 10,
  "patronId": 4
}

### Cancel a reservation
POST {{baseUrl}}/api/reservations/3/cancel

### Fulfill a reservation (must be Ready status)
POST {{baseUrl}}/api/reservations/1/fulfill

### ==============================
### FINES
### ==============================

### Get all fines
GET {{baseUrl}}/api/fines?page=1&pageSize=10

### Get fine by ID
GET {{baseUrl}}/api/fines/2

### Pay a fine
POST {{baseUrl}}/api/fines/2/pay

### Waive a fine
POST {{baseUrl}}/api/fines/3/waive
