@host = http://localhost:5000

### ===== OWNERS =====

### Get all owners
GET {{host}}/api/owners?page=1&pageSize=10

### Get owner by ID
GET {{host}}/api/owners/1

### Create a new owner
POST {{host}}/api/owners
Content-Type: application/json

{
  "firstName": "Alice",
  "lastName": "Walker",
  "email": "alice.walker@email.com",
  "phone": "555-0199",
  "address": "100 River Rd",
  "city": "Chicago",
  "state": "IL",
  "zipCode": "60601"
}

### Update an owner
PUT {{host}}/api/owners/1
Content-Type: application/json

{
  "firstName": "John",
  "lastName": "Smith",
  "email": "john.smith@email.com",
  "phone": "555-0101",
  "address": "123 Oak St Updated",
  "city": "Springfield",
  "state": "IL",
  "zipCode": "62701"
}

### Delete an owner (will fail if they have pets)
DELETE {{host}}/api/owners/5

### Get pets for owner
GET {{host}}/api/owners/1/pets

### Get appointments for owner
GET {{host}}/api/owners/1/appointments

### ===== PETS =====

### Get all pets
GET {{host}}/api/pets?page=1&pageSize=10

### Get all pets including inactive
GET {{host}}/api/pets?page=1&pageSize=10&includeInactive=true

### Get pet by ID
GET {{host}}/api/pets/1

### Create a new pet
POST {{host}}/api/pets
Content-Type: application/json

{
  "name": "Rocky",
  "species": "Dog",
  "breed": "Bulldog",
  "dateOfBirth": "2022-06-15",
  "weight": 25.5,
  "color": "White/Brown",
  "ownerId": 3
}

### Update a pet
PUT {{host}}/api/pets/1
Content-Type: application/json

{
  "name": "Buddy",
  "species": "Dog",
  "breed": "Golden Retriever",
  "dateOfBirth": "2020-03-15",
  "weight": 31.0,
  "color": "Golden",
  "microchipNumber": "MC001",
  "ownerId": 1
}

### Soft delete a pet
DELETE {{host}}/api/pets/8

### Get medical records for a pet
GET {{host}}/api/pets/1/medical-records

### Get vaccinations for a pet
GET {{host}}/api/pets/1/vaccinations

### Get upcoming vaccinations for a pet
GET {{host}}/api/pets/2/vaccinations/upcoming

### Get active prescriptions for a pet
GET {{host}}/api/pets/1/prescriptions/active

### ===== VETERINARIANS =====

### Get all veterinarians
GET {{host}}/api/veterinarians?page=1&pageSize=10

### Get veterinarian by ID
GET {{host}}/api/veterinarians/1

### Create a new veterinarian
POST {{host}}/api/veterinarians
Content-Type: application/json

{
  "firstName": "Dr. James",
  "lastName": "Wilson",
  "email": "j.wilson@happypaws.com",
  "phone": "555-0204",
  "specialization": "Cardiology",
  "licenseNumber": "VET-004",
  "hireDate": "2024-01-15"
}

### Update a veterinarian
PUT {{host}}/api/veterinarians/1
Content-Type: application/json

{
  "firstName": "Dr. Amanda",
  "lastName": "Chen",
  "email": "a.chen@happypaws.com",
  "phone": "555-0201",
  "specialization": "General Practice",
  "licenseNumber": "VET-001",
  "isAvailable": true
}

### Get veterinarian schedule for today
GET {{host}}/api/veterinarians/1/schedule

### Get all appointments for a veterinarian
GET {{host}}/api/veterinarians/1/appointments

### ===== APPOINTMENTS =====

### Get all appointments
GET {{host}}/api/appointments?page=1&pageSize=10

### Get appointment by ID
GET {{host}}/api/appointments/1

### Create a new appointment (future date)
POST {{host}}/api/appointments
Content-Type: application/json

{
  "petId": 2,
  "veterinarianId": 1,
  "appointmentDate": "2026-02-15T10:00:00Z",
  "durationMinutes": 30,
  "reason": "Annual wellness checkup"
}

### Update an appointment
PUT {{host}}/api/appointments/10
Content-Type: application/json

{
  "appointmentDate": "2026-02-20T14:00:00Z",
  "durationMinutes": 45,
  "reason": "General wellness exam - extended",
  "notes": "Owner requested extra time for questions"
}

### Update appointment status - Check in
PATCH {{host}}/api/appointments/7/status
Content-Type: application/json

{
  "status": "CheckedIn"
}

### Update appointment status - Cancel with reason
PATCH {{host}}/api/appointments/9/status
Content-Type: application/json

{
  "status": "Cancelled",
  "cancellationReason": "Owner called to cancel"
}

### Get today's appointments
GET {{host}}/api/appointments/today

### ===== MEDICAL RECORDS =====

### Get medical record by ID
GET {{host}}/api/medical-records/1

### Create a medical record (for a completed/in-progress appointment)
POST {{host}}/api/medical-records
Content-Type: application/json

{
  "appointmentId": 4,
  "diagnosis": "Healthy, all vaccinations up to date",
  "treatment": "Administered booster vaccines",
  "notes": "Pet in excellent health",
  "followUpDate": "2026-06-01"
}

### Update a medical record
PUT {{host}}/api/medical-records/1
Content-Type: application/json

{
  "diagnosis": "Healthy, all vitals normal - updated",
  "treatment": "No treatment required. Administered annual vaccines. Recommended dental check.",
  "followUpDate": "2026-06-15"
}

### ===== PRESCRIPTIONS =====

### Get prescription by ID
GET {{host}}/api/prescriptions/1

### Create a prescription
POST {{host}}/api/prescriptions
Content-Type: application/json

{
  "medicalRecordId": 1,
  "medicationName": "Apoquel",
  "dosage": "16mg once daily",
  "durationDays": 14,
  "startDate": "2025-07-01",
  "instructions": "Give with food in the morning"
}

### ===== VACCINATIONS =====

### Get vaccination by ID
GET {{host}}/api/vaccinations/1

### Create a vaccination
POST {{host}}/api/vaccinations
Content-Type: application/json

{
  "petId": 4,
  "vaccineName": "FVRCP",
  "dateAdministered": "2025-07-01",
  "expirationDate": "2026-07-01",
  "batchNumber": "FVRCP-2025-001",
  "administeredByVetId": 3,
  "notes": "Annual booster"
}
