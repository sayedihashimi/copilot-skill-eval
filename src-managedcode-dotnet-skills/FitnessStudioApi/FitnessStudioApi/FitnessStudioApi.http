@baseUrl = http://localhost:5000

### =====================
### MEMBERSHIP PLANS
### =====================

### List all active membership plans
GET {{baseUrl}}/api/membership-plans

### Get a specific membership plan
GET {{baseUrl}}/api/membership-plans/1

### Create a new membership plan
POST {{baseUrl}}/api/membership-plans
Content-Type: application/json

{
  "name": "Student",
  "description": "Discounted plan for students",
  "durationMonths": 6,
  "price": 19.99,
  "maxClassBookingsPerWeek": 2,
  "allowsPremiumClasses": false
}

### Update a membership plan
PUT {{baseUrl}}/api/membership-plans/1
Content-Type: application/json

{
  "name": "Basic",
  "description": "Updated basic plan with more perks",
  "durationMonths": 1,
  "price": 34.99,
  "maxClassBookingsPerWeek": 4,
  "allowsPremiumClasses": false
}

### Deactivate a membership plan
DELETE {{baseUrl}}/api/membership-plans/1

### =====================
### MEMBERS
### =====================

### List members (with pagination)
GET {{baseUrl}}/api/members?page=1&pageSize=10

### Search members
GET {{baseUrl}}/api/members?search=alice&page=1&pageSize=10

### Filter active members
GET {{baseUrl}}/api/members?isActive=true&page=1&pageSize=10

### Get a specific member
GET {{baseUrl}}/api/members/1

### Register a new member
POST {{baseUrl}}/api/members
Content-Type: application/json

{
  "firstName": "Zara",
  "lastName": "Nakamura",
  "email": "zara.nakamura@email.com",
  "phone": "555-0901",
  "dateOfBirth": "1998-06-20",
  "emergencyContactName": "Hiro Nakamura",
  "emergencyContactPhone": "555-0902"
}

### Update a member
PUT {{baseUrl}}/api/members/1
Content-Type: application/json

{
  "firstName": "Alice",
  "lastName": "Johnson",
  "email": "alice.johnson@email.com",
  "phone": "555-0101",
  "emergencyContactName": "Bob Johnson Updated",
  "emergencyContactPhone": "555-0103"
}

### Deactivate a member
DELETE {{baseUrl}}/api/members/8

### Get member's bookings
GET {{baseUrl}}/api/members/1/bookings

### Get member's upcoming bookings
GET {{baseUrl}}/api/members/1/bookings/upcoming

### Get member's membership history
GET {{baseUrl}}/api/members/1/memberships

### =====================
### MEMBERSHIPS
### =====================

### Create a membership
POST {{baseUrl}}/api/memberships
Content-Type: application/json

{
  "memberId": 7,
  "membershipPlanId": 2,
  "startDate": "2025-03-20",
  "paymentStatus": "Paid"
}

### Get a specific membership
GET {{baseUrl}}/api/memberships/1

### Cancel a membership
POST {{baseUrl}}/api/memberships/3/cancel
Content-Type: application/json

{
  "reason": "Moving to another city"
}

### Freeze a membership
POST {{baseUrl}}/api/memberships/2/freeze
Content-Type: application/json

{
  "freezeStartDate": "2025-04-01",
  "freezeEndDate": "2025-04-15"
}

### Unfreeze a membership
POST {{baseUrl}}/api/memberships/2/unfreeze

### Renew a membership (expired one)
POST {{baseUrl}}/api/memberships/7/renew

### =====================
### INSTRUCTORS
### =====================

### List all instructors
GET {{baseUrl}}/api/instructors

### Get a specific instructor
GET {{baseUrl}}/api/instructors/1

### Create a new instructor
POST {{baseUrl}}/api/instructors
Content-Type: application/json

{
  "firstName": "Mia",
  "lastName": "Chen",
  "email": "mia.chen@zenith.com",
  "phone": "555-1005",
  "bio": "Dance fitness and Zumba expert",
  "specializations": "Zumba,Dance,Cardio",
  "hireDate": "2025-01-15"
}

### Update an instructor
PUT {{baseUrl}}/api/instructors/1
Content-Type: application/json

{
  "firstName": "Sarah",
  "lastName": "Mitchell",
  "email": "sarah.mitchell@zenith.com",
  "phone": "555-1001",
  "bio": "Certified yoga instructor with 12 years of experience. RYT-500 certified.",
  "specializations": "Yoga,Pilates,Meditation,Stretching"
}

### Get instructor schedule
GET {{baseUrl}}/api/instructors/1/schedule

### =====================
### CLASS TYPES
### =====================

### List all class types
GET {{baseUrl}}/api/class-types

### Get a specific class type
GET {{baseUrl}}/api/class-types/1

### Create a new class type
POST {{baseUrl}}/api/class-types
Content-Type: application/json

{
  "name": "Zumba",
  "description": "High-energy dance fitness class",
  "defaultDurationMinutes": 60,
  "defaultCapacity": 30,
  "isPremium": false,
  "caloriesPerSession": 400,
  "difficultyLevel": "Beginner"
}

### Update a class type
PUT {{baseUrl}}/api/class-types/1
Content-Type: application/json

{
  "name": "Yoga",
  "description": "Vinyasa flow yoga — suitable for all levels, bring your own mat",
  "defaultDurationMinutes": 60,
  "defaultCapacity": 25,
  "isPremium": false,
  "caloriesPerSession": 280,
  "difficultyLevel": "AllLevels"
}

### =====================
### CLASS SCHEDULES
### =====================

### List scheduled classes
GET {{baseUrl}}/api/classes?page=1&pageSize=10

### Get a specific class schedule
GET {{baseUrl}}/api/classes/1

### Schedule a new class
POST {{baseUrl}}/api/classes
Content-Type: application/json

{
  "classTypeId": 1,
  "instructorId": 1,
  "startTime": "2025-03-25T08:00:00",
  "endTime": "2025-03-25T09:00:00",
  "capacity": 20,
  "room": "Studio A"
}

### Update a class schedule
PUT {{baseUrl}}/api/classes/1
Content-Type: application/json

{
  "instructorId": 4,
  "startTime": "2025-03-22T07:30:00",
  "endTime": "2025-03-22T08:30:00",
  "capacity": 25,
  "room": "Studio A"
}

### Cancel a class
PATCH {{baseUrl}}/api/classes/12/cancel
Content-Type: application/json

{
  "reason": "Instructor unavailable"
}

### Get class roster
GET {{baseUrl}}/api/classes/1/roster

### Get class waitlist
GET {{baseUrl}}/api/classes/9/waitlist

### Get available classes
GET {{baseUrl}}/api/classes/available

### =====================
### BOOKINGS
### =====================

### Book a class (member 4, class 7 - Yoga)
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 7,
  "memberId": 4
}

### Get a specific booking
GET {{baseUrl}}/api/bookings/1

### Cancel a booking
POST {{baseUrl}}/api/bookings/3/cancel
Content-Type: application/json

{
  "reason": "Cannot make it to class"
}

### Check in to a class
POST {{baseUrl}}/api/bookings/1/check-in

### Mark no-show
POST {{baseUrl}}/api/bookings/2/no-show
