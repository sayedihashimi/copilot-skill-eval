@baseUrl = http://localhost:5277

### =============================================
### Membership Plans
### =============================================

### List all active membership plans
GET {{baseUrl}}/api/membership-plans

### Get plan details (Basic plan)
GET {{baseUrl}}/api/membership-plans/1

### Get plan details (Premium plan)
GET {{baseUrl}}/api/membership-plans/2

### Create a new membership plan
POST {{baseUrl}}/api/membership-plans
Content-Type: application/json

{
  "name": "Student",
  "description": "Discounted plan for students with valid ID",
  "durationMonths": 3,
  "price": 19.99,
  "maxClassBookingsPerWeek": 2,
  "allowsPremiumClasses": false
}

### Update a membership plan
PUT {{baseUrl}}/api/membership-plans/1
Content-Type: application/json

{
  "name": "Basic",
  "description": "Access to standard classes, 3 bookings per week - updated",
  "durationMonths": 1,
  "price": 34.99,
  "maxClassBookingsPerWeek": 3,
  "allowsPremiumClasses": false,
  "isActive": true
}

### Deactivate a membership plan
DELETE {{baseUrl}}/api/membership-plans/4

### =============================================
### Members
### =============================================

### List all members (default pagination)
GET {{baseUrl}}/api/members

### List members - search by name
GET {{baseUrl}}/api/members?search=alice

### List members - filter active only with pagination
GET {{baseUrl}}/api/members?isActive=true&page=1&pageSize=5

### Get member details (Alice Johnson - Elite member)
GET {{baseUrl}}/api/members/1

### Get member details (Marcus Chen - Premium member)
GET {{baseUrl}}/api/members/2

### Get member details (Sarah Williams - Basic member)
GET {{baseUrl}}/api/members/3

### Register a new member
POST {{baseUrl}}/api/members
Content-Type: application/json

{
  "firstName": "Natalie",
  "lastName": "Parker",
  "email": "natalie.parker@email.com",
  "phone": "555-0901",
  "dateOfBirth": "1998-06-15",
  "emergencyContactName": "Steve Parker",
  "emergencyContactPhone": "555-0902"
}

### Register a member too young (should fail - under 16)
POST {{baseUrl}}/api/members
Content-Type: application/json

{
  "firstName": "Young",
  "lastName": "Person",
  "email": "young@email.com",
  "phone": "555-0000",
  "dateOfBirth": "2015-01-01",
  "emergencyContactName": "Parent",
  "emergencyContactPhone": "555-0001"
}

### Update member profile
PUT {{baseUrl}}/api/members/1
Content-Type: application/json

{
  "firstName": "Alice",
  "lastName": "Johnson",
  "email": "alice.johnson@email.com",
  "phone": "555-0103",
  "emergencyContactName": "Bob Johnson",
  "emergencyContactPhone": "555-0104"
}

### Deactivate member (Ryan Taylor - inactive, no future bookings)
DELETE {{baseUrl}}/api/members/8

### Get member's bookings
GET {{baseUrl}}/api/members/1/bookings

### Get member's bookings - filter by status
GET {{baseUrl}}/api/members/1/bookings?status=Confirmed

### Get member's bookings - filter by date range
GET {{baseUrl}}/api/members/1/bookings?fromDate=2025-01-01&toDate=2026-12-31

### Get member's upcoming confirmed bookings
GET {{baseUrl}}/api/members/1/bookings/upcoming

### Get membership history for a member
GET {{baseUrl}}/api/members/1/memberships

### Get membership history for member with expired membership
GET {{baseUrl}}/api/members/8/memberships

### =============================================
### Memberships
### =============================================

### Create a new membership (for a member without active membership)
POST {{baseUrl}}/api/memberships
Content-Type: application/json

{
  "memberId": 8,
  "membershipPlanId": 2,
  "paymentStatus": "Paid"
}

### Get membership details
GET {{baseUrl}}/api/memberships/1

### Get membership details (frozen membership)
GET {{baseUrl}}/api/memberships/7

### Cancel a membership
POST {{baseUrl}}/api/memberships/6/cancel

### Freeze a membership (must be Active, 7-30 days)
POST {{baseUrl}}/api/memberships/4/freeze
Content-Type: application/json

{
  "freezeDurationDays": 14
}

### Unfreeze a membership (extends EndDate by freeze duration)
POST {{baseUrl}}/api/memberships/7/unfreeze

### Renew an expired membership
POST {{baseUrl}}/api/memberships/8/renew

### =============================================
### Instructors
### =============================================

### List all instructors
GET {{baseUrl}}/api/instructors

### List instructors - filter by specialization
GET {{baseUrl}}/api/instructors?specialization=yoga

### List active instructors only
GET {{baseUrl}}/api/instructors?isActive=true

### Get instructor details
GET {{baseUrl}}/api/instructors/1

### Create a new instructor
POST {{baseUrl}}/api/instructors
Content-Type: application/json

{
  "firstName": "Aria",
  "lastName": "Foster",
  "email": "aria.foster@zenith.com",
  "phone": "555-1005",
  "bio": "Certified Zumba and dance fitness instructor with infectious energy.",
  "specializations": "Zumba, Dance, Cardio",
  "hireDate": "2025-01-10"
}

### Update an instructor
PUT {{baseUrl}}/api/instructors/1
Content-Type: application/json

{
  "firstName": "Maya",
  "lastName": "Patel",
  "email": "maya.patel@zenith.com",
  "phone": "555-1001",
  "bio": "Certified yoga instructor with 12 years of experience in Vinyasa, Hatha yoga, and meditation.",
  "specializations": "Yoga, Pilates, Meditation, Breathwork",
  "isActive": true
}

### Get instructor's schedule
GET {{baseUrl}}/api/instructors/1/schedule

### Get instructor's schedule - filter by date range
GET {{baseUrl}}/api/instructors/2/schedule?fromDate=2025-01-01&toDate=2026-12-31

### =============================================
### Class Types
### =============================================

### List all class types
GET {{baseUrl}}/api/class-types

### List class types - filter by difficulty
GET {{baseUrl}}/api/class-types?difficulty=Beginner

### List premium class types only
GET {{baseUrl}}/api/class-types?isPremium=true

### Get class type details
GET {{baseUrl}}/api/class-types/1

### Create a new class type
POST {{baseUrl}}/api/class-types
Content-Type: application/json

{
  "name": "Zumba",
  "description": "Dance fitness class combining Latin and international music",
  "defaultDurationMinutes": 60,
  "defaultCapacity": 25,
  "isPremium": false,
  "caloriesPerSession": 400,
  "difficultyLevel": "AllLevels"
}

### Update a class type
PUT {{baseUrl}}/api/class-types/1
Content-Type: application/json

{
  "name": "Yoga",
  "description": "Traditional yoga focusing on flexibility, balance, mindfulness, and deep stretching",
  "defaultDurationMinutes": 75,
  "defaultCapacity": 25,
  "isPremium": false,
  "caloriesPerSession": 280,
  "difficultyLevel": "AllLevels",
  "isActive": true
}

### =============================================
### Class Schedules
### =============================================

### List all scheduled classes
GET {{baseUrl}}/api/classes

### List classes - filter by class type (Yoga = 1)
GET {{baseUrl}}/api/classes?classTypeId=1

### List classes - filter by instructor
GET {{baseUrl}}/api/classes?instructorId=1

### List classes - filter by date range
GET {{baseUrl}}/api/classes?fromDate=2025-01-01&toDate=2026-12-31

### List classes with available spots
GET {{baseUrl}}/api/classes?available=true

### List classes with pagination
GET {{baseUrl}}/api/classes?page=1&pageSize=5

### Get class details (Yoga class)
GET {{baseUrl}}/api/classes/1

### Get class details (Full HIIT class with waitlist)
GET {{baseUrl}}/api/classes/2

### Schedule a new class
POST {{baseUrl}}/api/classes
Content-Type: application/json

{
  "classTypeId": 1,
  "instructorId": 4,
  "startTime": "2025-07-25T14:00:00",
  "durationMinutes": 60,
  "capacity": 20,
  "room": "Studio A"
}

### Update class details
PUT {{baseUrl}}/api/classes/1
Content-Type: application/json

{
  "classTypeId": 1,
  "instructorId": 1,
  "startTime": "2025-07-20T09:00:00",
  "endTime": "2025-07-20T10:00:00",
  "capacity": 25,
  "room": "Studio A"
}

### Cancel a class (cascades to all bookings)
PATCH {{baseUrl}}/api/classes/12/cancel
Content-Type: application/json

{
  "cancellationReason": "Instructor sick leave"
}

### Get confirmed members roster for a class
GET {{baseUrl}}/api/classes/1/roster

### Get waitlist for a class (HIIT class that's full)
GET {{baseUrl}}/api/classes/2/waitlist

### Get classes with available spots in next 7 days
GET {{baseUrl}}/api/classes/available

### =============================================
### Bookings
### =============================================

### Book a class - normal booking (Alice, Elite member, Spin class)
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 9,
  "memberId": 1
}

### Book a premium class as a Basic member (should fail - Sarah is Basic)
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 5,
  "memberId": 3
}

### Book a premium class as a Premium member (should succeed - Marcus is Premium)
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 6,
  "memberId": 2
}

### Book a class that's at capacity (should go to waitlist - HIIT class 2 is full)
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 2,
  "memberId": 6
}

### Get booking details
GET {{baseUrl}}/api/bookings/1

### Get a waitlisted booking
GET {{baseUrl}}/api/bookings/7

### Cancel a booking (free cancellation - more than 2 hours before)
POST {{baseUrl}}/api/bookings/14/cancel
Content-Type: application/json

{
  "cancellationReason": "Changed my schedule"
}

### Cancel a confirmed booking on a full class (should promote from waitlist)
POST {{baseUrl}}/api/bookings/4/cancel
Content-Type: application/json

{
  "cancellationReason": "Cannot make it"
}

### Check in for a class
POST {{baseUrl}}/api/bookings/1/check-in

### Mark booking as no-show
POST {{baseUrl}}/api/bookings/2/no-show
