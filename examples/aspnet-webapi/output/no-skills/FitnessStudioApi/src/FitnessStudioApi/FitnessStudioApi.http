@baseUrl = http://localhost:5183

### ==========================================
### Membership Plans
### ==========================================

### List all active membership plans
GET {{baseUrl}}/api/membership-plans
Accept: application/json

### Get specific plan
GET {{baseUrl}}/api/membership-plans/1
Accept: application/json

### Create a new plan
POST {{baseUrl}}/api/membership-plans
Content-Type: application/json

{
  "name": "Student",
  "description": "Discounted plan for students",
  "durationMonths": 6,
  "price": 19.99,
  "maxClassBookingsPerWeek": 2,
  "allowsPremiumClasses": false
}

### Update a plan
PUT {{baseUrl}}/api/membership-plans/1
Content-Type: application/json

{
  "name": "Basic",
  "description": "Essential access with limited class bookings per week - Updated",
  "durationMonths": 1,
  "price": 34.99,
  "maxClassBookingsPerWeek": 3,
  "allowsPremiumClasses": false,
  "isActive": true
}

### Deactivate a plan
DELETE {{baseUrl}}/api/membership-plans/4

### ==========================================
### Members
### ==========================================

### List all members
GET {{baseUrl}}/api/members
Accept: application/json

### List members with search
GET {{baseUrl}}/api/members?search=alice&page=1&pageSize=5
Accept: application/json

### List active members only
GET {{baseUrl}}/api/members?isActive=true&page=1&pageSize=10
Accept: application/json

### Get member details (includes active membership)
GET {{baseUrl}}/api/members/1
Accept: application/json

### Register a new member
POST {{baseUrl}}/api/members
Content-Type: application/json

{
  "firstName": "Isabella",
  "lastName": "Rodriguez",
  "email": "isabella.rodriguez@email.com",
  "phone": "555-0901",
  "dateOfBirth": "1997-08-20",
  "emergencyContactName": "Maria Rodriguez",
  "emergencyContactPhone": "555-0902"
}

### Update member profile
PUT {{baseUrl}}/api/members/1
Content-Type: application/json

{
  "firstName": "Alice",
  "lastName": "Johnson",
  "email": "alice.johnson@email.com",
  "phone": "555-0101-updated",
  "emergencyContactName": "Bob Johnson",
  "emergencyContactPhone": "555-0102"
}

### Deactivate a member (will fail if they have future bookings)
DELETE {{baseUrl}}/api/members/7

### Get member's bookings
GET {{baseUrl}}/api/members/1/bookings?page=1&pageSize=10
Accept: application/json

### Get member's bookings filtered by status
GET {{baseUrl}}/api/members/1/bookings?status=Confirmed&page=1&pageSize=10
Accept: application/json

### Get member's upcoming confirmed bookings
GET {{baseUrl}}/api/members/1/bookings/upcoming
Accept: application/json

### Get membership history
GET {{baseUrl}}/api/members/1/memberships
Accept: application/json

### ==========================================
### Memberships
### ==========================================

### Create a membership for a member
POST {{baseUrl}}/api/memberships
Content-Type: application/json

{
  "memberId": 7,
  "membershipPlanId": 2,
  "startDate": "2026-03-26"
}

### Get membership details
GET {{baseUrl}}/api/memberships/1
Accept: application/json

### Cancel a membership
POST {{baseUrl}}/api/memberships/1/cancel
Content-Type: application/json

### Freeze a membership (7-30 days)
POST {{baseUrl}}/api/memberships/2/freeze
Content-Type: application/json

{
  "freezeDurationDays": 14
}

### Unfreeze a membership
POST {{baseUrl}}/api/memberships/2/unfreeze
Content-Type: application/json

### Renew an expired membership
POST {{baseUrl}}/api/memberships/7/renew
Content-Type: application/json

### ==========================================
### Instructors
### ==========================================

### List all instructors
GET {{baseUrl}}/api/instructors
Accept: application/json

### List instructors by specialization
GET {{baseUrl}}/api/instructors?specialization=Yoga&page=1&pageSize=10
Accept: application/json

### Get instructor details
GET {{baseUrl}}/api/instructors/1
Accept: application/json

### Create a new instructor
POST {{baseUrl}}/api/instructors
Content-Type: application/json

{
  "firstName": "Rachel",
  "lastName": "Kim",
  "email": "rachel.kim@zenithfitness.com",
  "phone": "555-1005",
  "bio": "Former Olympic swimmer specializing in aquatic fitness and endurance training.",
  "specializations": "HIIT, Spin",
  "hireDate": "2026-01-15"
}

### Update instructor
PUT {{baseUrl}}/api/instructors/1
Content-Type: application/json

{
  "firstName": "Maya",
  "lastName": "Patel",
  "email": "maya.patel@zenithfitness.com",
  "phone": "555-1001",
  "bio": "Certified yoga instructor with 10+ years of experience in Vinyasa and Hatha yoga. Now also teaching Meditation.",
  "specializations": "Yoga, Pilates, Meditation",
  "isActive": true
}

### Get instructor schedule
GET {{baseUrl}}/api/instructors/1/schedule
Accept: application/json

### Get instructor schedule by date range
GET {{baseUrl}}/api/instructors/1/schedule?from=2026-03-27&to=2026-04-03
Accept: application/json

### ==========================================
### Class Types
### ==========================================

### List all class types
GET {{baseUrl}}/api/class-types
Accept: application/json

### List premium class types
GET {{baseUrl}}/api/class-types?isPremium=true
Accept: application/json

### List by difficulty level
GET {{baseUrl}}/api/class-types?difficulty=Beginner
Accept: application/json

### Get class type details
GET {{baseUrl}}/api/class-types/1
Accept: application/json

### Create a new class type
POST {{baseUrl}}/api/class-types
Content-Type: application/json

{
  "name": "Zumba",
  "description": "Dance-based fitness class with Latin-inspired choreography",
  "defaultDurationMinutes": 60,
  "defaultCapacity": 25,
  "isPremium": false,
  "caloriesPerSession": 400,
  "difficultyLevel": "AllLevels"
}

### Update class type
PUT {{baseUrl}}/api/class-types/1
Content-Type: application/json

{
  "name": "Yoga",
  "description": "Flow through postures to improve flexibility, balance, and mental clarity - beginner friendly",
  "defaultDurationMinutes": 60,
  "defaultCapacity": 25,
  "isPremium": false,
  "caloriesPerSession": 250,
  "difficultyLevel": "AllLevels",
  "isActive": true
}

### ==========================================
### Class Schedules
### ==========================================

### List all scheduled classes
GET {{baseUrl}}/api/classes?page=1&pageSize=20
Accept: application/json

### List classes with available spots
GET {{baseUrl}}/api/classes?available=true
Accept: application/json

### List classes by class type
GET {{baseUrl}}/api/classes?classTypeId=1
Accept: application/json

### List classes by instructor
GET {{baseUrl}}/api/classes?instructorId=1
Accept: application/json

### List classes by date range
GET {{baseUrl}}/api/classes?from=2026-03-27&to=2026-03-29
Accept: application/json

### Get class details
GET {{baseUrl}}/api/classes/1
Accept: application/json

### Schedule a new class
POST {{baseUrl}}/api/classes
Content-Type: application/json

{
  "classTypeId": 1,
  "instructorId": 1,
  "startTime": "2026-04-01T09:00:00",
  "endTime": "2026-04-01T10:00:00",
  "capacity": 20,
  "room": "Studio A"
}

### Update class details
PUT {{baseUrl}}/api/classes/1
Content-Type: application/json

{
  "instructorId": 1,
  "startTime": "2026-03-27T07:30:00",
  "endTime": "2026-03-27T08:30:00",
  "capacity": 25,
  "room": "Studio A"
}

### Cancel a class (cascades to all bookings)
PATCH {{baseUrl}}/api/classes/12/cancel
Content-Type: application/json

{
  "cancellationReason": "Instructor sick day"
}

### Get class roster
GET {{baseUrl}}/api/classes/1/roster
Accept: application/json

### Get class waitlist
GET {{baseUrl}}/api/classes/6/waitlist
Accept: application/json

### Get available classes in next 7 days
GET {{baseUrl}}/api/classes/available
Accept: application/json

### ==========================================
### Bookings
### ==========================================

### Book a class (normal booking)
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 7,
  "memberId": 1
}

### Book a class (will go to waitlist if class is full - class 6 is at capacity)
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 6,
  "memberId": 5
}

### Attempt to book a premium class as a Basic member (should fail)
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 5,
  "memberId": 3
}

### Get booking details
GET {{baseUrl}}/api/bookings/1
Accept: application/json

### Cancel a booking (promotes waitlist)
POST {{baseUrl}}/api/bookings/1/cancel
Content-Type: application/json

{
  "cancellationReason": "Personal schedule conflict"
}

### Check in for a class (only works within 15 min window of class start)
POST {{baseUrl}}/api/bookings/1/check-in
Content-Type: application/json

### Mark booking as no-show (only works after 15 min past class start)
POST {{baseUrl}}/api/bookings/1/no-show
Content-Type: application/json
