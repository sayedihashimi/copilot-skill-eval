@baseUrl = http://localhost:5134

### ============================================================
### Authors
### ============================================================

### List all authors
GET {{baseUrl}}/api/authors?page=1&pageSize=10
Accept: application/json

### Search authors by name
GET {{baseUrl}}/api/authors?search=Orwell&page=1&pageSize=10
Accept: application/json

### Get author by ID (includes books)
GET {{baseUrl}}/api/authors/1
Accept: application/json

### Create a new author
POST {{baseUrl}}/api/authors
Content-Type: application/json

{
  "firstName": "Margaret",
  "lastName": "Atwood",
  "biography": "Canadian poet and novelist known for The Handmaid's Tale.",
  "birthDate": "1939-11-18",
  "country": "Canada"
}

### Update an author
PUT {{baseUrl}}/api/authors/1
Content-Type: application/json

{
  "firstName": "Harper",
  "lastName": "Lee",
  "biography": "American novelist best known for 'To Kill a Mockingbird', winner of the Pulitzer Prize.",
  "birthDate": "1926-04-28",
  "country": "United States"
}

### Delete an author (will fail if author has books)
DELETE {{baseUrl}}/api/authors/1
Accept: application/json

### ============================================================
### Categories
### ============================================================

### List all categories
GET {{baseUrl}}/api/categories?page=1&pageSize=10
Accept: application/json

### Get category by ID (includes book count)
GET {{baseUrl}}/api/categories/1
Accept: application/json

### Create a new category
POST {{baseUrl}}/api/categories
Content-Type: application/json

{
  "name": "Philosophy",
  "description": "Books exploring fundamental questions about existence, knowledge, and ethics"
}

### Update a category
PUT {{baseUrl}}/api/categories/1
Content-Type: application/json

{
  "name": "Fiction",
  "description": "Novels, short stories, literary fiction, and imaginative narratives"
}

### Delete a category (will fail if category has books)
DELETE {{baseUrl}}/api/categories/1
Accept: application/json

### ============================================================
### Books
### ============================================================

### List all books
GET {{baseUrl}}/api/books?page=1&pageSize=10
Accept: application/json

### Search books by title
GET {{baseUrl}}/api/books?search=Foundation&page=1&pageSize=10
Accept: application/json

### Filter available books
GET {{baseUrl}}/api/books?available=true&page=1&pageSize=10
Accept: application/json

### Filter unavailable books
GET {{baseUrl}}/api/books?available=false&page=1&pageSize=10
Accept: application/json

### Sort books by year
GET {{baseUrl}}/api/books?sortBy=year&page=1&pageSize=10
Accept: application/json

### Search books by author name
GET {{baseUrl}}/api/books?search=Asimov&page=1&pageSize=10
Accept: application/json

### Search books by category
GET {{baseUrl}}/api/books?search=Mystery&page=1&pageSize=10
Accept: application/json

### Get book by ID (includes authors, categories)
GET {{baseUrl}}/api/books/1
Accept: application/json

### Create a new book
POST {{baseUrl}}/api/books
Content-Type: application/json

{
  "title": "Fahrenheit 451",
  "isbn": "978-1-4516-7331-8",
  "publisher": "Ballantine Books",
  "publicationYear": 1953,
  "description": "A dystopian novel about a future society where books are outlawed.",
  "pageCount": 249,
  "language": "English",
  "totalCopies": 3,
  "authorIds": [],
  "categoryIds": [1, 2]
}

### Update a book
PUT {{baseUrl}}/api/books/1
Content-Type: application/json

{
  "title": "To Kill a Mockingbird",
  "isbn": "978-0-06-112008-4",
  "publisher": "J.B. Lippincott & Co.",
  "publicationYear": 1960,
  "description": "A novel about racial injustice in the Deep South, a classic of modern American literature.",
  "pageCount": 281,
  "language": "English",
  "totalCopies": 4,
  "authorIds": [1],
  "categoryIds": [1, 7]
}

### Delete a book (will fail if book has active loans)
DELETE {{baseUrl}}/api/books/1
Accept: application/json

### Get book loan history
GET {{baseUrl}}/api/books/1/loans?page=1&pageSize=10
Accept: application/json

### Get book reservations queue
GET {{baseUrl}}/api/books/8/reservations?page=1&pageSize=10
Accept: application/json

### ============================================================
### Patrons
### ============================================================

### List all patrons
GET {{baseUrl}}/api/patrons?page=1&pageSize=10
Accept: application/json

### Search patrons by name
GET {{baseUrl}}/api/patrons?search=Alice&page=1&pageSize=10
Accept: application/json

### Filter patrons by membership type
GET {{baseUrl}}/api/patrons?membershipType=Premium&page=1&pageSize=10
Accept: application/json

### Get patron by ID (includes active loans count and unpaid fines)
GET {{baseUrl}}/api/patrons/1
Accept: application/json

### Create a new patron
POST {{baseUrl}}/api/patrons
Content-Type: application/json

{
  "firstName": "Hannah",
  "lastName": "Martinez",
  "email": "hannah.martinez@email.com",
  "phone": "555-0108",
  "address": "258 Spruce Street",
  "membershipType": "Standard"
}

### Update a patron
PUT {{baseUrl}}/api/patrons/1
Content-Type: application/json

{
  "firstName": "Alice",
  "lastName": "Johnson",
  "email": "alice.johnson@email.com",
  "phone": "555-0101",
  "address": "123 Oak Street, Apt 4B",
  "membershipType": "Premium"
}

### Deactivate a patron (fails if patron has active loans)
DELETE {{baseUrl}}/api/patrons/1
Accept: application/json

### Get patron's loans (all)
GET {{baseUrl}}/api/patrons/1/loans?page=1&pageSize=10
Accept: application/json

### Get patron's active loans
GET {{baseUrl}}/api/patrons/1/loans?status=Active&page=1&pageSize=10
Accept: application/json

### Get patron's reservations
GET {{baseUrl}}/api/patrons/1/reservations?page=1&pageSize=10
Accept: application/json

### Get patron's fines
GET {{baseUrl}}/api/patrons/4/fines?page=1&pageSize=10
Accept: application/json

### Get patron's unpaid fines
GET {{baseUrl}}/api/patrons/4/fines?status=Unpaid&page=1&pageSize=10
Accept: application/json

### ============================================================
### Loans
### ============================================================

### List all loans
GET {{baseUrl}}/api/loans?page=1&pageSize=10
Accept: application/json

### Filter loans by status
GET {{baseUrl}}/api/loans?status=Active&page=1&pageSize=10
Accept: application/json

### Filter overdue loans
GET {{baseUrl}}/api/loans?overdue=true&page=1&pageSize=10
Accept: application/json

### Get loan by ID
GET {{baseUrl}}/api/loans/1
Accept: application/json

### Check out a book (valid checkout)
POST {{baseUrl}}/api/loans
Content-Type: application/json

{
  "bookId": 6,
  "patronId": 5
}

### Return a book
POST {{baseUrl}}/api/loans/1/return
Accept: application/json

### Renew a loan
POST {{baseUrl}}/api/loans/3/renew
Accept: application/json

### Get all overdue loans (also flags overdue loans)
GET {{baseUrl}}/api/loans/overdue?page=1&pageSize=10
Accept: application/json

### ============================================================
### Business Rule Tests - Loans
### ============================================================

### FAIL: Checkout for inactive patron (patron 6 is inactive)
POST {{baseUrl}}/api/loans
Content-Type: application/json

{
  "bookId": 6,
  "patronId": 6
}

### FAIL: Checkout when no copies available (book 8 has 0 available)
POST {{baseUrl}}/api/loans
Content-Type: application/json

{
  "bookId": 8,
  "patronId": 5
}

### FAIL: Renew overdue loan (loan 6 is overdue)
POST {{baseUrl}}/api/loans/6/renew
Accept: application/json

### ============================================================
### Reservations
### ============================================================

### List all reservations
GET {{baseUrl}}/api/reservations?page=1&pageSize=10
Accept: application/json

### Filter reservations by status
GET {{baseUrl}}/api/reservations?status=Pending&page=1&pageSize=10
Accept: application/json

### Get reservation by ID
GET {{baseUrl}}/api/reservations/1
Accept: application/json

### Create a reservation
POST {{baseUrl}}/api/reservations
Content-Type: application/json

{
  "bookId": 1,
  "patronId": 5
}

### Cancel a reservation
POST {{baseUrl}}/api/reservations/2/cancel
Accept: application/json

### Fulfill a ready reservation (reservation 4 is Ready)
POST {{baseUrl}}/api/reservations/4/fulfill
Accept: application/json

### ============================================================
### Business Rule Tests - Reservations
### ============================================================

### FAIL: Reserve a book patron already has on active loan (patron 3 has book 8)
POST {{baseUrl}}/api/reservations
Content-Type: application/json

{
  "bookId": 8,
  "patronId": 3
}

### ============================================================
### Fines
### ============================================================

### List all fines
GET {{baseUrl}}/api/fines?page=1&pageSize=10
Accept: application/json

### Filter unpaid fines
GET {{baseUrl}}/api/fines?status=Unpaid&page=1&pageSize=10
Accept: application/json

### Get fine by ID
GET {{baseUrl}}/api/fines/1
Accept: application/json

### Pay a fine
POST {{baseUrl}}/api/fines/1/pay
Accept: application/json

### Waive a fine
POST {{baseUrl}}/api/fines/2/waive
Accept: application/json
