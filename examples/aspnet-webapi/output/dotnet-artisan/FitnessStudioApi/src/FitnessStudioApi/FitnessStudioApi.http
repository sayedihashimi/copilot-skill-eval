@baseUrl = http://localhost:5250

### ============================================================
### Membership Plans
### ============================================================

### List all active membership plans
GET {{baseUrl}}/api/membership-plans

### Get plan details
GET {{baseUrl}}/api/membership-plans/1

### Create a new plan
POST {{baseUrl}}/api/membership-plans
Content-Type: application/json

{
  "name": "Student",
  "description": "Discounted plan for students",
  "durationMonths": 3,
  "price": 19.99,
  "maxClassBookingsPerWeek": 2,
  "allowsPremiumClasses": false
}

### Update a plan
PUT {{baseUrl}}/api/membership-plans/1
Content-Type: application/json

{
  "name": "Basic",
  "description": "Access to standard classes, up to 3 per week. Updated!",
  "durationMonths": 1,
  "price": 34.99,
  "maxClassBookingsPerWeek": 3,
  "allowsPremiumClasses": false,
  "isActive": true
}

### Deactivate a plan (soft delete)
DELETE {{baseUrl}}/api/membership-plans/1

### ============================================================
### Members
### ============================================================

### List members (all)
GET {{baseUrl}}/api/members?page=1&pageSize=10

### Search members by name
GET {{baseUrl}}/api/members?search=alice&page=1&pageSize=10

### Filter active members only
GET {{baseUrl}}/api/members?isActive=true&page=1&pageSize=5

### Get member details (includes active membership)
GET {{baseUrl}}/api/members/1

### Register a new member
POST {{baseUrl}}/api/members
Content-Type: application/json

{
  "firstName": "Sofia",
  "lastName": "Garcia",
  "email": "sofia.garcia@example.com",
  "phone": "555-0901",
  "dateOfBirth": "1996-08-20",
  "emergencyContactName": "Luis Garcia",
  "emergencyContactPhone": "555-0902"
}

### Update member profile
PUT {{baseUrl}}/api/members/1
Content-Type: application/json

{
  "firstName": "Alice",
  "lastName": "Johnson",
  "email": "alice.johnson@example.com",
  "phone": "555-0101-updated",
  "emergencyContactName": "Bob Johnson",
  "emergencyContactPhone": "555-0102"
}

### Deactivate member (fails if future bookings exist)
DELETE {{baseUrl}}/api/members/8

### Get member's bookings
GET {{baseUrl}}/api/members/1/bookings?page=1&pageSize=10

### Get member's bookings filtered by status
GET {{baseUrl}}/api/members/1/bookings?status=Confirmed&page=1&pageSize=10

### Get member's upcoming bookings
GET {{baseUrl}}/api/members/1/bookings/upcoming

### Get member's membership history
GET {{baseUrl}}/api/members/1/memberships

### ============================================================
### Memberships
### ============================================================

### Create a membership (for a member without one)
POST {{baseUrl}}/api/memberships
Content-Type: application/json

{
  "memberId": 7,
  "membershipPlanId": 2,
  "startDate": "2026-03-25",
  "paymentStatus": "Paid"
}

### Get membership details
GET {{baseUrl}}/api/memberships/1

### Cancel a membership
POST {{baseUrl}}/api/memberships/4/cancel
Content-Type: application/json

{}

### Freeze a membership (7-30 days)
POST {{baseUrl}}/api/memberships/1/freeze
Content-Type: application/json

{
  "freezeDays": 14
}

### Unfreeze a membership
POST {{baseUrl}}/api/memberships/1/unfreeze
Content-Type: application/json

{}

### Renew an expired membership (member 7 has expired membership #7)
POST {{baseUrl}}/api/memberships/7/renew
Content-Type: application/json

{}

### ============================================================
### Instructors
### ============================================================

### List all instructors
GET {{baseUrl}}/api/instructors

### Filter by specialization
GET {{baseUrl}}/api/instructors?specialization=Yoga

### Filter active only
GET {{baseUrl}}/api/instructors?isActive=true

### Get instructor details
GET {{baseUrl}}/api/instructors/1

### Create an instructor
POST {{baseUrl}}/api/instructors
Content-Type: application/json

{
  "firstName": "Liam",
  "lastName": "Foster",
  "email": "liam.f@zenithfitness.com",
  "phone": "555-1005",
  "bio": "CrossFit certified trainer and nutrition coach.",
  "specializations": "HIIT, CrossFit",
  "hireDate": "2026-01-15"
}

### Update an instructor
PUT {{baseUrl}}/api/instructors/1
Content-Type: application/json

{
  "firstName": "Sarah",
  "lastName": "Martinez",
  "email": "sarah.m@zenithfitness.com",
  "phone": "555-1001",
  "bio": "Certified yoga and Pilates instructor with 12 years of experience.",
  "specializations": "Yoga, Pilates, Meditation, Barre",
  "isActive": true
}

### Get instructor's schedule
GET {{baseUrl}}/api/instructors/1/schedule

### Get instructor's schedule for a date range
GET {{baseUrl}}/api/instructors/2/schedule?fromDate=2026-03-26&toDate=2026-03-30

### ============================================================
### Class Types
### ============================================================

### List all class types
GET {{baseUrl}}/api/class-types

### Filter by difficulty
GET {{baseUrl}}/api/class-types?difficulty=Advanced

### Filter premium classes only
GET {{baseUrl}}/api/class-types?isPremium=true

### Get class type details
GET {{baseUrl}}/api/class-types/1

### Create a class type
POST {{baseUrl}}/api/class-types
Content-Type: application/json

{
  "name": "Zumba",
  "description": "Dance-based fitness class with Latin music",
  "defaultDurationMinutes": 60,
  "defaultCapacity": 25,
  "isPremium": false,
  "caloriesPerSession": 400,
  "difficultyLevel": "Beginner"
}

### Update a class type
PUT {{baseUrl}}/api/class-types/1
Content-Type: application/json

{
  "name": "Yoga",
  "description": "Vinyasa flow yoga for all levels. Improve flexibility and mindfulness.",
  "defaultDurationMinutes": 75,
  "defaultCapacity": 20,
  "isPremium": false,
  "caloriesPerSession": 300,
  "difficultyLevel": "AllLevels",
  "isActive": true
}

### ============================================================
### Class Schedules
### ============================================================

### List all scheduled classes
GET {{baseUrl}}/api/classes?page=1&pageSize=20

### Filter by class type
GET {{baseUrl}}/api/classes?classTypeId=1&page=1&pageSize=10

### Filter by instructor
GET {{baseUrl}}/api/classes?instructorId=2&page=1&pageSize=10

### Filter available classes only
GET {{baseUrl}}/api/classes?hasAvailability=true&page=1&pageSize=10

### Filter by date range
GET {{baseUrl}}/api/classes?fromDate=2026-03-27&toDate=2026-03-29&page=1&pageSize=10

### Get class details
GET {{baseUrl}}/api/classes/1

### Schedule a new class
POST {{baseUrl}}/api/classes
Content-Type: application/json

{
  "classTypeId": 1,
  "instructorId": 3,
  "startTime": "2026-03-31T10:00:00",
  "endTime": "2026-03-31T11:00:00",
  "capacity": 20,
  "room": "Studio A"
}

### Update a class
PUT {{baseUrl}}/api/classes/1
Content-Type: application/json

{
  "classTypeId": 1,
  "instructorId": 1,
  "startTime": "2026-03-27T08:00:00",
  "endTime": "2026-03-27T09:00:00",
  "capacity": 25,
  "room": "Studio A"
}

### Cancel a class (cascades to all bookings)
PATCH {{baseUrl}}/api/classes/8/cancel
Content-Type: application/json

{
  "reason": "Instructor unavailable due to illness"
}

### Get class roster (confirmed members)
GET {{baseUrl}}/api/classes/1/roster

### Get class waitlist
GET {{baseUrl}}/api/classes/3/waitlist

### Get available classes in next 7 days
GET {{baseUrl}}/api/classes/available

### ============================================================
### Bookings
### ============================================================

### Book a class (member 4, Premium plan, standard class)
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 6,
  "memberId": 4
}

### Get booking details
GET {{baseUrl}}/api/bookings/1

### Cancel a booking (promotes from waitlist if applicable)
POST {{baseUrl}}/api/bookings/1/cancel
Content-Type: application/json

{
  "reason": "Schedule conflict"
}

### Check in for a class (works within 15 min window of class start)
POST {{baseUrl}}/api/bookings/1/check-in
Content-Type: application/json

{}

### Mark booking as no-show (works 15 min after class start)
POST {{baseUrl}}/api/bookings/1/no-show
Content-Type: application/json

{}

### ============================================================
### Business Rule Test Scenarios
### ============================================================

### TEST: Basic member trying to book a premium class (should fail - Pilates is premium)
### Member 3 (Diana) has Basic plan
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 4,
  "memberId": 3
}

### TEST: Booking a class more than 7 days in advance (should fail)
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 1,
  "memberId": 1
}

### TEST: Member without active membership trying to book (member 7 has expired)
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 1,
  "memberId": 7
}

### TEST: Instructor schedule conflict (schedule class at same time as existing)
POST {{baseUrl}}/api/classes
Content-Type: application/json

{
  "classTypeId": 2,
  "instructorId": 1,
  "startTime": "2026-03-27T07:30:00",
  "endTime": "2026-03-27T08:15:00",
  "room": "Studio B"
}
