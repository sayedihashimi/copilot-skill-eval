@baseUrl = http://localhost:5179

### =====================
### Owners
### =====================

### List all owners
GET {{baseUrl}}/api/owners?page=1&pageSize=10

### Search owners by name
GET {{baseUrl}}/api/owners?search=Johnson

### Get owner by ID (includes pets)
GET {{baseUrl}}/api/owners/1

### Create a new owner
POST {{baseUrl}}/api/owners
Content-Type: application/json

{
  "firstName": "David",
  "lastName": "Martinez",
  "email": "david.martinez@email.com",
  "phone": "555-0106",
  "address": "987 Birch Way",
  "city": "Miami",
  "state": "FL",
  "zipCode": "33101"
}

### Update an owner
PUT {{baseUrl}}/api/owners/1
Content-Type: application/json

{
  "firstName": "Sarah",
  "lastName": "Johnson",
  "email": "sarah.johnson@email.com",
  "phone": "555-0101",
  "address": "123 Oak Street, Apt 4B",
  "city": "Springfield",
  "state": "IL",
  "zipCode": "62701"
}

### Delete an owner (will fail if owner has active pets)
DELETE {{baseUrl}}/api/owners/5

### Get all pets for an owner
GET {{baseUrl}}/api/owners/1/pets

### Get appointment history for an owner's pets
GET {{baseUrl}}/api/owners/1/appointments?page=1&pageSize=10

### =====================
### Pets
### =====================

### List all active pets
GET {{baseUrl}}/api/pets?page=1&pageSize=10

### Search pets by name
GET {{baseUrl}}/api/pets?search=Buddy

### Filter pets by species
GET {{baseUrl}}/api/pets?species=Dog

### Include inactive pets
GET {{baseUrl}}/api/pets?includeInactive=true

### Get pet by ID (includes owner info)
GET {{baseUrl}}/api/pets/1

### Create a new pet
POST {{baseUrl}}/api/pets
Content-Type: application/json

{
  "name": "Rocky",
  "species": "Dog",
  "breed": "Bulldog",
  "dateOfBirth": "2022-04-10",
  "weight": 25.5,
  "color": "White and Brown",
  "microchipNumber": "MC-009-2022",
  "ownerId": 2
}

### Update a pet (including owner transfer)
PUT {{baseUrl}}/api/pets/1
Content-Type: application/json

{
  "name": "Buddy",
  "species": "Dog",
  "breed": "Golden Retriever",
  "dateOfBirth": "2020-03-15",
  "weight": 33.0,
  "color": "Golden",
  "microchipNumber": "MC-001-2020",
  "ownerId": 1
}

### Soft-delete a pet
DELETE {{baseUrl}}/api/pets/8

### Get all medical records for a pet
GET {{baseUrl}}/api/pets/1/medical-records

### Get all vaccinations for a pet
GET {{baseUrl}}/api/pets/1/vaccinations

### Get upcoming/overdue vaccinations for a pet
GET {{baseUrl}}/api/pets/3/vaccinations/upcoming

### Get active prescriptions for a pet
GET {{baseUrl}}/api/pets/1/prescriptions/active

### =====================
### Veterinarians
### =====================

### List all veterinarians
GET {{baseUrl}}/api/veterinarians?page=1&pageSize=10

### Filter by specialization
GET {{baseUrl}}/api/veterinarians?specialization=Surgery

### Filter by availability
GET {{baseUrl}}/api/veterinarians?isAvailable=true

### Get veterinarian by ID
GET {{baseUrl}}/api/veterinarians/1

### Create a new veterinarian
POST {{baseUrl}}/api/veterinarians
Content-Type: application/json

{
  "firstName": "Dr. Kevin",
  "lastName": "Park",
  "email": "kevin.park@happypaws.com",
  "phone": "555-0204",
  "specialization": "Dermatology",
  "licenseNumber": "VET-2022-004",
  "hireDate": "2022-06-15"
}

### Update a veterinarian
PUT {{baseUrl}}/api/veterinarians/1
Content-Type: application/json

{
  "firstName": "Dr. Amanda",
  "lastName": "Foster",
  "email": "amanda.foster@happypaws.com",
  "phone": "555-0201",
  "specialization": "General Practice",
  "licenseNumber": "VET-2015-001",
  "isAvailable": true
}

### Get vet's schedule for today
GET {{baseUrl}}/api/veterinarians/1/schedule

### Get vet's schedule for a specific date
GET {{baseUrl}}/api/veterinarians/1/schedule?date=2026-03-28

### Get all appointments for a vet
GET {{baseUrl}}/api/veterinarians/1/appointments?page=1&pageSize=10

### Get completed appointments for a vet
GET {{baseUrl}}/api/veterinarians/1/appointments?status=Completed

### =====================
### Appointments
### =====================

### List all appointments
GET {{baseUrl}}/api/appointments?page=1&pageSize=10

### Filter by status
GET {{baseUrl}}/api/appointments?status=Scheduled

### Filter by date range
GET {{baseUrl}}/api/appointments?fromDate=2026-03-01&toDate=2026-04-30

### Filter by vet
GET {{baseUrl}}/api/appointments?vetId=1

### Get today's appointments
GET {{baseUrl}}/api/appointments/today

### Get appointment by ID (with pet, vet, and medical record)
GET {{baseUrl}}/api/appointments/1

### Schedule a new appointment
POST {{baseUrl}}/api/appointments
Content-Type: application/json

{
  "petId": 2,
  "veterinarianId": 3,
  "appointmentDate": "2026-04-15T14:00:00Z",
  "durationMinutes": 30,
  "reason": "Annual wellness checkup",
  "notes": "Owner reports cat has been sneezing occasionally"
}

### Update appointment
PUT {{baseUrl}}/api/appointments/7
Content-Type: application/json

{
  "petId": 1,
  "veterinarianId": 2,
  "appointmentDate": "2026-04-01T10:00:00Z",
  "durationMinutes": 45,
  "reason": "Vaccination booster and general checkup",
  "notes": "Include weight check"
}

### Update appointment status - Check In
PATCH {{baseUrl}}/api/appointments/6/status
Content-Type: application/json

{
  "status": "CheckedIn"
}

### Update appointment status - Start (InProgress)
PATCH {{baseUrl}}/api/appointments/6/status
Content-Type: application/json

{
  "status": "InProgress"
}

### Update appointment status - Complete
PATCH {{baseUrl}}/api/appointments/6/status
Content-Type: application/json

{
  "status": "Completed"
}

### Update appointment status - Cancel (requires reason)
PATCH {{baseUrl}}/api/appointments/9/status
Content-Type: application/json

{
  "status": "Cancelled",
  "cancellationReason": "Owner requested reschedule due to travel"
}

### =====================
### Medical Records
### =====================

### Get medical record by ID (with prescriptions)
GET {{baseUrl}}/api/medical-records/1

### Create a medical record (appointment must be Completed or InProgress)
POST {{baseUrl}}/api/medical-records
Content-Type: application/json

{
  "appointmentId": 4,
  "petId": 5,
  "veterinarianId": 3,
  "diagnosis": "Bilateral otitis externa - resolving",
  "treatment": "Continue ear drops for 5 more days, ear cleaned",
  "notes": "Significant improvement since last visit",
  "followUpDate": "2026-04-10"
}

### Update a medical record
PUT {{baseUrl}}/api/medical-records/1
Content-Type: application/json

{
  "diagnosis": "Healthy — no issues found, excellent condition",
  "treatment": "Annual vaccinations administered (DHPP, Rabies). Dental check performed.",
  "notes": "Weight stable at 32.5kg, teeth in good condition, heart and lungs clear",
  "followUpDate": "2027-03-25"
}

### =====================
### Prescriptions
### =====================

### Get prescription by ID
GET {{baseUrl}}/api/prescriptions/1

### Create a new prescription
POST {{baseUrl}}/api/prescriptions
Content-Type: application/json

{
  "medicalRecordId": 1,
  "medicationName": "Frontline Plus",
  "dosage": "1 application monthly",
  "durationDays": 90,
  "startDate": "2026-03-25",
  "instructions": "Apply between shoulder blades. Do not bathe for 48 hours after application."
}

### =====================
### Vaccinations
### =====================

### Get vaccination by ID
GET {{baseUrl}}/api/vaccinations/1

### Record a new vaccination
POST {{baseUrl}}/api/vaccinations
Content-Type: application/json

{
  "petId": 3,
  "vaccineName": "DHPP",
  "dateAdministered": "2026-03-25",
  "expirationDate": "2027-03-25",
  "batchNumber": "DHPP-2026-G7",
  "administeredByVetId": 2,
  "notes": "Annual booster"
}
