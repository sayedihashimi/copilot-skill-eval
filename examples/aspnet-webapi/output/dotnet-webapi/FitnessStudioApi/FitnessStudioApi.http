@baseUrl = http://localhost:5176

### ==========================================
### Membership Plans
### ==========================================

### List all active membership plans
GET {{baseUrl}}/api/membership-plans

### Get membership plan by ID
GET {{baseUrl}}/api/membership-plans/1

### Create a new membership plan
POST {{baseUrl}}/api/membership-plans
Content-Type: application/json

{
  "name": "Student",
  "description": "Discounted plan for students",
  "durationMonths": 1,
  "price": 19.99,
  "maxClassBookingsPerWeek": 2,
  "allowsPremiumClasses": false
}

### Update a membership plan
PUT {{baseUrl}}/api/membership-plans/1
Content-Type: application/json

{
  "name": "Basic",
  "description": "Access to standard classes, 3 bookings per week - updated",
  "durationMonths": 1,
  "price": 34.99,
  "maxClassBookingsPerWeek": 3,
  "allowsPremiumClasses": false,
  "isActive": true
}

### Deactivate a membership plan (soft delete)
DELETE {{baseUrl}}/api/membership-plans/1

### ==========================================
### Members
### ==========================================

### List all members (with pagination)
GET {{baseUrl}}/api/members?page=1&pageSize=10

### Search members by name
GET {{baseUrl}}/api/members?search=alice

### Filter active members only
GET {{baseUrl}}/api/members?isActive=true&page=1&pageSize=5

### Get member by ID (includes active membership info)
GET {{baseUrl}}/api/members/1

### Register a new member
POST {{baseUrl}}/api/members
Content-Type: application/json

{
  "firstName": "Zoe",
  "lastName": "Parker",
  "email": "zoe.parker@email.com",
  "phone": "555-0901",
  "dateOfBirth": "2000-05-20",
  "emergencyContactName": "Tom Parker",
  "emergencyContactPhone": "555-0902"
}

### Update member profile
PUT {{baseUrl}}/api/members/1
Content-Type: application/json

{
  "firstName": "Alice",
  "lastName": "Johnson",
  "email": "alice.johnson@email.com",
  "phone": "555-0103",
  "emergencyContactName": "Bob Johnson",
  "emergencyContactPhone": "555-0102"
}

### Deactivate a member (fails if they have future bookings)
DELETE {{baseUrl}}/api/members/8

### Get member's bookings (with filters)
GET {{baseUrl}}/api/members/1/bookings?page=1&pageSize=10

### Get member's bookings filtered by status
GET {{baseUrl}}/api/members/1/bookings?status=Confirmed&page=1&pageSize=10

### Get member's upcoming confirmed bookings
GET {{baseUrl}}/api/members/1/bookings/upcoming

### Get membership history for a member
GET {{baseUrl}}/api/members/1/memberships

### ==========================================
### Memberships
### ==========================================

### Create a membership for a member (member 7 has expired membership)
POST {{baseUrl}}/api/memberships
Content-Type: application/json

{
  "memberId": 7,
  "membershipPlanId": 2,
  "startDate": "2026-03-25"
}

### Get membership details
GET {{baseUrl}}/api/memberships/1

### Cancel a membership
POST {{baseUrl}}/api/memberships/1/cancel

### Freeze a membership (7-30 days)
POST {{baseUrl}}/api/memberships/2/freeze
Content-Type: application/json

{
  "freezeDurationDays": 14
}

### Unfreeze a membership
POST {{baseUrl}}/api/memberships/2/unfreeze

### Renew an expired membership (member 8's expired membership)
POST {{baseUrl}}/api/memberships/8/renew

### ==========================================
### Instructors
### ==========================================

### List all instructors
GET {{baseUrl}}/api/instructors

### Filter instructors by specialization
GET {{baseUrl}}/api/instructors?specialization=yoga

### Filter active instructors
GET {{baseUrl}}/api/instructors?isActive=true

### Get instructor by ID
GET {{baseUrl}}/api/instructors/1

### Create a new instructor
POST {{baseUrl}}/api/instructors
Content-Type: application/json

{
  "firstName": "Anna",
  "lastName": "Lee",
  "email": "anna.lee@zenith.com",
  "phone": "555-1005",
  "bio": "Certified Zumba and dance fitness instructor.",
  "specializations": "Zumba, Dance",
  "hireDate": "2025-01-15"
}

### Update an instructor
PUT {{baseUrl}}/api/instructors/1
Content-Type: application/json

{
  "firstName": "Sarah",
  "lastName": "Mitchell",
  "email": "sarah.mitchell@zenith.com",
  "phone": "555-1001",
  "bio": "Certified yoga and pilates instructor with 12 years experience. RYT-500 certified.",
  "specializations": "Yoga, Pilates, Meditation, Barre",
  "isActive": true
}

### Get instructor's class schedule
GET {{baseUrl}}/api/instructors/1/schedule

### Get instructor's schedule filtered by date range
GET {{baseUrl}}/api/instructors/2/schedule?fromDate=2026-03-26&toDate=2026-04-02

### ==========================================
### Class Types
### ==========================================

### List all class types
GET {{baseUrl}}/api/class-types

### Filter by difficulty level
GET {{baseUrl}}/api/class-types?difficulty=Advanced

### Filter premium classes only
GET {{baseUrl}}/api/class-types?isPremium=true

### Get class type by ID
GET {{baseUrl}}/api/class-types/1

### Create a new class type
POST {{baseUrl}}/api/class-types
Content-Type: application/json

{
  "name": "Barre",
  "description": "Ballet-inspired fitness class for toning and flexibility",
  "defaultDurationMinutes": 55,
  "defaultCapacity": 18,
  "isPremium": false,
  "caloriesPerSession": 350,
  "difficultyLevel": "Intermediate"
}

### Update a class type
PUT {{baseUrl}}/api/class-types/1
Content-Type: application/json

{
  "name": "Yoga",
  "description": "Traditional yoga focusing on flexibility, mindfulness, and breathing",
  "defaultDurationMinutes": 60,
  "defaultCapacity": 22,
  "isPremium": false,
  "caloriesPerSession": 280,
  "difficultyLevel": "AllLevels",
  "isActive": true
}

### ==========================================
### Class Schedules
### ==========================================

### List all scheduled classes (with pagination)
GET {{baseUrl}}/api/classes?page=1&pageSize=10

### Filter by date range
GET {{baseUrl}}/api/classes?fromDate=2026-03-26&toDate=2026-04-02&page=1&pageSize=20

### Filter by class type
GET {{baseUrl}}/api/classes?classTypeId=1&page=1&pageSize=10

### Filter classes with availability
GET {{baseUrl}}/api/classes?hasAvailability=true&page=1&pageSize=10

### Get class details by ID
GET {{baseUrl}}/api/classes/1

### Schedule a new class
POST {{baseUrl}}/api/classes
Content-Type: application/json

{
  "classTypeId": 1,
  "instructorId": 3,
  "startTime": "2026-03-30T09:00:00",
  "capacity": 20,
  "room": "Studio A"
}

### Update class details
PUT {{baseUrl}}/api/classes/1
Content-Type: application/json

{
  "instructorId": 1,
  "startTime": "2026-03-26T07:30:00",
  "capacity": 25,
  "room": "Studio A"
}

### Cancel a class (cascades to all bookings)
PATCH {{baseUrl}}/api/classes/7/cancel
Content-Type: application/json

{
  "cancellationReason": "Instructor illness"
}

### Get class roster (confirmed members)
GET {{baseUrl}}/api/classes/1/roster

### Get class waitlist
GET {{baseUrl}}/api/classes/2/waitlist

### Get available classes in next 7 days
GET {{baseUrl}}/api/classes/available

### ==========================================
### Bookings
### ==========================================

### Book a class (member 3 has Basic plan, schedule 1 is Yoga - non-premium)
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 7,
  "memberId": 3
}

### Get booking details
GET {{baseUrl}}/api/bookings/1

### Cancel a booking (promotes waitlist if applicable)
POST {{baseUrl}}/api/bookings/1/cancel
Content-Type: application/json

{
  "cancellationReason": "Unable to attend"
}

### Check in for a class (within 15 min window of class start)
POST {{baseUrl}}/api/bookings/1/check-in

### Mark booking as no-show (after 15 min past class start)
POST {{baseUrl}}/api/bookings/15/no-show

### ==========================================
### Business Rule Tests
### ==========================================

### Test: Basic member trying to book a PREMIUM class (HIIT id=2 is premium)
### Should fail with 400 - Basic plan doesn't include premium classes
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 9,
  "memberId": 3
}

### Test: Member without active membership trying to book
### Member 8 has expired membership - should fail
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 7,
  "memberId": 8
}

### Test: Get a non-existent resource (404)
GET {{baseUrl}}/api/members/9999

### Test: Get waitlist for full class (class 2 has waitlisted members)
GET {{baseUrl}}/api/classes/2/waitlist
