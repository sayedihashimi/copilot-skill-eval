@baseUrl = http://localhost:5156

### ===========================
### Owners
### ===========================

### Get all owners (paginated)
GET {{baseUrl}}/api/owners?page=1&pageSize=10

### Search owners by name
GET {{baseUrl}}/api/owners?search=Johnson

### Get owner by ID (includes pets)
GET {{baseUrl}}/api/owners/1

### Create a new owner
POST {{baseUrl}}/api/owners
Content-Type: application/json

{
  "firstName": "David",
  "lastName": "Martinez",
  "email": "david.martinez@email.com",
  "phone": "555-0106",
  "address": "987 Birch Way",
  "city": "Chicago",
  "state": "IL",
  "zipCode": "60601"
}

### Update an existing owner
PUT {{baseUrl}}/api/owners/1
Content-Type: application/json

{
  "firstName": "Sarah",
  "lastName": "Johnson",
  "email": "sarah.johnson.updated@email.com",
  "phone": "555-0101",
  "address": "123 Oak Street",
  "city": "Portland",
  "state": "OR",
  "zipCode": "97201"
}

### Delete an owner (will fail if owner has active pets)
DELETE {{baseUrl}}/api/owners/5

### Get all pets for an owner
GET {{baseUrl}}/api/owners/1/pets

### Get appointment history for an owner's pets
GET {{baseUrl}}/api/owners/1/appointments?page=1&pageSize=10

### ===========================
### Pets
### ===========================

### Get all active pets (paginated)
GET {{baseUrl}}/api/pets?page=1&pageSize=10

### Search pets by name
GET {{baseUrl}}/api/pets?name=Buddy

### Search pets by species
GET {{baseUrl}}/api/pets?species=Cat

### Get all pets including inactive
GET {{baseUrl}}/api/pets?includeInactive=true

### Get pet by ID (includes owner info)
GET {{baseUrl}}/api/pets/1

### Create a new pet
POST {{baseUrl}}/api/pets
Content-Type: application/json

{
  "name": "Rocky",
  "species": "Dog",
  "breed": "Bulldog",
  "dateOfBirth": "2022-04-10",
  "weight": 25.0,
  "color": "White and Brown",
  "microchipNumber": "MC-009-2022",
  "ownerId": 2
}

### Update a pet (can also transfer ownership)
PUT {{baseUrl}}/api/pets/1
Content-Type: application/json

{
  "name": "Buddy",
  "species": "Dog",
  "breed": "Golden Retriever",
  "dateOfBirth": "2020-03-15",
  "weight": 33.0,
  "color": "Golden",
  "microchipNumber": "MC-001-2020",
  "ownerId": 1
}

### Soft-delete a pet
DELETE {{baseUrl}}/api/pets/8

### Get all medical records for a pet
GET {{baseUrl}}/api/pets/1/medical-records

### Get all vaccinations for a pet
GET {{baseUrl}}/api/pets/1/vaccinations

### Get upcoming/overdue vaccinations for a pet
GET {{baseUrl}}/api/pets/1/vaccinations/upcoming

### Get active prescriptions for a pet
GET {{baseUrl}}/api/pets/1/prescriptions/active

### ===========================
### Veterinarians
### ===========================

### Get all veterinarians
GET {{baseUrl}}/api/veterinarians?page=1&pageSize=10

### Filter by specialization
GET {{baseUrl}}/api/veterinarians?specialization=Surgery

### Filter by availability
GET {{baseUrl}}/api/veterinarians?isAvailable=true

### Get veterinarian by ID
GET {{baseUrl}}/api/veterinarians/1

### Create a new veterinarian
POST {{baseUrl}}/api/veterinarians
Content-Type: application/json

{
  "firstName": "Dr. Maria",
  "lastName": "Santos",
  "email": "maria.santos@happypaws.com",
  "phone": "555-0204",
  "specialization": "Dermatology",
  "licenseNumber": "VET-2022-004",
  "isAvailable": true,
  "hireDate": "2022-06-15"
}

### Update a veterinarian
PUT {{baseUrl}}/api/veterinarians/1
Content-Type: application/json

{
  "firstName": "Dr. Amanda",
  "lastName": "Foster",
  "email": "amanda.foster@happypaws.com",
  "phone": "555-0201",
  "specialization": "General Practice",
  "licenseNumber": "VET-2015-001",
  "isAvailable": true,
  "hireDate": "2015-06-01"
}

### Get vet's schedule for a specific date
GET {{baseUrl}}/api/veterinarians/1/schedule?date=2026-06-15

### Get all appointments for a vet (with status filter)
GET {{baseUrl}}/api/veterinarians/1/appointments?status=Scheduled&page=1&pageSize=10

### ===========================
### Appointments
### ===========================

### Get all appointments (paginated)
GET {{baseUrl}}/api/appointments?page=1&pageSize=10

### Filter by date range
GET {{baseUrl}}/api/appointments?dateFrom=2026-01-01&dateTo=2026-12-31

### Filter by status
GET {{baseUrl}}/api/appointments?status=Scheduled

### Filter by veterinarian
GET {{baseUrl}}/api/appointments?vetId=1

### Filter by pet
GET {{baseUrl}}/api/appointments?petId=1

### Get appointment by ID (includes pet, vet, medical record)
GET {{baseUrl}}/api/appointments/1

### Schedule a new appointment
POST {{baseUrl}}/api/appointments
Content-Type: application/json

{
  "petId": 4,
  "veterinarianId": 3,
  "appointmentDate": "2026-07-20T10:00:00Z",
  "durationMinutes": 30,
  "reason": "Annual dental checkup",
  "notes": "Owner reports bad breath"
}

### Update appointment details
PUT {{baseUrl}}/api/appointments/5
Content-Type: application/json

{
  "petId": 5,
  "veterinarianId": 1,
  "appointmentDate": "2026-06-15T10:00:00Z",
  "durationMinutes": 45,
  "reason": "Puppy wellness check and vaccinations",
  "notes": "First visit - bring vaccination records"
}

### Update appointment status - Check in
PATCH {{baseUrl}}/api/appointments/5/status
Content-Type: application/json

{
  "status": "CheckedIn"
}

### Update appointment status - Start
PATCH {{baseUrl}}/api/appointments/5/status
Content-Type: application/json

{
  "status": "InProgress"
}

### Update appointment status - Complete
PATCH {{baseUrl}}/api/appointments/5/status
Content-Type: application/json

{
  "status": "Completed"
}

### Update appointment status - Cancel (requires reason)
PATCH {{baseUrl}}/api/appointments/6/status
Content-Type: application/json

{
  "status": "Cancelled",
  "cancellationReason": "Pet owner requested reschedule due to travel"
}

### Get today's appointments
GET {{baseUrl}}/api/appointments/today

### ===========================
### Medical Records
### ===========================

### Get medical record by ID (with prescriptions)
GET {{baseUrl}}/api/medical-records/1

### Create a medical record (appointment must be Completed or InProgress)
POST {{baseUrl}}/api/medical-records
Content-Type: application/json

{
  "appointmentId": 5,
  "petId": 5,
  "veterinarianId": 1,
  "diagnosis": "Healthy puppy, normal development",
  "treatment": "Wellness exam completed. DHPP vaccine administered.",
  "notes": "Weight gain on track. Recommend dental chew treats.",
  "followUpDate": "2026-09-15"
}

### Update a medical record
PUT {{baseUrl}}/api/medical-records/1
Content-Type: application/json

{
  "diagnosis": "Healthy, no concerns - updated",
  "treatment": "Routine wellness exam completed. All vitals normal. Blood work ordered.",
  "notes": "Weight stable, coat healthy. Recommend senior diet starting next year.",
  "followUpDate": "2026-07-05"
}

### ===========================
### Prescriptions
### ===========================

### Get prescription by ID
GET {{baseUrl}}/api/prescriptions/1

### Create a new prescription
POST {{baseUrl}}/api/prescriptions
Content-Type: application/json

{
  "medicalRecordId": 1,
  "medicationName": "Apoquel",
  "dosage": "16mg once daily",
  "durationDays": 30,
  "startDate": "2026-03-25",
  "instructions": "Give with food in the morning. Monitor for any GI upset."
}

### ===========================
### Vaccinations
### ===========================

### Get vaccination by ID
GET {{baseUrl}}/api/vaccinations/1

### Record a new vaccination
POST {{baseUrl}}/api/vaccinations
Content-Type: application/json

{
  "petId": 5,
  "vaccineName": "Rabies",
  "dateAdministered": "2026-03-25",
  "expirationDate": "2027-03-25",
  "batchNumber": "RAB-2026-050",
  "administeredByVetId": 1,
  "notes": "First rabies vaccination"
}
