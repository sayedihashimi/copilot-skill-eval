@baseUrl = http://localhost:5195

### ========================================
### Membership Plans
### ========================================

### List all active plans
GET {{baseUrl}}/api/membership-plans

### Get plan details
GET {{baseUrl}}/api/membership-plans/1

### Create a new plan
POST {{baseUrl}}/api/membership-plans
Content-Type: application/json

{
  "name": "Student",
  "description": "Discounted plan for students, 2 classes per week",
  "durationMonths": 3,
  "price": 19.99,
  "maxClassBookingsPerWeek": 2,
  "allowsPremiumClasses": false
}

### Update a plan
PUT {{baseUrl}}/api/membership-plans/1
Content-Type: application/json

{
  "name": "Basic",
  "description": "Access to standard classes, 3 bookings per week — updated",
  "durationMonths": 1,
  "price": 34.99,
  "maxClassBookingsPerWeek": 3,
  "allowsPremiumClasses": false
}

### Deactivate a plan
DELETE {{baseUrl}}/api/membership-plans/4

### ========================================
### Members
### ========================================

### List members (with search and pagination)
GET {{baseUrl}}/api/members?search=alice&isActive=true&page=1&pageSize=10

### List all members
GET {{baseUrl}}/api/members

### Get member details (includes active membership info)
GET {{baseUrl}}/api/members/1

### Register a new member
POST {{baseUrl}}/api/members
Content-Type: application/json

{
  "firstName": "Taylor",
  "lastName": "Swift",
  "email": "taylor.swift@email.com",
  "phone": "555-0200",
  "dateOfBirth": "1998-05-14",
  "emergencyContactName": "Andrea Swift",
  "emergencyContactPhone": "555-0201"
}

### Update member profile
PUT {{baseUrl}}/api/members/1
Content-Type: application/json

{
  "firstName": "Alice",
  "lastName": "Johnson",
  "email": "alice.johnson@email.com",
  "phone": "555-0101-updated",
  "emergencyContactName": "Bob Johnson",
  "emergencyContactPhone": "555-0102"
}

### Deactivate member (will fail if they have future bookings)
DELETE {{baseUrl}}/api/members/8

### Get member's bookings (with filters)
GET {{baseUrl}}/api/members/1/bookings?status=Confirmed&page=1&pageSize=10

### Get member's upcoming confirmed bookings
GET {{baseUrl}}/api/members/1/bookings/upcoming

### Get membership history
GET {{baseUrl}}/api/members/4/memberships

### ========================================
### Memberships
### ========================================

### Purchase a membership for a member (Ryan Patel — has expired membership)
POST {{baseUrl}}/api/memberships
Content-Type: application/json

{
  "memberId": 8,
  "membershipPlanId": 2,
  "startDate": "2026-03-25",
  "paymentStatus": "Paid"
}

### Get membership details
GET {{baseUrl}}/api/memberships/1

### Cancel a membership
POST {{baseUrl}}/api/memberships/1/cancel

### Freeze a membership (7-30 days)
POST {{baseUrl}}/api/memberships/7/freeze
Content-Type: application/json

{
  "freezeDurationDays": 14
}

### Unfreeze a membership (extends EndDate by freeze duration)
POST {{baseUrl}}/api/memberships/8/unfreeze

### Renew an expired membership
POST {{baseUrl}}/api/memberships/4/renew

### ========================================
### Instructors
### ========================================

### List all instructors
GET {{baseUrl}}/api/instructors

### List instructors by specialization
GET {{baseUrl}}/api/instructors?specialization=Yoga&isActive=true

### Get instructor details
GET {{baseUrl}}/api/instructors/1

### Create an instructor
POST {{baseUrl}}/api/instructors
Content-Type: application/json

{
  "firstName": "Chris",
  "lastName": "Taylor",
  "email": "chris.taylor@zenith.com",
  "phone": "555-0300",
  "bio": "Certified CrossFit trainer with 5 years experience.",
  "specializations": "CrossFit, HIIT, Strength Training",
  "hireDate": "2026-03-01"
}

### Update an instructor
PUT {{baseUrl}}/api/instructors/1
Content-Type: application/json

{
  "firstName": "Maya",
  "lastName": "Singh",
  "email": "maya.singh@zenith.com",
  "phone": "555-0201",
  "bio": "Certified yoga instructor with 12 years of experience in Hatha, Vinyasa, and Yin yoga.",
  "specializations": "Yoga, Pilates, Meditation, Yin Yoga"
}

### Get instructor's schedule
GET {{baseUrl}}/api/instructors/1/schedule

### ========================================
### Class Types
### ========================================

### List all class types
GET {{baseUrl}}/api/class-types

### List premium class types
GET {{baseUrl}}/api/class-types?isPremium=true

### List by difficulty
GET {{baseUrl}}/api/class-types?difficulty=Advanced

### Get class type details
GET {{baseUrl}}/api/class-types/1

### Create a class type
POST {{baseUrl}}/api/class-types
Content-Type: application/json

{
  "name": "CrossFit",
  "description": "Functional fitness combining weightlifting, cardio, and gymnastics",
  "defaultDurationMinutes": 60,
  "defaultCapacity": 12,
  "isPremium": false,
  "caloriesPerSession": 550,
  "difficultyLevel": "Advanced"
}

### Update a class type
PUT {{baseUrl}}/api/class-types/1
Content-Type: application/json

{
  "name": "Yoga",
  "description": "Traditional Hatha and Vinyasa yoga for flexibility, mindfulness, and strength",
  "defaultDurationMinutes": 60,
  "defaultCapacity": 25,
  "isPremium": false,
  "caloriesPerSession": 280,
  "difficultyLevel": "AllLevels"
}

### ========================================
### Class Schedules
### ========================================

### List all scheduled classes
GET {{baseUrl}}/api/classes?page=1&pageSize=20

### List classes with filters
GET {{baseUrl}}/api/classes?classTypeId=1&hasAvailability=true

### Get class details
GET {{baseUrl}}/api/classes/1

### Schedule a new class
POST {{baseUrl}}/api/classes
Content-Type: application/json

{
  "classTypeId": 1,
  "instructorId": 4,
  "startTime": "2026-03-28T06:00:00",
  "durationMinutes": 60,
  "capacity": 20,
  "room": "Studio A"
}

### Update class details
PUT {{baseUrl}}/api/classes/1
Content-Type: application/json

{
  "instructorId": 1,
  "startTime": "2026-03-27T07:30:00",
  "durationMinutes": 75,
  "capacity": 25,
  "room": "Studio A"
}

### Cancel a class (cascades to all bookings)
PATCH {{baseUrl}}/api/classes/2/cancel
Content-Type: application/json

{
  "cancellationReason": "Instructor called in sick"
}

### Get class roster
GET {{baseUrl}}/api/classes/1/roster

### Get class waitlist (use the full Spin class — schedule id 9)
GET {{baseUrl}}/api/classes/9/waitlist

### Get available classes in the next 7 days
GET {{baseUrl}}/api/classes/available

### ========================================
### Bookings
### ========================================

### Book a class (normal booking)
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 4,
  "memberId": 2
}

### Get booking details
GET {{baseUrl}}/api/bookings/1

### Cancel a booking (promotes from waitlist if applicable)
POST {{baseUrl}}/api/bookings/1/cancel
Content-Type: application/json

{
  "cancellationReason": "Personal emergency"
}

### Check in for a class (15 min before to 15 min after start)
POST {{baseUrl}}/api/bookings/1/check-in

### Mark booking as no-show
POST {{baseUrl}}/api/bookings/15/no-show

### ========================================
### Business Rule Tests
### ========================================

### Test: Book a premium class as a Basic member (member 3 = Sofia, Basic plan)
### Expected: 400 — plan does not include premium classes
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 5,
  "memberId": 3
}

### Test: Book when member has frozen membership (member 7 = Olivia, frozen)
### Expected: 400 — frozen membership cannot book
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 4,
  "memberId": 7
}

### Test: Book when member has no active membership (member 8 = Ryan, expired)
### Expected: 400 — no active membership
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 4,
  "memberId": 8
}

### Test: Book a cancelled class (schedule 12 is cancelled)
### Expected: 400 — cannot book cancelled class
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 12,
  "memberId": 1
}
