@VetClinicApi_HostAddress = http://localhost:5044

### Owners

### List all owners
GET {{VetClinicApi_HostAddress}}/api/owners?page=1&pageSize=10
Accept: application/json

### Search owners by name
GET {{VetClinicApi_HostAddress}}/api/owners?search=Johnson
Accept: application/json

### Get owner by ID (includes pets)
GET {{VetClinicApi_HostAddress}}/api/owners/1
Accept: application/json

### Create a new owner
POST {{VetClinicApi_HostAddress}}/api/owners
Content-Type: application/json

{
  "firstName": "David",
  "lastName": "Park",
  "email": "david.park@email.com",
  "phone": "555-0106",
  "address": "987 Birch Way",
  "city": "San Francisco",
  "state": "CA",
  "zipCode": "94101"
}

### Update an owner
PUT {{VetClinicApi_HostAddress}}/api/owners/1
Content-Type: application/json

{
  "firstName": "Sarah",
  "lastName": "Johnson",
  "email": "sarah.johnson@email.com",
  "phone": "555-0101",
  "address": "123 Oak Street Updated",
  "city": "Springfield",
  "state": "IL",
  "zipCode": "62701"
}

### Delete an owner (will fail if owner has active pets)
DELETE {{VetClinicApi_HostAddress}}/api/owners/5

### Get all pets for an owner
GET {{VetClinicApi_HostAddress}}/api/owners/1/pets
Accept: application/json

### Get appointment history for an owner's pets
GET {{VetClinicApi_HostAddress}}/api/owners/1/appointments
Accept: application/json

### Pets

### List all active pets
GET {{VetClinicApi_HostAddress}}/api/pets?page=1&pageSize=10
Accept: application/json

### Search pets by name
GET {{VetClinicApi_HostAddress}}/api/pets?search=Buddy
Accept: application/json

### Filter pets by species
GET {{VetClinicApi_HostAddress}}/api/pets?species=Dog
Accept: application/json

### Include inactive pets
GET {{VetClinicApi_HostAddress}}/api/pets?includeInactive=true
Accept: application/json

### Get pet by ID (includes owner info)
GET {{VetClinicApi_HostAddress}}/api/pets/1
Accept: application/json

### Create a new pet
POST {{VetClinicApi_HostAddress}}/api/pets
Content-Type: application/json

{
  "name": "Shadow",
  "species": "Cat",
  "breed": "Russian Blue",
  "dateOfBirth": "2023-04-10",
  "weight": 5.2,
  "color": "Gray",
  "microchipNumber": "MC-009-2023",
  "ownerId": 2
}

### Update a pet (including owner transfer)
PUT {{VetClinicApi_HostAddress}}/api/pets/1
Content-Type: application/json

{
  "name": "Buddy",
  "species": "Dog",
  "breed": "Golden Retriever",
  "dateOfBirth": "2020-03-15",
  "weight": 33.0,
  "color": "Golden",
  "microchipNumber": "MC-001-2020",
  "ownerId": 1
}

### Soft-delete a pet (set IsActive = false)
DELETE {{VetClinicApi_HostAddress}}/api/pets/8

### Get medical records for a pet
GET {{VetClinicApi_HostAddress}}/api/pets/1/medical-records
Accept: application/json

### Get vaccinations for a pet
GET {{VetClinicApi_HostAddress}}/api/pets/1/vaccinations
Accept: application/json

### Get upcoming/overdue vaccinations for a pet
GET {{VetClinicApi_HostAddress}}/api/pets/3/vaccinations/upcoming
Accept: application/json

### Get active prescriptions for a pet
GET {{VetClinicApi_HostAddress}}/api/pets/3/prescriptions/active
Accept: application/json

### Veterinarians

### List all veterinarians
GET {{VetClinicApi_HostAddress}}/api/veterinarians?page=1&pageSize=10
Accept: application/json

### Filter by specialization
GET {{VetClinicApi_HostAddress}}/api/veterinarians?specialization=Surgery
Accept: application/json

### Filter by availability
GET {{VetClinicApi_HostAddress}}/api/veterinarians?isAvailable=true
Accept: application/json

### Get veterinarian by ID
GET {{VetClinicApi_HostAddress}}/api/veterinarians/1
Accept: application/json

### Create a new veterinarian
POST {{VetClinicApi_HostAddress}}/api/veterinarians
Content-Type: application/json

{
  "firstName": "Thomas",
  "lastName": "Lee",
  "email": "dr.lee@happypaws.com",
  "phone": "555-0204",
  "specialization": "Dermatology",
  "licenseNumber": "VET-2022-004",
  "hireDate": "2022-08-01"
}

### Update a veterinarian
PUT {{VetClinicApi_HostAddress}}/api/veterinarians/1
Content-Type: application/json

{
  "firstName": "Amanda",
  "lastName": "Foster",
  "email": "dr.foster@happypaws.com",
  "phone": "555-0201",
  "specialization": "General Practice",
  "licenseNumber": "VET-2015-001",
  "isAvailable": true
}

### Get vet's schedule for a specific date
GET {{VetClinicApi_HostAddress}}/api/veterinarians/1/schedule?date=2026-03-28
Accept: application/json

### Get all appointments for a vet
GET {{VetClinicApi_HostAddress}}/api/veterinarians/1/appointments?page=1&pageSize=10
Accept: application/json

### Get vet appointments filtered by status
GET {{VetClinicApi_HostAddress}}/api/veterinarians/1/appointments?status=Scheduled
Accept: application/json

### Appointments

### List all appointments
GET {{VetClinicApi_HostAddress}}/api/appointments?page=1&pageSize=10
Accept: application/json

### Filter appointments by date range
GET {{VetClinicApi_HostAddress}}/api/appointments?fromDate=2026-03-01&toDate=2026-04-30
Accept: application/json

### Filter appointments by status
GET {{VetClinicApi_HostAddress}}/api/appointments?status=Scheduled
Accept: application/json

### Filter appointments by vet
GET {{VetClinicApi_HostAddress}}/api/appointments?vetId=1
Accept: application/json

### Filter appointments by pet
GET {{VetClinicApi_HostAddress}}/api/appointments?petId=1
Accept: application/json

### Get appointment by ID (includes pet, vet, medical record)
GET {{VetClinicApi_HostAddress}}/api/appointments/1
Accept: application/json

### Schedule a new appointment
POST {{VetClinicApi_HostAddress}}/api/appointments
Content-Type: application/json

{
  "petId": 1,
  "veterinarianId": 2,
  "appointmentDate": "2026-04-15T10:00:00Z",
  "durationMinutes": 30,
  "reason": "Annual wellness checkup",
  "notes": "Owner reports occasional sneezing"
}

### Update an appointment
PUT {{VetClinicApi_HostAddress}}/api/appointments/6
Content-Type: application/json

{
  "petId": 1,
  "veterinarianId": 1,
  "appointmentDate": "2026-04-01T09:00:00Z",
  "durationMinutes": 45,
  "reason": "Follow-up checkup - extended",
  "notes": "Need extra time for blood work"
}

### Update appointment status - Check In
PATCH {{VetClinicApi_HostAddress}}/api/appointments/6/status
Content-Type: application/json

{
  "status": "CheckedIn"
}

### Update appointment status - Start
PATCH {{VetClinicApi_HostAddress}}/api/appointments/6/status
Content-Type: application/json

{
  "status": "InProgress"
}

### Update appointment status - Complete
PATCH {{VetClinicApi_HostAddress}}/api/appointments/6/status
Content-Type: application/json

{
  "status": "Completed"
}

### Update appointment status - Cancel (requires reason)
PATCH {{VetClinicApi_HostAddress}}/api/appointments/7/status
Content-Type: application/json

{
  "status": "Cancelled",
  "cancellationReason": "Owner requested rescheduling"
}

### Get today's appointments
GET {{VetClinicApi_HostAddress}}/api/appointments/today
Accept: application/json

### Medical Records

### Get medical record with prescriptions
GET {{VetClinicApi_HostAddress}}/api/medical-records/1
Accept: application/json

### Create a medical record (appointment must be Completed or InProgress)
POST {{VetClinicApi_HostAddress}}/api/medical-records
Content-Type: application/json

{
  "appointmentId": 6,
  "petId": 1,
  "veterinarianId": 1,
  "diagnosis": "Mild upper respiratory infection",
  "treatment": "Prescribed antibiotics for 7 days. Rest and monitor symptoms.",
  "notes": "Sneezing and mild nasal discharge observed. No fever.",
  "followUpDate": "2026-04-20"
}

### Update a medical record
PUT {{VetClinicApi_HostAddress}}/api/medical-records/1
Content-Type: application/json

{
  "diagnosis": "Healthy - no issues found during annual exam (updated)",
  "treatment": "Routine wellness examination completed. All vaccinations up to date. Blood work normal.",
  "notes": "Weight is ideal. Teeth in good condition. Heart and lungs clear. Updated after lab results.",
  "followUpDate": "2027-03-25"
}

### Prescriptions

### Get prescription details
GET {{VetClinicApi_HostAddress}}/api/prescriptions/1
Accept: application/json

### Create a prescription for a medical record
POST {{VetClinicApi_HostAddress}}/api/prescriptions
Content-Type: application/json

{
  "medicalRecordId": 1,
  "medicationName": "Amoxicillin",
  "dosage": "250mg twice daily",
  "durationDays": 10,
  "startDate": "2026-03-25",
  "instructions": "Administer with food. Complete the full course."
}

### Get active prescriptions for a pet
GET {{VetClinicApi_HostAddress}}/api/pets/3/prescriptions/active
Accept: application/json

### Vaccinations

### Get vaccination details
GET {{VetClinicApi_HostAddress}}/api/vaccinations/1
Accept: application/json

### Record a new vaccination
POST {{VetClinicApi_HostAddress}}/api/vaccinations
Content-Type: application/json

{
  "petId": 3,
  "vaccineName": "DHPP",
  "dateAdministered": "2026-03-25",
  "expirationDate": "2027-03-25",
  "batchNumber": "DHPP-2026-G7",
  "administeredByVetId": 1,
  "notes": "Annual DHPP booster administered"
}
