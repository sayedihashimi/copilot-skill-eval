@page "{eventId:int}"
@model SparkEvents.Pages.Events.TicketTypesModel

@{
    ViewData["Title"] = "Manage Ticket Types";
}

<section>
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Ticket Types — @Model.Event!.Title</h1>
    </div>

    <h3>Existing Ticket Types</h3>
    @if (Model.TicketTypes.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Price</th>
                        <th>Early-Bird</th>
                        <th>Quantity</th>
                        <th>Sold</th>
                        <th>Active</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var tt in Model.TicketTypes)
                    {
                        <tr>
                            <td>@tt.Name</td>
                            <td>@tt.Price.ToString("C")</td>
                            <td>@(tt.EarlyBirdPrice?.ToString("C") ?? "—")</td>
                            <td>@tt.Quantity</td>
                            <td>@tt.QuantitySold</td>
                            <td>@(tt.IsActive ? "Yes" : "No")</td>
                            <td>
                                <form method="post" asp-page-handler="ToggleActive" class="d-inline">
                                    <input type="hidden" name="ticketTypeId" value="@tt.Id" />
                                    <input type="hidden" name="eventId" value="@Model.Event.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-warning">@(tt.IsActive ? "Deactivate" : "Activate")</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-muted">No ticket types defined.</p>
    }

    <hr />
    <h3>Add Ticket Type</h3>

    <div class="row">
        <div class="col-md-8">
            <form method="post" asp-page-handler="Create">
                <div asp-validation-summary="All" class="text-danger"></div>
                <input type="hidden" name="eventId" value="@Model.Event.Id" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Input.Name" class="form-label"></label>
                        <input asp-for="Input.Name" class="form-control" />
                        <span asp-validation-for="Input.Name" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Input.Description" class="form-label"></label>
                        <input asp-for="Input.Description" class="form-control" />
                        <span asp-validation-for="Input.Description" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-3 mb-3">
                        <label asp-for="Input.Price" class="form-label"></label>
                        <input asp-for="Input.Price" class="form-control" type="number" step="0.01" min="0" />
                        <span asp-validation-for="Input.Price" class="text-danger"></span>
                    </div>
                    <div class="col-md-3 mb-3">
                        <label asp-for="Input.EarlyBirdPrice" class="form-label"></label>
                        <input asp-for="Input.EarlyBirdPrice" class="form-control" type="number" step="0.01" min="0" />
                        <span asp-validation-for="Input.EarlyBirdPrice" class="text-danger"></span>
                    </div>
                    <div class="col-md-3 mb-3">
                        <label asp-for="Input.Quantity" class="form-label"></label>
                        <input asp-for="Input.Quantity" class="form-control" type="number" min="1" />
                        <span asp-validation-for="Input.Quantity" class="text-danger"></span>
                    </div>
                    <div class="col-md-3 mb-3">
                        <label asp-for="Input.SortOrder" class="form-label"></label>
                        <input asp-for="Input.SortOrder" class="form-control" type="number" />
                        <span asp-validation-for="Input.SortOrder" class="text-danger"></span>
                    </div>
                </div>

                <button type="submit" class="btn btn-success">Add Ticket Type</button>
            </form>
        </div>
    </div>

    <div class="mt-3">
        <a asp-page="Details" asp-route-id="@Model.Event.Id" class="btn btn-secondary">Back to Event</a>
    </div>
</section>
