@page "{eventId:int}"
@model SparkEvents.Pages.Events.RosterModel

@{
    ViewData["Title"] = "Event Roster";
}

<section>
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Roster — @Model.Event!.Title</h1>
    </div>

    <form method="get" class="row g-3 mb-4">
        <div class="col-md-4">
            <input asp-for="Search" class="form-control" placeholder="Search by name or confirmation..." />
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-outline-primary">Search</button>
        </div>
    </form>

    @if (Model.Registrations.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Confirmation</th>
                        <th>Attendee</th>
                        <th>Ticket Type</th>
                        <th>Amount Paid</th>
                        <th>Status</th>
                        <th>Check-In</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var reg in Model.Registrations)
                    {
                        <tr>
                            <td>@reg.ConfirmationNumber</td>
                            <td>@reg.Attendee.FullName</td>
                            <td>@reg.TicketType.Name</td>
                            <td>@reg.AmountPaid.ToString("C")</td>
                            <td><partial name="Shared/_StatusBadge" model="@reg.Status.ToString()" /></td>
                            <td>@(reg.CheckIn != null ? reg.CheckIn.CheckInTime.ToString("h:mm tt") : "—")</td>
                            <td>
                                <a asp-page="/Registrations/Details" asp-route-id="@reg.Id" class="btn btn-sm btn-outline-info">Details</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <partial name="Shared/_Pagination" model="Model.Pagination" />
    }
    else
    {
        <p class="text-muted">No registrations found.</p>
    }

    <a asp-page="Details" asp-route-id="@Model.Event.Id" class="btn btn-secondary">Back to Event</a>
</section>
