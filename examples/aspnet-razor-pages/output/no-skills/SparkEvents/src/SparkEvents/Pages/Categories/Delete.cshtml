@page "{id:int}"
@model SparkEvents.Pages.Categories.DeleteModel

@{
    ViewData["Title"] = "Delete Category";
}

<section>
    <h1>Delete Category</h1>
    <hr />

    <div class="alert alert-warning">
        <strong>Are you sure you want to delete this category?</strong>
    </div>

    <dl class="row">
        <dt class="col-sm-3">Name</dt>
        <dd class="col-sm-9">@Model.Category!.Name</dd>

        <dt class="col-sm-3">Description</dt>
        <dd class="col-sm-9">@(Model.Category.Description ?? "—")</dd>
    </dl>

    <form method="post">
        <input type="hidden" name="id" value="@Model.Category.Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-page="Index" class="btn btn-secondary">Cancel</a>
    </form>
</section>
