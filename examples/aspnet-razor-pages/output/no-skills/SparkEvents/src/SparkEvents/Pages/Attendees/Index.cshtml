@page
@model SparkEvents.Pages.Attendees.IndexModel

@{
    ViewData["Title"] = "Attendees";
}

<section>
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Attendees</h1>
        <a asp-page="Create" class="btn btn-primary">Add Attendee</a>
    </div>

    <form method="get" class="row g-3 mb-4">
        <div class="col-md-4">
            <input asp-for="Search" class="form-control" placeholder="Search by name or email..." />
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-outline-primary">Search</button>
        </div>
    </form>

    @if (Model.Attendees.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Organization</th>
                        <th>Phone</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var attendee in Model.Attendees)
                    {
                        <tr>
                            <td><a asp-page="Details" asp-route-id="@attendee.Id">@attendee.FullName</a></td>
                            <td>@attendee.Email</td>
                            <td>@(attendee.Organization ?? "—")</td>
                            <td>@(attendee.Phone ?? "—")</td>
                            <td>
                                <a asp-page="Edit" asp-route-id="@attendee.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <partial name="Shared/_Pagination" model="Model.Pagination" />
    }
    else
    {
        <p class="text-muted">No attendees found.</p>
    }
</section>
