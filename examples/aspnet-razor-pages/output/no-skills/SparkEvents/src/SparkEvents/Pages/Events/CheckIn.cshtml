@page "{eventId:int}"
@model SparkEvents.Pages.Events.CheckInModel

@{
    ViewData["Title"] = "Check-In Dashboard";
}

<section>
    <h1>Check-In — @Model.Event!.Title</h1>
    <p class="text-muted">@Model.Event.StartDate.ToString("MMMM dd, yyyy h:mm tt")</p>

    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Check-In Progress</h5>
                    @{
                        var pct = Model.TotalConfirmed > 0 ? (int)(Model.TotalCheckedIn * 100.0 / Model.TotalConfirmed) : 0;
                    }
                    <div class="progress mb-2" style="height: 30px;">
                        <div class="progress-bar bg-success" role="progressbar" style="width: @pct%"
                             aria-valuenow="@Model.TotalCheckedIn" aria-valuemin="0" aria-valuemax="@Model.TotalConfirmed">
                            @Model.TotalCheckedIn / @Model.TotalConfirmed
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <form method="get" class="row g-3 mb-4">
        <div class="col-md-4">
            <input asp-for="Search" class="form-control" placeholder="Search by name or confirmation #..." />
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-outline-primary">Search</button>
        </div>
    </form>

    @if (Model.Registrations.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Confirmation</th>
                        <th>Attendee</th>
                        <th>Ticket</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var reg in Model.Registrations)
                    {
                        <tr>
                            <td>@reg.ConfirmationNumber</td>
                            <td>@reg.Attendee.FullName</td>
                            <td>@reg.TicketType.Name</td>
                            <td><partial name="Shared/_StatusBadge" model="@reg.Status.ToString()" /></td>
                            <td>
                                @if (reg.Status == RegistrationStatus.Confirmed)
                                {
                                    <a asp-page="CheckInProcess" asp-route-eventId="@Model.Event.Id" asp-route-registrationId="@reg.Id" class="btn btn-sm btn-success">Check In</a>
                                }
                                else if (reg.Status == RegistrationStatus.CheckedIn)
                                {
                                    <span class="text-success">✓ @reg.CheckIn?.CheckInTime.ToString("h:mm tt")</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-muted">No registrations found.</p>
    }

    <a asp-page="Details" asp-route-id="@Model.Event.Id" class="btn btn-secondary">Back to Event</a>
</section>
