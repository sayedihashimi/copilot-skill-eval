@model string

@{
    var status = Model?.ToLower() ?? "";
    var badgeClass = status switch
    {
        "draft" => "badge-status-draft",
        "published" => "badge-status-published",
        "soldout" => "badge-status-soldout",
        "completed" => "badge-status-completed",
        "cancelled" => "badge-status-cancelled",
        "confirmed" => "badge-status-confirmed",
        "waitlisted" => "badge-status-waitlisted",
        "checkedin" => "badge-status-checkedin",
        "noshow" => "badge-status-noshow",
        _ => "bg-secondary"
    };
    var displayText = status switch
    {
        "soldout" => "Sold Out",
        "checkedin" => "Checked In",
        "noshow" => "No Show",
        _ => Model ?? ""
    };
}

<span class="badge @badgeClass">@displayText</span>
