@page "{id:int}"
@model SparkEvents.Pages.Registrations.CancelModel

@{
    ViewData["Title"] = "Cancel Registration";
}

<section>
    <h1>Cancel Registration</h1>
    <hr />

    <div class="card mb-4">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-4">Confirmation Number</dt>
                <dd class="col-sm-8">@Model.Registration!.ConfirmationNumber</dd>

                <dt class="col-sm-4">Event</dt>
                <dd class="col-sm-8">@Model.Registration.Event.Title</dd>

                <dt class="col-sm-4">Attendee</dt>
                <dd class="col-sm-8">@Model.Registration.Attendee.FullName</dd>

                <dt class="col-sm-4">Ticket Type</dt>
                <dd class="col-sm-8">@Model.Registration.TicketType.Name</dd>

                <dt class="col-sm-4">Amount Paid</dt>
                <dd class="col-sm-8">@Model.Registration.AmountPaid.ToString("C")</dd>
            </dl>
        </div>
    </div>

    @{
        var hoursUntilEvent = (Model.Registration.Event.StartDate - DateTime.UtcNow).TotalHours;
    }
    @if (hoursUntilEvent <= 24)
    {
        <div class="alert alert-danger">
            <strong>Cancellation not allowed.</strong> Cancellations are not permitted within 24 hours of the event start.
        </div>
        <a asp-page="Details" asp-route-id="@Model.Registration.Id" class="btn btn-secondary">Go Back</a>
    }
    else
    {
        <div class="alert alert-warning">
            <strong>Cancellation Policy:</strong> This registration can be cancelled up to 24 hours before the event.
        </div>

        <form method="post">
            <div asp-validation-summary="All" class="text-danger"></div>
            <input type="hidden" name="id" value="@Model.Registration.Id" />

            <div class="mb-3">
                <label asp-for="CancellationReason" class="form-label">Reason (optional)</label>
                <textarea asp-for="CancellationReason" class="form-control" rows="3"></textarea>
            </div>

            <button type="submit" class="btn btn-danger">Confirm Cancellation</button>
            <a asp-page="Details" asp-route-id="@Model.Registration.Id" class="btn btn-secondary">Go Back</a>
        </form>
    }
</section>
