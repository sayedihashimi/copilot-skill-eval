@page
@model SparkEvents.Pages.IndexModel

@{
    ViewData["Title"] = "Dashboard";
}

<section>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>⚡ Spark Events Dashboard</h1>
    </div>

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-bg-primary">
                <div class="card-body">
                    <h5 class="card-title">Total Events</h5>
                    <p class="card-text display-6">@Model.TotalEvents</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-bg-success">
                <div class="card-body">
                    <h5 class="card-title">Active Registrations</h5>
                    <p class="card-text display-6">@Model.TotalRegistrations</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-bg-info">
                <div class="card-body">
                    <h5 class="card-title">Events This Month</h5>
                    <p class="card-text display-6">@Model.EventsThisMonth</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-bg-warning">
                <div class="card-body">
                    <h5 class="card-title">Today's Events</h5>
                    <p class="card-text display-6">@Model.TodaysEvents.Count</p>
                </div>
            </div>
        </div>
    </div>
</section>

@if (Model.TodaysEvents.Any())
{
    <section class="mb-4">
        <h3>Today's Events</h3>
        <div class="row">
            @foreach (var evt in Model.TodaysEvents)
            {
                var checkedIn = evt.Registrations.Count(r => r.Status == RegistrationStatus.CheckedIn);
                var totalConfirmed = evt.Registrations.Count(r => r.Status == RegistrationStatus.Confirmed || r.Status == RegistrationStatus.CheckedIn);
                var pct = totalConfirmed > 0 ? (int)(checkedIn * 100.0 / totalConfirmed) : 0;
                <div class="col-md-6 mb-3">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">
                                <a asp-page="/Events/Details" asp-route-id="@evt.Id">@evt.Title</a>
                            </h5>
                            <p class="card-text text-muted">@evt.Venue.Name — @evt.StartDate.ToString("h:mm tt")</p>
                            <div class="progress mb-2" style="height: 25px;">
                                <div class="progress-bar bg-success" role="progressbar" style="width: @pct%"
                                     aria-valuenow="@checkedIn" aria-valuemin="0" aria-valuemax="@totalConfirmed">
                                    @checkedIn / @totalConfirmed checked in
                                </div>
                            </div>
                            <a asp-page="/Events/CheckIn" asp-route-eventId="@evt.Id" class="btn btn-sm btn-primary">Check-In</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>
}

<section class="mb-4">
    <h3>Upcoming Events (Next 7 Days)</h3>
    @if (Model.UpcomingEvents.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Event</th>
                        <th>Category</th>
                        <th>Venue</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th>Registrations</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var evt in Model.UpcomingEvents)
                    {
                        <tr>
                            <td><a asp-page="/Events/Details" asp-route-id="@evt.Id">@evt.Title</a></td>
                            <td>@evt.EventCategory.Name</td>
                            <td>@evt.Venue.Name</td>
                            <td>@evt.StartDate.ToString("MMM dd, yyyy")</td>
                            <td><partial name="Shared/_StatusBadge" model="@evt.Status.ToString()" /></td>
                            <td>@evt.CurrentRegistrations / @evt.TotalCapacity</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-muted">No upcoming events in the next 7 days.</p>
    }
</section>

<section>
    <h3>Recent Registrations</h3>
    @if (Model.RecentRegistrations.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Confirmation</th>
                        <th>Attendee</th>
                        <th>Event</th>
                        <th>Ticket</th>
                        <th>Status</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var reg in Model.RecentRegistrations)
                    {
                        <tr>
                            <td><a asp-page="/Registrations/Details" asp-route-id="@reg.Id">@reg.ConfirmationNumber</a></td>
                            <td>@reg.Attendee.FullName</td>
                            <td>@reg.Event.Title</td>
                            <td>@reg.TicketType.Name</td>
                            <td><partial name="Shared/_StatusBadge" model="@reg.Status.ToString()" /></td>
                            <td>@reg.RegistrationDate.ToString("MMM dd, yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-muted">No recent registrations.</p>
    }
</section>
