@page "{id:int}"
@model SparkEvents.Pages.Attendees.DetailsModel

@{
    ViewData["Title"] = Model.Attendee!.FullName;
}

<section>
    <h1>@Model.Attendee.FullName</h1>
    <hr />

    <div class="row mb-4">
        <div class="col-md-6">
            <dl class="row">
                <dt class="col-sm-4">Email</dt>
                <dd class="col-sm-8">@Model.Attendee.Email</dd>

                <dt class="col-sm-4">Phone</dt>
                <dd class="col-sm-8">@(Model.Attendee.Phone ?? "—")</dd>

                <dt class="col-sm-4">Organization</dt>
                <dd class="col-sm-8">@(Model.Attendee.Organization ?? "—")</dd>

                <dt class="col-sm-4">Dietary Needs</dt>
                <dd class="col-sm-8">@(Model.Attendee.DietaryNeeds ?? "—")</dd>

                <dt class="col-sm-4">Registered Since</dt>
                <dd class="col-sm-8">@Model.Attendee.CreatedAt.ToString("MMM dd, yyyy")</dd>
            </dl>
        </div>
    </div>

    <h3>Registration History</h3>
    @if (Model.Attendee.Registrations.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Event</th>
                        <th>Ticket Type</th>
                        <th>Status</th>
                        <th>Amount</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var reg in Model.Attendee.Registrations.OrderByDescending(r => r.RegistrationDate))
                    {
                        <tr>
                            <td><a asp-page="/Events/Details" asp-route-id="@reg.EventId">@reg.Event.Title</a></td>
                            <td>@reg.TicketType.Name</td>
                            <td><partial name="Shared/_StatusBadge" model="@reg.Status.ToString()" /></td>
                            <td>@reg.AmountPaid.ToString("C")</td>
                            <td>@reg.RegistrationDate.ToString("MMM dd, yyyy")</td>
                            <td><a asp-page="/Registrations/Details" asp-route-id="@reg.Id" class="btn btn-sm btn-outline-info">Details</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-muted">No registrations yet.</p>
    }

    <a asp-page="Edit" asp-route-id="@Model.Attendee.Id" class="btn btn-primary">Edit</a>
    <a asp-page="Index" class="btn btn-secondary">Back to List</a>
</section>
