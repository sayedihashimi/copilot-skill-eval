@page "{id:int}"
@model SparkEvents.Pages.Venues.DeleteModel

@{
    ViewData["Title"] = "Delete Venue";
}

<section>
    <h1>Delete Venue</h1>
    <hr />

    <div class="alert alert-warning">
        <strong>Are you sure you want to delete this venue?</strong>
    </div>

    <dl class="row">
        <dt class="col-sm-3">Name</dt>
        <dd class="col-sm-9">@Model.Venue!.Name</dd>

        <dt class="col-sm-3">Address</dt>
        <dd class="col-sm-9">@Model.Venue.Address, @Model.Venue.City, @Model.Venue.State @Model.Venue.ZipCode</dd>

        <dt class="col-sm-3">Max Capacity</dt>
        <dd class="col-sm-9">@Model.Venue.MaxCapacity</dd>
    </dl>

    <form method="post">
        <input type="hidden" name="id" value="@Model.Venue.Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-page="Index" class="btn btn-secondary">Cancel</a>
    </form>
</section>
