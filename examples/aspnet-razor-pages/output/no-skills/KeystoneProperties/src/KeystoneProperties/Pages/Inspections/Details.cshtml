@page "{id:int}"
@model KeystoneProperties.Pages.Inspections.DetailsModel
@{ ViewData["Title"] = "Inspection Details"; }

@if (Model.Inspection == null) { <div class="alert alert-danger">Inspection not found.</div> return; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Inspection — @Model.Inspection.InspectionType</h1>
    <div>
        @if (!Model.Inspection.CompletedDate.HasValue)
        { <a asp-page="Complete" asp-route-id="@Model.Inspection.Id" class="btn btn-outline-success">Complete</a> }
        <a asp-page="Index" class="btn btn-outline-secondary">Back to List</a>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-header"><strong>Inspection Information</strong></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Type</dt><dd class="col-sm-7">@Model.Inspection.InspectionType</dd>
                    <dt class="col-sm-5">Scheduled</dt><dd class="col-sm-7">@Model.Inspection.ScheduledDate.ToString("MMM dd, yyyy")</dd>
                    <dt class="col-sm-5">Completed</dt><dd class="col-sm-7">@(Model.Inspection.CompletedDate?.ToString("MMM dd, yyyy") ?? "Pending")</dd>
                    <dt class="col-sm-5">Inspector</dt><dd class="col-sm-7">@Model.Inspection.InspectorName</dd>
                    <dt class="col-sm-5">Condition</dt><dd class="col-sm-7">
                        @if (Model.Inspection.OverallCondition.HasValue)
                        { <partial name="_StatusBadgePartial" view-data='@(new ViewDataDictionary(ViewData) { { "StatusText", Model.Inspection.OverallCondition.ToString()! }, { "StatusType", "OverallCondition" } })' /> }
                        else { <span class="text-muted">Not assessed</span> }
                    </dd>
                    <dt class="col-sm-5">Follow-Up</dt><dd class="col-sm-7">@(Model.Inspection.FollowUpRequired ? "Yes" : "No")</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-header"><strong>Location</strong></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Property</dt><dd class="col-sm-7"><a asp-page="/Properties/Details" asp-route-id="@Model.Inspection.Unit.PropertyId">@Model.Inspection.Unit.Property.Name</a></dd>
                    <dt class="col-sm-5">Unit</dt><dd class="col-sm-7"><a asp-page="/Units/Details" asp-route-id="@Model.Inspection.UnitId">@Model.Inspection.Unit.UnitNumber</a></dd>
                    @if (Model.Inspection.LeaseId.HasValue)
                    { <dt class="col-sm-5">Lease</dt><dd class="col-sm-7"><a asp-page="/Leases/Details" asp-route-id="@Model.Inspection.LeaseId">Lease #@Model.Inspection.LeaseId</a></dd> }
                </dl>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Inspection.Notes))
{
    <div class="card"><div class="card-header"><strong>Notes</strong></div><div class="card-body"><p>@Model.Inspection.Notes</p></div></div>
}
