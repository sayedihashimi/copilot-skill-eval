@page
@model KeystoneProperties.Pages.Payments.IndexModel
@{ ViewData["Title"] = "Payments"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Payments</h1>
    <div>
        <a asp-page="Create" class="btn btn-primary">Record Payment</a>
        <a asp-page="Overdue" class="btn btn-outline-danger">Overdue Payments</a>
    </div>
</div>

<form method="get" class="row g-3 mb-4">
    <div class="col-md-2">
        <select name="type" class="form-select">
            <option value="">All Types</option>
            @foreach (var t in Enum.GetValues<KeystoneProperties.Models.Enums.PaymentType>())
            { <option value="@t" selected="@(Model.Type == t)">@t</option> }
        </select>
    </div>
    <div class="col-md-2">
        <select name="status" class="form-select">
            <option value="">All Status</option>
            @foreach (var s in Enum.GetValues<KeystoneProperties.Models.Enums.PaymentStatus>())
            { <option value="@s" selected="@(Model.Status == s)">@s</option> }
        </select>
    </div>
    <div class="col-md-2">
        <input type="date" name="fromDate" value="@Model.FromDate?.ToString("yyyy-MM-dd")" class="form-control" placeholder="From" />
    </div>
    <div class="col-md-2">
        <input type="date" name="toDate" value="@Model.ToDate?.ToString("yyyy-MM-dd")" class="form-control" placeholder="To" />
    </div>
    <div class="col-md-2">
        <select name="propertyId" class="form-select">
            <option value="">All Properties</option>
            @foreach (var p in Model.PropertyList) { <option value="@p.Id" selected="@(Model.PropertyId == p.Id)">@p.Name</option> }
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-outline-secondary w-100">Filter</button>
    </div>
</form>

@if (Model.Payments.Items.Any())
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr><th>Date</th><th>Tenant</th><th>Property/Unit</th><th>Type</th><th>Amount</th><th>Method</th><th>Status</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var p in Model.Payments.Items)
            {
                <tr>
                    <td>@p.PaymentDate.ToString("MMM dd, yyyy")</td>
                    <td>@p.Lease.Tenant.FullName</td>
                    <td>@p.Lease.Unit.Property.Name — @p.Lease.Unit.UnitNumber</td>
                    <td>@p.PaymentType</td>
                    <td>@p.Amount.ToString("C")</td>
                    <td>@p.PaymentMethod</td>
                    <td><partial name="_StatusBadgePartial" view-data='@(new ViewDataDictionary(ViewData) { { "StatusText", p.Status.ToString() }, { "StatusType", "PaymentStatus" } })' /></td>
                    <td><a asp-page="Details" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary">View</a></td>
                </tr>
            }
        </tbody>
    </table>

}
else { <div class="alert alert-info">No payments found.</div> }

@if (Model.Payments.TotalPages > 1)
{
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.Payments.HasPreviousPage ? "" : "disabled")">
                <a class="page-link" href="?pageNumber=@(Model.Payments.PageNumber - 1)&type=@Model.Type&status=@Model.Status&fromDate=@Model.FromDate&toDate=@Model.ToDate&propertyId=@Model.PropertyId">Previous</a>
            </li>
            @for (int i = 1; i <= Model.Payments.TotalPages; i++)
            {
                <li class="page-item @(i == Model.Payments.PageNumber ? "active" : "")">
                    <a class="page-link" href="?pageNumber=@i&type=@Model.Type&status=@Model.Status&fromDate=@Model.FromDate&toDate=@Model.ToDate&propertyId=@Model.PropertyId">@i</a>
                </li>
            }
            <li class="page-item @(Model.Payments.HasNextPage ? "" : "disabled")">
                <a class="page-link" href="?pageNumber=@(Model.Payments.PageNumber + 1)&type=@Model.Type&status=@Model.Status&fromDate=@Model.FromDate&toDate=@Model.ToDate&propertyId=@Model.PropertyId">Next</a>
            </li>
        </ul>
    </nav>
}
