@page "{id:int}"
@model KeystoneProperties.Pages.Payments.DetailsModel
@{ ViewData["Title"] = "Payment Details"; }

@if (Model.Payment == null) { <div class="alert alert-danger">Payment not found.</div> return; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Payment #@Model.Payment.Id</h1>
    <a asp-page="Index" class="btn btn-outline-secondary">Back to List</a>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header"><strong>Payment Information</strong></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Amount</dt><dd class="col-sm-7">@Model.Payment.Amount.ToString("C")</dd>
                    <dt class="col-sm-5">Payment Date</dt><dd class="col-sm-7">@Model.Payment.PaymentDate.ToString("MMM dd, yyyy")</dd>
                    <dt class="col-sm-5">Due Date</dt><dd class="col-sm-7">@Model.Payment.DueDate.ToString("MMM dd, yyyy")</dd>
                    <dt class="col-sm-5">Type</dt><dd class="col-sm-7">@Model.Payment.PaymentType</dd>
                    <dt class="col-sm-5">Method</dt><dd class="col-sm-7">@Model.Payment.PaymentMethod</dd>
                    <dt class="col-sm-5">Status</dt><dd class="col-sm-7"><partial name="_StatusBadgePartial" view-data='@(new ViewDataDictionary(ViewData) { { "StatusText", Model.Payment.Status.ToString() }, { "StatusType", "PaymentStatus" } })' /></dd>
                    <dt class="col-sm-5">Reference</dt><dd class="col-sm-7">@(Model.Payment.ReferenceNumber ?? "—")</dd>
                    @if (!string.IsNullOrWhiteSpace(Model.Payment.Notes))
                    { <dt class="col-sm-5">Notes</dt><dd class="col-sm-7">@Model.Payment.Notes</dd> }
                </dl>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header"><strong>Lease & Tenant</strong></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Tenant</dt><dd class="col-sm-7"><a asp-page="/Tenants/Details" asp-route-id="@Model.Payment.Lease.TenantId">@Model.Payment.Lease.Tenant.FullName</a></dd>
                    <dt class="col-sm-5">Property</dt><dd class="col-sm-7">@Model.Payment.Lease.Unit.Property.Name</dd>
                    <dt class="col-sm-5">Unit</dt><dd class="col-sm-7">@Model.Payment.Lease.Unit.UnitNumber</dd>
                    <dt class="col-sm-5">Lease</dt><dd class="col-sm-7"><a asp-page="/Leases/Details" asp-route-id="@Model.Payment.LeaseId">Lease #@Model.Payment.LeaseId</a></dd>
                </dl>
            </div>
        </div>
    </div>
</div>
