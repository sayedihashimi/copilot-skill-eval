@page "{id:int}"
@model KeystoneProperties.Pages.Tenants.DeactivateModel
@{ ViewData["Title"] = "Deactivate Tenant"; }

<h1>Deactivate Tenant</h1>
@if (Model.Tenant != null)
{
    <div class="alert alert-warning" role="alert">Are you sure you want to deactivate <strong>@Model.Tenant.FullName</strong>?</div>
    <div class="card mb-3"><div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Name</dt><dd class="col-sm-9">@Model.Tenant.FullName</dd>
            <dt class="col-sm-3">Email</dt><dd class="col-sm-9">@Model.Tenant.Email</dd>
        </dl>
    </div></div>
    <form method="post">
        <input type="hidden" name="id" value="@Model.Tenant.Id" />
        <button type="submit" class="btn btn-danger">Confirm Deactivation</button>
        <a asp-page="Details" asp-route-id="@Model.Tenant.Id" class="btn btn-outline-secondary">Cancel</a>
    </form>
}
