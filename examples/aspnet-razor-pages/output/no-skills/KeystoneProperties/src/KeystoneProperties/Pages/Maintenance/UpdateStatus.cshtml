@page "{id:int}"
@model KeystoneProperties.Pages.Maintenance.UpdateStatusModel
@{ ViewData["Title"] = "Update Maintenance Status"; }

@if (Model.Request == null) { <div class="alert alert-danger">Request not found.</div> return; }

<h1>Update Status: @Model.Request.Title</h1>

<div class="card mb-3"><div class="card-body">
    <dl class="row mb-0">
        <dt class="col-sm-3">Current Status</dt><dd class="col-sm-9"><partial name="_StatusBadgePartial" view-data='@(new ViewDataDictionary(ViewData) { { "StatusText", Model.Request.Status.ToString() }, { "StatusType", "MaintenanceStatus" } })' /></dd>
        <dt class="col-sm-3">Priority</dt><dd class="col-sm-9"><partial name="_StatusBadgePartial" view-data='@(new ViewDataDictionary(ViewData) { { "StatusText", Model.Request.Priority.ToString() }, { "StatusType", "MaintenancePriority" } })' /></dd>
        <dt class="col-sm-3">Unit</dt><dd class="col-sm-9">@Model.Request.Unit.Property.Name — @Model.Request.Unit.UnitNumber</dd>
    </dl>
</div></div>

<div class="row"><div class="col-md-8">
    <form method="post">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="All" class="text-danger"></div>
        <div class="mb-3">
            <label asp-for="Input.NewStatus" class="form-label">New Status</label>
            <select asp-for="Input.NewStatus" class="form-select">
                @foreach (var s in Model.ValidTransitions) { <option value="@s">@s</option> }
            </select>
        </div>
        <div class="mb-3">
            <label asp-for="Input.AssignedTo" class="form-label"></label>
            <input asp-for="Input.AssignedTo" class="form-control" />
            <small class="text-muted">Required when transitioning to Assigned.</small>
        </div>
        <div class="mb-3">
            <label asp-for="Input.CompletionNotes" class="form-label"></label>
            <textarea asp-for="Input.CompletionNotes" class="form-control" rows="3"></textarea>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Input.EstimatedCost" class="form-label"></label>
                <input asp-for="Input.EstimatedCost" class="form-control" />
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="Input.ActualCost" class="form-label"></label>
                <input asp-for="Input.ActualCost" class="form-control" />
            </div>
        </div>
        <button type="submit" class="btn btn-warning">Update Status</button>
        <a asp-page="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
    </form>
</div></div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
