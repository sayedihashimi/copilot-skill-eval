@page "{id:int}"
@model KeystoneProperties.Pages.Leases.TerminateModel
@{ ViewData["Title"] = "Terminate Lease"; }

<h1>Terminate Lease #@Model.Id</h1>

@if (Model.Lease != null)
{
    <div class="alert alert-danger" role="alert">
        You are about to terminate the lease for <strong>@Model.Lease.Tenant.FullName</strong> at
        <strong>@Model.Lease.Unit.Property.Name — Unit @Model.Lease.Unit.UnitNumber</strong>.
    </div>

    <div class="card mb-3"><div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Period</dt><dd class="col-sm-9">@Model.Lease.StartDate.ToString("MMM dd, yyyy") — @Model.Lease.EndDate.ToString("MMM dd, yyyy")</dd>
            <dt class="col-sm-3">Monthly Rent</dt><dd class="col-sm-9">@Model.Lease.MonthlyRentAmount.ToString("C")</dd>
            <dt class="col-sm-3">Deposit</dt><dd class="col-sm-9">@Model.Lease.DepositAmount.ToString("C")</dd>
        </dl>
    </div></div>

    <div class="row"><div class="col-md-8">
        <form method="post">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="All" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="Input.Reason" class="form-label"></label>
                <textarea asp-for="Input.Reason" class="form-control" rows="3" required></textarea>
                <span asp-validation-for="Input.Reason" class="text-danger"></span>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Input.DepositDisposition" class="form-label">Deposit Disposition</label>
                    <select asp-for="Input.DepositDisposition" asp-items="Html.GetEnumSelectList<KeystoneProperties.Models.Enums.DepositStatus>()" class="form-select"></select>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Input.DepositReturnAmount" class="form-label">Deposit Return Amount</label>
                    <input asp-for="Input.DepositReturnAmount" class="form-control" />
                </div>
            </div>
            <button type="submit" class="btn btn-danger">Terminate Lease</button>
            <a asp-page="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div></div>
}

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
