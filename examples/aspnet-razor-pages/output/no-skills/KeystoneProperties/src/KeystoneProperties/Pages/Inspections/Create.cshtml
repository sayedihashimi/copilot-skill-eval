@page
@model KeystoneProperties.Pages.Inspections.CreateModel
@{ ViewData["Title"] = "Schedule Inspection"; }

<h1>Schedule Inspection</h1>
<div class="row"><div class="col-md-8">
    <form method="post">
        <div asp-validation-summary="All" class="text-danger"></div>
        <div class="mb-3">
            <label asp-for="Input.UnitId" class="form-label">Unit</label>
            <select asp-for="Input.UnitId" class="form-select">
                <option value="">Select Unit...</option>
                @foreach (var u in Model.UnitList) { <option value="@u.Id">@u.Property.Name — Unit @u.UnitNumber</option> }
            </select>
            <span asp-validation-for="Input.UnitId" class="text-danger"></span>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Input.InspectionType" class="form-label"></label>
                <select asp-for="Input.InspectionType" asp-items="Html.GetEnumSelectList<KeystoneProperties.Models.Enums.InspectionType>()" class="form-select"></select>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="Input.ScheduledDate" class="form-label"></label>
                <input asp-for="Input.ScheduledDate" class="form-control" type="date" />
                <span asp-validation-for="Input.ScheduledDate" class="text-danger"></span>
            </div>
        </div>
        <div class="mb-3">
            <label asp-for="Input.InspectorName" class="form-label"></label>
            <input asp-for="Input.InspectorName" class="form-control" />
            <span asp-validation-for="Input.InspectorName" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Input.LeaseId" class="form-label">Link to Lease (optional)</label>
            <select asp-for="Input.LeaseId" class="form-select">
                <option value="">No linked lease</option>
                @foreach (var l in Model.LeaseList) { <option value="@l.Id">Lease #@l.Id — @l.Tenant.FullName</option> }
            </select>
        </div>
        <div class="mb-3">
            <label asp-for="Input.Notes" class="form-label"></label>
            <textarea asp-for="Input.Notes" class="form-control" rows="3"></textarea>
        </div>
        <button type="submit" class="btn btn-primary">Schedule Inspection</button>
        <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
    </form>
</div></div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
