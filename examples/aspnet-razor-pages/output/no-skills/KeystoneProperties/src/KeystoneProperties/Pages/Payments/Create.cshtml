@page
@model KeystoneProperties.Pages.Payments.CreateModel
@{ ViewData["Title"] = "Record Payment"; }

<h1>Record Payment</h1>
<div class="row"><div class="col-md-8">
    <form method="post">
        <div asp-validation-summary="All" class="text-danger"></div>
        <div class="mb-3">
            <label asp-for="Input.LeaseId" class="form-label">Lease</label>
            <select asp-for="Input.LeaseId" class="form-select">
                <option value="">Select Lease...</option>
                @foreach (var l in Model.LeaseList)
                { <option value="@l.Id">Lease #@l.Id — @l.Tenant.FullName (@l.Unit.Property.Name Unit @l.Unit.UnitNumber) - @l.MonthlyRentAmount.ToString("C")/mo</option> }
            </select>
            <span asp-validation-for="Input.LeaseId" class="text-danger"></span>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Input.Amount" class="form-label"></label>
                <input asp-for="Input.Amount" class="form-control" />
                <span asp-validation-for="Input.Amount" class="text-danger"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="Input.PaymentType" class="form-label"></label>
                <select asp-for="Input.PaymentType" asp-items="Html.GetEnumSelectList<KeystoneProperties.Models.Enums.PaymentType>()" class="form-select"></select>
            </div>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Input.PaymentDate" class="form-label"></label>
                <input asp-for="Input.PaymentDate" class="form-control" type="date" />
                <span asp-validation-for="Input.PaymentDate" class="text-danger"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="Input.DueDate" class="form-label"></label>
                <input asp-for="Input.DueDate" class="form-control" type="date" />
                <span asp-validation-for="Input.DueDate" class="text-danger"></span>
                <small class="text-muted">If payment date is more than 5 days after due date, a late fee will be auto-generated.</small>
            </div>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Input.PaymentMethod" class="form-label"></label>
                <select asp-for="Input.PaymentMethod" asp-items="Html.GetEnumSelectList<KeystoneProperties.Models.Enums.PaymentMethod>()" class="form-select"></select>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="Input.Status" class="form-label"></label>
                <select asp-for="Input.Status" asp-items="Html.GetEnumSelectList<KeystoneProperties.Models.Enums.PaymentStatus>()" class="form-select"></select>
            </div>
        </div>
        <div class="mb-3">
            <label asp-for="Input.ReferenceNumber" class="form-label"></label>
            <input asp-for="Input.ReferenceNumber" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Input.Notes" class="form-label"></label>
            <textarea asp-for="Input.Notes" class="form-control" rows="2"></textarea>
        </div>
        <button type="submit" class="btn btn-primary">Record Payment</button>
        <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
    </form>
</div></div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
