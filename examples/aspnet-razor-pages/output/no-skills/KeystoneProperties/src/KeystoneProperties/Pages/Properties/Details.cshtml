@page "{id:int}"
@model KeystoneProperties.Pages.Properties.DetailsModel
@{
    ViewData["Title"] = Model.Property?.Name ?? "Property Details";
}

@if (Model.Property == null)
{
    <div class="alert alert-danger">Property not found.</div>
    return;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>@Model.Property.Name</h1>
    <div>
        <a asp-page="Edit" asp-route-id="@Model.Property.Id" class="btn btn-outline-primary">Edit</a>
        <a asp-page="Index" class="btn btn-outline-secondary">Back to List</a>
    </div>
</div>

<section class="row mb-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header"><strong>Property Information</strong></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Address</dt>
                    <dd class="col-sm-8">@Model.Property.Address, @Model.Property.City, @Model.Property.State @Model.Property.ZipCode</dd>
                    <dt class="col-sm-4">Type</dt>
                    <dd class="col-sm-8">@Model.Property.PropertyType</dd>
                    <dt class="col-sm-4">Year Built</dt>
                    <dd class="col-sm-8">@(Model.Property.YearBuilt?.ToString() ?? "N/A")</dd>
                    <dt class="col-sm-4">Total Units</dt>
                    <dd class="col-sm-8">@Model.Property.TotalUnits</dd>
                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">
                        @if (Model.Property.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                    </dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header"><strong>Occupancy Summary</strong></div>
            <div class="card-body">
                @{
                    var units = Model.Property.Units;
                    var occupied = units.Count(u => u.Status == KeystoneProperties.Models.Enums.UnitStatus.Occupied);
                    var available = units.Count(u => u.Status == KeystoneProperties.Models.Enums.UnitStatus.Available);
                    var maintenance = units.Count(u => u.Status == KeystoneProperties.Models.Enums.UnitStatus.Maintenance);
                    var rate = units.Count > 0 ? (double)occupied / units.Count * 100 : 0;
                }
                <dl class="row mb-0">
                    <dt class="col-sm-6">Occupied</dt><dd class="col-sm-6">@occupied</dd>
                    <dt class="col-sm-6">Available</dt><dd class="col-sm-6">@available</dd>
                    <dt class="col-sm-6">Maintenance</dt><dd class="col-sm-6">@maintenance</dd>
                    <dt class="col-sm-6">Occupancy Rate</dt><dd class="col-sm-6"><strong>@rate.ToString("F1")%</strong></dd>
                </dl>
            </div>
        </div>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.Property.Description))
{
    <section class="mb-4">
        <p>@Model.Property.Description</p>
    </section>
}

<section>
    <h3>Units</h3>
    @if (units.Any())
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Unit #</th>
                    <th>Floor</th>
                    <th>Beds</th>
                    <th>Baths</th>
                    <th>Sq Ft</th>
                    <th>Rent</th>
                    <th>Status</th>
                    <th>Current Tenant</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var unit in units.OrderBy(u => u.UnitNumber))
                {
                    var currentLease = unit.Leases.FirstOrDefault(l => l.Status == KeystoneProperties.Models.Enums.LeaseStatus.Active);
                    <tr>
                        <td>@unit.UnitNumber</td>
                        <td>@(unit.Floor?.ToString() ?? "-")</td>
                        <td>@(unit.Bedrooms == 0 ? "Studio" : unit.Bedrooms.ToString())</td>
                        <td>@unit.Bathrooms</td>
                        <td>@unit.SquareFeet.ToString("N0")</td>
                        <td>@unit.MonthlyRent.ToString("C")</td>
                        <td>
                            <partial name="_StatusBadgePartial" view-data='@(new ViewDataDictionary(ViewData) { { "StatusText", unit.Status.ToString() }, { "StatusType", "UnitStatus" } })' />
                        </td>
                        <td>@(currentLease?.Tenant?.FullName ?? "-")</td>
                        <td><a asp-page="/Units/Details" asp-route-id="@unit.Id" class="btn btn-sm btn-outline-primary">View</a></td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p class="text-muted">No units found for this property.</p>
    }
</section>
