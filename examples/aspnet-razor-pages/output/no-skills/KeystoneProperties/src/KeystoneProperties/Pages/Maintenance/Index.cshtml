@page
@model KeystoneProperties.Pages.Maintenance.IndexModel
@{ ViewData["Title"] = "Maintenance Requests"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Maintenance Requests</h1>
    <a asp-page="Create" class="btn btn-primary">New Request</a>
</div>

<form method="get" class="row g-3 mb-4">
    <div class="col-md-2">
        <select name="status" class="form-select">
            <option value="">All Status</option>
            @foreach (var s in Enum.GetValues<KeystoneProperties.Models.Enums.MaintenanceStatus>())
            { <option value="@s" selected="@(Model.Status == s)">@s</option> }
        </select>
    </div>
    <div class="col-md-2">
        <select name="priority" class="form-select">
            <option value="">All Priorities</option>
            @foreach (var p in Enum.GetValues<KeystoneProperties.Models.Enums.MaintenancePriority>())
            { <option value="@p" selected="@(Model.Priority == p)">@p</option> }
        </select>
    </div>
    <div class="col-md-2">
        <select name="category" class="form-select">
            <option value="">All Categories</option>
            @foreach (var c in Enum.GetValues<KeystoneProperties.Models.Enums.MaintenanceCategory>())
            { <option value="@c" selected="@(Model.Category == c)">@c</option> }
        </select>
    </div>
    <div class="col-md-3">
        <select name="propertyId" class="form-select">
            <option value="">All Properties</option>
            @foreach (var p in Model.PropertyList) { <option value="@p.Id" selected="@(Model.PropertyId == p.Id)">@p.Name</option> }
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-outline-secondary w-100">Filter</button>
    </div>
</form>

@if (Model.Requests.Items.Any())
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr><th>Title</th><th>Property/Unit</th><th>Tenant</th><th>Priority</th><th>Category</th><th>Status</th><th>Date</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var m in Model.Requests.Items)
            {
                <tr>
                    <td><a asp-page="Details" asp-route-id="@m.Id">@m.Title</a></td>
                    <td>@m.Unit.Property.Name — @m.Unit.UnitNumber</td>
                    <td>@m.Tenant.FullName</td>
                    <td><partial name="_StatusBadgePartial" view-data='@(new ViewDataDictionary(ViewData) { { "StatusText", m.Priority.ToString() }, { "StatusType", "MaintenancePriority" } })' /></td>
                    <td>@m.Category</td>
                    <td><partial name="_StatusBadgePartial" view-data='@(new ViewDataDictionary(ViewData) { { "StatusText", m.Status.ToString() }, { "StatusType", "MaintenanceStatus" } })' /></td>
                    <td>@m.SubmittedDate.ToString("MMM dd")</td>
                    <td>
                        <a asp-page="Details" asp-route-id="@m.Id" class="btn btn-sm btn-outline-primary">View</a>
                        @if (m.Status != KeystoneProperties.Models.Enums.MaintenanceStatus.Completed && m.Status != KeystoneProperties.Models.Enums.MaintenanceStatus.Cancelled)
                        { <a asp-page="UpdateStatus" asp-route-id="@m.Id" class="btn btn-sm btn-outline-warning">Update</a> }
                    </td>
                </tr>
            }
        </tbody>
    </table>

}
else { <div class="alert alert-info">No maintenance requests found.</div> }

@if (Model.Requests.TotalPages > 1)
{
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.Requests.HasPreviousPage ? "" : "disabled")">
                <a class="page-link" href="?pageNumber=@(Model.Requests.PageNumber - 1)&status=@Model.Status&priority=@Model.Priority&category=@Model.Category&propertyId=@Model.PropertyId">Previous</a>
            </li>
            @for (int i = 1; i <= Model.Requests.TotalPages; i++)
            {
                <li class="page-item @(i == Model.Requests.PageNumber ? "active" : "")">
                    <a class="page-link" href="?pageNumber=@i&status=@Model.Status&priority=@Model.Priority&category=@Model.Category&propertyId=@Model.PropertyId">@i</a>
                </li>
            }
            <li class="page-item @(Model.Requests.HasNextPage ? "" : "disabled")">
                <a class="page-link" href="?pageNumber=@(Model.Requests.PageNumber + 1)&status=@Model.Status&priority=@Model.Priority&category=@Model.Category&propertyId=@Model.PropertyId">Next</a>
            </li>
        </ul>
    </nav>
}
