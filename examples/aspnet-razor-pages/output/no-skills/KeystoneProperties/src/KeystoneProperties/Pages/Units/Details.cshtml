@page "{id:int}"
@model KeystoneProperties.Pages.Units.DetailsModel
@{
    ViewData["Title"] = $"Unit {Model.Unit?.UnitNumber}";
}

@if (Model.Unit == null)
{
    <div class="alert alert-danger">Unit not found.</div>
    return;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Unit @Model.Unit.UnitNumber — @Model.Unit.Property.Name</h1>
    <div>
        <a asp-page="Edit" asp-route-id="@Model.Unit.Id" class="btn btn-outline-primary">Edit</a>
        <a asp-page="Index" class="btn btn-outline-secondary">Back to List</a>
    </div>
</div>

<section class="row mb-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header"><strong>Unit Information</strong></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Property</dt><dd class="col-sm-8"><a asp-page="/Properties/Details" asp-route-id="@Model.Unit.PropertyId">@Model.Unit.Property.Name</a></dd>
                    <dt class="col-sm-4">Unit #</dt><dd class="col-sm-8">@Model.Unit.UnitNumber</dd>
                    <dt class="col-sm-4">Floor</dt><dd class="col-sm-8">@(Model.Unit.Floor?.ToString() ?? "N/A")</dd>
                    <dt class="col-sm-4">Bedrooms</dt><dd class="col-sm-8">@(Model.Unit.Bedrooms == 0 ? "Studio" : Model.Unit.Bedrooms.ToString())</dd>
                    <dt class="col-sm-4">Bathrooms</dt><dd class="col-sm-8">@Model.Unit.Bathrooms</dd>
                    <dt class="col-sm-4">Sq Ft</dt><dd class="col-sm-8">@Model.Unit.SquareFeet.ToString("N0")</dd>
                    <dt class="col-sm-4">Rent</dt><dd class="col-sm-8">@Model.Unit.MonthlyRent.ToString("C")/mo</dd>
                    <dt class="col-sm-4">Deposit</dt><dd class="col-sm-8">@Model.Unit.DepositAmount.ToString("C")</dd>
                    <dt class="col-sm-4">Status</dt><dd class="col-sm-8"><partial name="_StatusBadgePartial" view-data='@(new ViewDataDictionary(ViewData) { { "StatusText", Model.Unit.Status.ToString() }, { "StatusType", "UnitStatus" } })' /></dd>
                    <dt class="col-sm-4">Amenities</dt><dd class="col-sm-8">@(Model.Unit.Amenities ?? "None")</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        @{
            var currentLease = Model.Unit.Leases.FirstOrDefault(l => l.Status == KeystoneProperties.Models.Enums.LeaseStatus.Active);
        }
        <div class="card">
            <div class="card-header"><strong>Current Lease</strong></div>
            <div class="card-body">
                @if (currentLease != null)
                {
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Tenant</dt><dd class="col-sm-8"><a asp-page="/Tenants/Details" asp-route-id="@currentLease.TenantId">@currentLease.Tenant.FullName</a></dd>
                        <dt class="col-sm-4">Period</dt><dd class="col-sm-8">@currentLease.StartDate.ToString("MMM dd, yyyy") — @currentLease.EndDate.ToString("MMM dd, yyyy")</dd>
                        <dt class="col-sm-4">Rent</dt><dd class="col-sm-8">@currentLease.MonthlyRentAmount.ToString("C")/mo</dd>
                    </dl>
                    <a asp-page="/Leases/Details" asp-route-id="@currentLease.Id" class="btn btn-sm btn-outline-primary mt-2">View Lease</a>
                }
                else
                {
                    <p class="text-muted">No active lease.</p>
                }
            </div>
        </div>
    </div>
</section>

<section class="mb-4">
    <h3>Lease History</h3>
    @if (Model.Unit.Leases.Any())
    {
        <table class="table table-striped">
            <thead><tr><th>Tenant</th><th>Period</th><th>Rent</th><th>Status</th><th></th></tr></thead>
            <tbody>
                @foreach (var lease in Model.Unit.Leases.OrderByDescending(l => l.StartDate))
                {
                    <tr>
                        <td>@lease.Tenant.FullName</td>
                        <td>@lease.StartDate.ToString("MMM yyyy") — @lease.EndDate.ToString("MMM yyyy")</td>
                        <td>@lease.MonthlyRentAmount.ToString("C")</td>
                        <td><partial name="_StatusBadgePartial" view-data='@(new ViewDataDictionary(ViewData) { { "StatusText", lease.Status.ToString() }, { "StatusType", "LeaseStatus" } })' /></td>
                        <td><a asp-page="/Leases/Details" asp-route-id="@lease.Id" class="btn btn-sm btn-outline-primary">View</a></td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p class="text-muted">No lease history.</p>
    }
</section>

<section class="mb-4">
    <h3>Maintenance History</h3>
    @if (Model.Unit.MaintenanceRequests.Any())
    {
        <table class="table table-striped">
            <thead><tr><th>Title</th><th>Priority</th><th>Status</th><th>Date</th><th></th></tr></thead>
            <tbody>
                @foreach (var req in Model.Unit.MaintenanceRequests.OrderByDescending(m => m.SubmittedDate))
                {
                    <tr>
                        <td>@req.Title</td>
                        <td><partial name="_StatusBadgePartial" view-data='@(new ViewDataDictionary(ViewData) { { "StatusText", req.Priority.ToString() }, { "StatusType", "MaintenancePriority" } })' /></td>
                        <td><partial name="_StatusBadgePartial" view-data='@(new ViewDataDictionary(ViewData) { { "StatusText", req.Status.ToString() }, { "StatusType", "MaintenanceStatus" } })' /></td>
                        <td>@req.SubmittedDate.ToString("MMM dd, yyyy")</td>
                        <td><a asp-page="/Maintenance/Details" asp-route-id="@req.Id" class="btn btn-sm btn-outline-primary">View</a></td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p class="text-muted">No maintenance history.</p>
    }
</section>

<section>
    <h3>Inspections</h3>
    @if (Model.Unit.Inspections.Any())
    {
        <table class="table table-striped">
            <thead><tr><th>Type</th><th>Scheduled</th><th>Completed</th><th>Condition</th><th></th></tr></thead>
            <tbody>
                @foreach (var insp in Model.Unit.Inspections.OrderByDescending(i => i.ScheduledDate))
                {
                    <tr>
                        <td>@insp.InspectionType</td>
                        <td>@insp.ScheduledDate.ToString("MMM dd, yyyy")</td>
                        <td>@(insp.CompletedDate?.ToString("MMM dd, yyyy") ?? "Pending")</td>
                        <td>
                            @if (insp.OverallCondition.HasValue)
                            {
                                <partial name="_StatusBadgePartial" view-data='@(new ViewDataDictionary(ViewData) { { "StatusText", insp.OverallCondition.ToString()! }, { "StatusType", "OverallCondition" } })' />
                            }
                            else { <span class="text-muted">—</span> }
                        </td>
                        <td><a asp-page="/Inspections/Details" asp-route-id="@insp.Id" class="btn btn-sm btn-outline-primary">View</a></td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p class="text-muted">No inspections.</p>
    }
</section>
