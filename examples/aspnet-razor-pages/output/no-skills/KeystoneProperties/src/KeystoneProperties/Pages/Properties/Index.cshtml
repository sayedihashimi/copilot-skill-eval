@page
@model KeystoneProperties.Pages.Properties.IndexModel
@{
    ViewData["Title"] = "Properties";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Properties</h1>
    <a asp-page="Create" class="btn btn-primary">Add Property</a>
</div>

<form method="get" class="row g-3 mb-4">
    <div class="col-md-4">
        <input type="text" name="search" value="@Model.Search" class="form-control" placeholder="Search by name or city..." />
    </div>
    <div class="col-md-3">
        <select name="type" class="form-select">
            <option value="">All Types</option>
            @foreach (var t in Enum.GetValues<KeystoneProperties.Models.Enums.PropertyType>())
            {
                <option value="@t" selected="@(Model.Type == t)">@t</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <select name="isActive" class="form-select">
            <option value="">All Status</option>
            <option value="true" selected="@(Model.IsActive == true)">Active</option>
            <option value="false" selected="@(Model.IsActive == false)">Inactive</option>
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-outline-secondary w-100">Filter</button>
    </div>
</form>

@if (Model.Properties.Items.Any())
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Type</th>
                <th>City</th>
                <th>State</th>
                <th>Units</th>
                <th>Occupancy</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var prop in Model.Properties.Items)
            {
                var occupied = prop.Units.Count(u => u.Status == KeystoneProperties.Models.Enums.UnitStatus.Occupied);
                var total = prop.Units.Count;
                var rate = total > 0 ? (double)occupied / total * 100 : 0;
                <tr>
                    <td><a asp-page="Details" asp-route-id="@prop.Id">@prop.Name</a></td>
                    <td>@prop.PropertyType</td>
                    <td>@prop.City</td>
                    <td>@prop.State</td>
                    <td>@total</td>
                    <td>@occupied / @total (@rate.ToString("F0")%)</td>
                    <td>
                        @if (prop.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                    </td>
                    <td>
                        <a asp-page="Edit" asp-route-id="@prop.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                        @if (prop.IsActive)
                        {
                            <a asp-page="Deactivate" asp-route-id="@prop.Id" class="btn btn-sm btn-outline-danger">Deactivate</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

}
else
{
    <div class="alert alert-info">No properties found matching your criteria.</div>
}

@if (Model.Properties.TotalPages > 1)
{
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.Properties.HasPreviousPage ? "" : "disabled")">
                <a class="page-link" href="?pageNumber=@(Model.Properties.PageNumber - 1)&search=@Model.Search&type=@Model.Type&isActive=@Model.IsActive">Previous</a>
            </li>
            @for (int i = 1; i <= Model.Properties.TotalPages; i++)
            {
                <li class="page-item @(i == Model.Properties.PageNumber ? "active" : "")">
                    <a class="page-link" href="?pageNumber=@i&search=@Model.Search&type=@Model.Type&isActive=@Model.IsActive">@i</a>
                </li>
            }
            <li class="page-item @(Model.Properties.HasNextPage ? "" : "disabled")">
                <a class="page-link" href="?pageNumber=@(Model.Properties.PageNumber + 1)&search=@Model.Search&type=@Model.Type&isActive=@Model.IsActive">Next</a>
            </li>
        </ul>
    </nav>
    <p class="text-center text-muted">Showing page @Model.Properties.PageNumber of @Model.Properties.TotalPages (@Model.Properties.TotalCount total items)</p>
}
