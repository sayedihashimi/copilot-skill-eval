@page
@model KeystoneProperties.Pages.Inspections.IndexModel
@{ ViewData["Title"] = "Inspections"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Inspections</h1>
    <a asp-page="Create" class="btn btn-primary">Schedule Inspection</a>
</div>

<form method="get" class="row g-3 mb-4">
    <div class="col-md-3">
        <select name="type" class="form-select">
            <option value="">All Types</option>
            @foreach (var t in Enum.GetValues<KeystoneProperties.Models.Enums.InspectionType>())
            { <option value="@t" selected="@(Model.Type == t)">@t</option> }
        </select>
    </div>
    <div class="col-md-3">
        <input type="date" name="fromDate" value="@Model.FromDate?.ToString("yyyy-MM-dd")" class="form-control" placeholder="From" />
    </div>
    <div class="col-md-3">
        <input type="date" name="toDate" value="@Model.ToDate?.ToString("yyyy-MM-dd")" class="form-control" placeholder="To" />
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-outline-secondary w-100">Filter</button>
    </div>
</form>

@if (Model.Inspections.Items.Any())
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr><th>Type</th><th>Property/Unit</th><th>Scheduled</th><th>Completed</th><th>Condition</th><th>Inspector</th><th>Follow-Up</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var i in Model.Inspections.Items)
            {
                <tr>
                    <td>@i.InspectionType</td>
                    <td>@i.Unit.Property.Name — @i.Unit.UnitNumber</td>
                    <td>@i.ScheduledDate.ToString("MMM dd, yyyy")</td>
                    <td>@(i.CompletedDate?.ToString("MMM dd, yyyy") ?? "Pending")</td>
                    <td>
                        @if (i.OverallCondition.HasValue)
                        { <partial name="_StatusBadgePartial" view-data='@(new ViewDataDictionary(ViewData) { { "StatusText", i.OverallCondition.ToString()! }, { "StatusType", "OverallCondition" } })' /> }
                        else { <span class="text-muted">—</span> }
                    </td>
                    <td>@i.InspectorName</td>
                    <td>@(i.FollowUpRequired ? "Yes" : "No")</td>
                    <td>
                        <a asp-page="Details" asp-route-id="@i.Id" class="btn btn-sm btn-outline-primary">View</a>
                        @if (!i.CompletedDate.HasValue)
                        { <a asp-page="Complete" asp-route-id="@i.Id" class="btn btn-sm btn-outline-success">Complete</a> }
                    </td>
                </tr>
            }
        </tbody>
    </table>

}
else { <div class="alert alert-info">No inspections found.</div> }

@if (Model.Inspections.TotalPages > 1)
{
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.Inspections.HasPreviousPage ? "" : "disabled")">
                <a class="page-link" href="?pageNumber=@(Model.Inspections.PageNumber - 1)&type=@Model.Type&fromDate=@Model.FromDate&toDate=@Model.ToDate">Previous</a>
            </li>
            @for (int i = 1; i <= Model.Inspections.TotalPages; i++)
            {
                <li class="page-item @(i == Model.Inspections.PageNumber ? "active" : "")">
                    <a class="page-link" href="?pageNumber=@i&type=@Model.Type&fromDate=@Model.FromDate&toDate=@Model.ToDate">@i</a>
                </li>
            }
            <li class="page-item @(Model.Inspections.HasNextPage ? "" : "disabled")">
                <a class="page-link" href="?pageNumber=@(Model.Inspections.PageNumber + 1)&type=@Model.Type&fromDate=@Model.FromDate&toDate=@Model.ToDate">Next</a>
            </li>
        </ul>
    </nav>
}
