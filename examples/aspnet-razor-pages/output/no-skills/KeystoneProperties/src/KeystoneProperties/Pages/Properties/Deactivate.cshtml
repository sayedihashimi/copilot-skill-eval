@page "{id:int}"
@model KeystoneProperties.Pages.Properties.DeactivateModel
@{
    ViewData["Title"] = "Deactivate Property";
}

<h1>Deactivate Property</h1>

@if (Model.Property != null)
{
    <div class="alert alert-warning" role="alert">
        Are you sure you want to deactivate <strong>@Model.Property.Name</strong>?
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Name</dt><dd class="col-sm-9">@Model.Property.Name</dd>
                <dt class="col-sm-3">Address</dt><dd class="col-sm-9">@Model.Property.Address, @Model.Property.City, @Model.Property.State</dd>
                <dt class="col-sm-3">Type</dt><dd class="col-sm-9">@Model.Property.PropertyType</dd>
            </dl>
        </div>
    </div>

    <form method="post">
        <input type="hidden" name="id" value="@Model.Property.Id" />
        <button type="submit" class="btn btn-danger">Confirm Deactivation</button>
        <a asp-page="Details" asp-route-id="@Model.Property.Id" class="btn btn-outline-secondary">Cancel</a>
    </form>
}
