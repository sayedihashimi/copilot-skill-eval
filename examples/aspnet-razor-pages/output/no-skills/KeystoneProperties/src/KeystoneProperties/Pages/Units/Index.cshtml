@page
@model KeystoneProperties.Pages.Units.IndexModel
@{
    ViewData["Title"] = "Units";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Units</h1>
    <a asp-page="Create" class="btn btn-primary">Add Unit</a>
</div>

<form method="get" class="row g-3 mb-4">
    <div class="col-md-2">
        <input type="text" name="search" value="@Model.Search" class="form-control" placeholder="Unit #..." />
    </div>
    <div class="col-md-2">
        <select name="propertyId" class="form-select">
            <option value="">All Properties</option>
            @foreach (var p in Model.PropertyList)
            {
                <option value="@p.Id" selected="@(Model.PropertyId == p.Id)">@p.Name</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <select name="status" class="form-select">
            <option value="">All Status</option>
            @foreach (var s in Enum.GetValues<KeystoneProperties.Models.Enums.UnitStatus>())
            {
                <option value="@s" selected="@(Model.Status == s)">@s</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <select name="bedrooms" class="form-select">
            <option value="">Bedrooms</option>
            <option value="0" selected="@(Model.Bedrooms == 0)">Studio</option>
            @for (int i = 1; i <= 5; i++)
            {
                <option value="@i" selected="@(Model.Bedrooms == i)">@i BR</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <input type="number" name="minRent" value="@Model.MinRent" class="form-control" placeholder="Min Rent" />
    </div>
    <div class="col-md-2">
        <input type="number" name="maxRent" value="@Model.MaxRent" class="form-control" placeholder="Max Rent" />
    </div>
    <div class="col-12">
        <button type="submit" class="btn btn-outline-secondary">Filter</button>
        <a asp-page="Index" class="btn btn-outline-dark">Clear</a>
    </div>
</form>

@if (Model.Units.Items.Any())
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Property</th>
                <th>Unit #</th>
                <th>Beds</th>
                <th>Baths</th>
                <th>Sq Ft</th>
                <th>Monthly Rent</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var unit in Model.Units.Items)
            {
                <tr>
                    <td>@unit.Property.Name</td>
                    <td>@unit.UnitNumber</td>
                    <td>@(unit.Bedrooms == 0 ? "Studio" : unit.Bedrooms.ToString())</td>
                    <td>@unit.Bathrooms</td>
                    <td>@unit.SquareFeet.ToString("N0")</td>
                    <td>@unit.MonthlyRent.ToString("C")</td>
                    <td>
                        <partial name="_StatusBadgePartial" view-data='@(new ViewDataDictionary(ViewData) { { "StatusText", unit.Status.ToString() }, { "StatusType", "UnitStatus" } })' />
                    </td>
                    <td>
                        <a asp-page="Details" asp-route-id="@unit.Id" class="btn btn-sm btn-outline-primary">View</a>
                        <a asp-page="Edit" asp-route-id="@unit.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

}
else
{
    <div class="alert alert-info">No units found matching your criteria.</div>
}

@if (Model.Units.TotalPages > 1)
{
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.Units.HasPreviousPage ? "" : "disabled")">
                <a class="page-link" href="?pageNumber=@(Model.Units.PageNumber - 1)&search=@Model.Search&propertyId=@Model.PropertyId&status=@Model.Status&bedrooms=@Model.Bedrooms&minRent=@Model.MinRent&maxRent=@Model.MaxRent">Previous</a>
            </li>
            @for (int i = 1; i <= Model.Units.TotalPages; i++)
            {
                <li class="page-item @(i == Model.Units.PageNumber ? "active" : "")">
                    <a class="page-link" href="?pageNumber=@i&search=@Model.Search&propertyId=@Model.PropertyId&status=@Model.Status&bedrooms=@Model.Bedrooms&minRent=@Model.MinRent&maxRent=@Model.MaxRent">@i</a>
                </li>
            }
            <li class="page-item @(Model.Units.HasNextPage ? "" : "disabled")">
                <a class="page-link" href="?pageNumber=@(Model.Units.PageNumber + 1)&search=@Model.Search&propertyId=@Model.PropertyId&status=@Model.Status&bedrooms=@Model.Bedrooms&minRent=@Model.MinRent&maxRent=@Model.MaxRent">Next</a>
            </li>
        </ul>
    </nav>
}
