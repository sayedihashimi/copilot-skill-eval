@page
@model KeystoneProperties.Pages.Tenants.IndexModel
@{
    ViewData["Title"] = "Tenants";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Tenants</h1>
    <a asp-page="Create" class="btn btn-primary">Add Tenant</a>
</div>

<form method="get" class="row g-3 mb-4">
    <div class="col-md-5">
        <input type="text" name="search" value="@Model.Search" class="form-control" placeholder="Search by name or email..." />
    </div>
    <div class="col-md-3">
        <select name="isActive" class="form-select">
            <option value="">All Status</option>
            <option value="true" selected="@(Model.IsActive == true)">Active</option>
            <option value="false" selected="@(Model.IsActive == false)">Inactive</option>
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-outline-secondary w-100">Filter</button>
    </div>
</form>

@if (Model.Tenants.Items.Any())
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr><th>Name</th><th>Email</th><th>Phone</th><th>Status</th><th>Actions</th></tr>
        </thead>
        <tbody>
            @foreach (var t in Model.Tenants.Items)
            {
                <tr>
                    <td><a asp-page="Details" asp-route-id="@t.Id">@t.FullName</a></td>
                    <td>@t.Email</td>
                    <td>@t.Phone</td>
                    <td>
                        @if (t.IsActive) { <span class="badge bg-success">Active</span> }
                        else { <span class="badge bg-secondary">Inactive</span> }
                    </td>
                    <td>
                        <a asp-page="Edit" asp-route-id="@t.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                        @if (t.IsActive) { <a asp-page="Deactivate" asp-route-id="@t.Id" class="btn btn-sm btn-outline-danger">Deactivate</a> }
                    </td>
                </tr>
            }
        </tbody>
    </table>

}
else
{
    <div class="alert alert-info">No tenants found.</div>
}

@if (Model.Tenants.TotalPages > 1)
{
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.Tenants.HasPreviousPage ? "" : "disabled")">
                <a class="page-link" href="?pageNumber=@(Model.Tenants.PageNumber - 1)&search=@Model.Search&isActive=@Model.IsActive">Previous</a>
            </li>
            @for (int i = 1; i <= Model.Tenants.TotalPages; i++)
            {
                <li class="page-item @(i == Model.Tenants.PageNumber ? "active" : "")">
                    <a class="page-link" href="?pageNumber=@i&search=@Model.Search&isActive=@Model.IsActive">@i</a>
                </li>
            }
            <li class="page-item @(Model.Tenants.HasNextPage ? "" : "disabled")">
                <a class="page-link" href="?pageNumber=@(Model.Tenants.PageNumber + 1)&search=@Model.Search&isActive=@Model.IsActive">Next</a>
            </li>
        </ul>
    </nav>
}
