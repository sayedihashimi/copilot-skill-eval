<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Keystone Properties</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/KeystoneProperties.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-3" aria-label="Main navigation">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-page="/Index">🏠 Keystone Properties</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                        aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    @{
                        var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
                        string NavClass(string path) => currentPage.StartsWith(path) ? "nav-link active" : "nav-link";
                        string AriaCurrent(string path) => currentPage.StartsWith(path) ? "page" : "";
                    }
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="@(currentPage == "/Index" ? "nav-link active" : "nav-link")" asp-page="/Index" aria-current="@(currentPage == "/Index" ? "page" : "")">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="@NavClass("/Properties")" asp-page="/Properties/Index" aria-current="@AriaCurrent("/Properties")">Properties</a>
                        </li>
                        <li class="nav-item">
                            <a class="@NavClass("/Units")" asp-page="/Units/Index" aria-current="@AriaCurrent("/Units")">Units</a>
                        </li>
                        <li class="nav-item">
                            <a class="@NavClass("/Tenants")" asp-page="/Tenants/Index" aria-current="@AriaCurrent("/Tenants")">Tenants</a>
                        </li>
                        <li class="nav-item">
                            <a class="@NavClass("/Leases")" asp-page="/Leases/Index" aria-current="@AriaCurrent("/Leases")">Leases</a>
                        </li>
                        <li class="nav-item">
                            <a class="@NavClass("/Payments")" asp-page="/Payments/Index" aria-current="@AriaCurrent("/Payments")">Payments</a>
                        </li>
                        <li class="nav-item">
                            <a class="@NavClass("/Maintenance")" asp-page="/Maintenance/Index" aria-current="@AriaCurrent("/Maintenance")">Maintenance</a>
                        </li>
                        <li class="nav-item">
                            <a class="@NavClass("/Inspections")" asp-page="/Inspections/Index" aria-current="@AriaCurrent("/Inspections")">Inspections</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted py-3 mt-4">
        <div class="container text-center">
            &copy; @DateTime.Now.Year Keystone Properties — Property Management System
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
