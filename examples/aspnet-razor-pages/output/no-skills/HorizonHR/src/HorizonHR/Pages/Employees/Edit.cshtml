@page "{id:int}"
@model HorizonHR.Pages.Employees.EditModel
@{
    ViewData["Title"] = "Edit Employee";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="Index">Employees</a></li>
        <li class="breadcrumb-item"><a asp-page="Details" asp-route-id="@Model.Input.Id">@Model.Input.FirstName @Model.Input.LastName</a></li>
        <li class="breadcrumb-item active" aria-current="page">Edit</li>
    </ol>
</nav>

<h1>Edit Employee</h1>
<p class="text-muted">Employee Number: <strong>@Model.EmployeeNumber</strong></p>

<div class="row">
    <div class="col-md-8">
        <form method="post">
            <input type="hidden" asp-for="Input.Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <fieldset class="mb-4">
                <legend>Personal Information</legend>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="Input.FirstName" class="form-label"></label>
                        <input asp-for="Input.FirstName" class="form-control" />
                        <span asp-validation-for="Input.FirstName" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Input.LastName" class="form-label"></label>
                        <input asp-for="Input.LastName" class="form-control" />
                        <span asp-validation-for="Input.LastName" class="text-danger"></span>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="Input.Email" class="form-label"></label>
                        <input asp-for="Input.Email" class="form-control" type="email" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Input.Phone" class="form-label"></label>
                        <input asp-for="Input.Phone" class="form-control" type="tel" />
                        <span asp-validation-for="Input.Phone" class="text-danger"></span>
                    </div>
                </div>
                <div class="mb-3">
                    <label asp-for="Input.DateOfBirth" class="form-label"></label>
                    <input asp-for="Input.DateOfBirth" class="form-control" type="date" />
                    <span asp-validation-for="Input.DateOfBirth" class="text-danger"></span>
                </div>
            </fieldset>

            <fieldset class="mb-4">
                <legend>Employment Details</legend>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="Input.HireDate" class="form-label"></label>
                        <input asp-for="Input.HireDate" class="form-control" type="date" />
                        <span asp-validation-for="Input.HireDate" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Input.DepartmentId" class="form-label"></label>
                        <select asp-for="Input.DepartmentId" class="form-select"
                                asp-items="Model.DepartmentList">
                            <option value="">— Select Department —</option>
                        </select>
                        <span asp-validation-for="Input.DepartmentId" class="text-danger"></span>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="Input.ManagerId" class="form-label"></label>
                        <select asp-for="Input.ManagerId" class="form-select"
                                asp-items="Model.ManagerList">
                            <option value="">— No Manager —</option>
                        </select>
                        <span asp-validation-for="Input.ManagerId" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Input.JobTitle" class="form-label"></label>
                        <input asp-for="Input.JobTitle" class="form-control" />
                        <span asp-validation-for="Input.JobTitle" class="text-danger"></span>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="Input.EmploymentType" class="form-label"></label>
                        <select asp-for="Input.EmploymentType" class="form-select"
                                asp-items="Html.GetEnumSelectList<HorizonHR.Models.EmploymentType>()">
                        </select>
                        <span asp-validation-for="Input.EmploymentType" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Input.Salary" class="form-label"></label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="Input.Salary" class="form-control" type="number" step="0.01" min="0.01" />
                        </div>
                        <span asp-validation-for="Input.Salary" class="text-danger"></span>
                    </div>
                </div>
            </fieldset>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-page="Details" asp-route-id="@Model.Input.Id" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
