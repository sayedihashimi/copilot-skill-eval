@page "{id:int}"
@model HorizonHR.Pages.Reviews.SelfAssessmentModel
@{
    ViewData["Title"] = "Self-Assessment";
}

<h1 class="mb-4">Self-Assessment</h1>

<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0">Review Information</h5>
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Employee</dt>
            <dd class="col-sm-9">@Model.Review.Employee.FullName</dd>

            <dt class="col-sm-3">Reviewer</dt>
            <dd class="col-sm-9">@Model.Review.Reviewer.FullName</dd>

            <dt class="col-sm-3">Review Period</dt>
            <dd class="col-sm-9">
                @Model.Review.ReviewPeriodStart.ToString("MMM d, yyyy") &ndash; @Model.Review.ReviewPeriodEnd.ToString("MMM d, yyyy")
            </dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                <partial name="_StatusBadge" model="@Model.Review.Status.ToString()" />
            </dd>
        </dl>
    </div>
</div>

<div class="row">
    <div class="col-md-10">
        <form method="post">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="SelfAssessment" class="form-label"></label>
                <textarea asp-for="SelfAssessment" class="form-control" rows="8"
                          placeholder="Describe your accomplishments, challenges, and areas of growth during this review period..."></textarea>
                <span asp-validation-for="SelfAssessment" class="text-danger"></span>
                <div class="form-text">Maximum 5000 characters.</div>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">Submit Self-Assessment</button>
                <a asp-page="Details" asp-route-id="@Model.Review.Id" class="btn btn-outline-secondary ms-2">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
