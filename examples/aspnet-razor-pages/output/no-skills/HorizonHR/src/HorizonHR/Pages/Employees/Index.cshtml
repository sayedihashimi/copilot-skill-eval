@page
@model HorizonHR.Pages.Employees.IndexModel
@{
    ViewData["Title"] = "Employee Directory";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Employee Directory</h1>
    <a asp-page="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Add Employee
    </a>
</div>

<form method="get" class="card mb-4">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-4">
                <label for="Search" class="form-label">Search</label>
                <input type="text" class="form-control" id="Search" asp-for="Search"
                       placeholder="Name, email, or employee number" />
            </div>
            <div class="col-md-2">
                <label for="DepartmentId" class="form-label">Department</label>
                <select class="form-select" id="DepartmentId" asp-for="DepartmentId"
                        asp-items="Model.DepartmentList">
                    <option value="">All Departments</option>
                </select>
            </div>
            <div class="col-md-2">
                <label for="EmploymentType" class="form-label">Type</label>
                <select class="form-select" id="EmploymentType" asp-for="EmploymentType"
                        asp-items="Html.GetEnumSelectList<HorizonHR.Models.EmploymentType>()">
                    <option value="">All Types</option>
                </select>
            </div>
            <div class="col-md-2">
                <label for="Status" class="form-label">Status</label>
                <select class="form-select" id="Status" asp-for="Status"
                        asp-items="Html.GetEnumSelectList<HorizonHR.Models.EmployeeStatus>()">
                    <option value="">All Statuses</option>
                </select>
            </div>
            <div class="col-md-2 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-outline-primary">Filter</button>
                <a asp-page="Index" class="btn btn-outline-secondary">Clear</a>
            </div>
        </div>
    </div>
</form>

<p class="text-muted mb-2">Showing @Model.Employees.Count of @Model.Employees.TotalCount employees</p>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Employee #</th>
                <th>Name</th>
                <th>Email</th>
                <th>Department</th>
                <th>Job Title</th>
                <th>Type</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var employee in Model.Employees)
            {
                <tr>
                    <td>@employee.EmployeeNumber</td>
                    <td>@employee.FullName</td>
                    <td>@employee.Email</td>
                    <td>@employee.Department?.Name</td>
                    <td>@employee.JobTitle</td>
                    <td>
                        <partial name="_StatusBadge" model="@employee.EmploymentType.ToString()" />
                    </td>
                    <td>
                        <partial name="_StatusBadge" model="@employee.Status.ToString()" />
                    </td>
                    <td>
                        <a asp-page="Details" asp-route-id="@employee.Id"
                           class="btn btn-sm btn-outline-primary">Details</a>
                        <a asp-page="Edit" asp-route-id="@employee.Id"
                           class="btn btn-sm btn-outline-secondary">Edit</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (Model.Employees.TotalCount == 0)
{
    <div class="text-center text-muted py-4">
        <p>No employees found matching your criteria.</p>
    </div>
}

@if (Model.Employees.TotalPages > 1)
{
    <nav aria-label="Employee list pagination">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.Employees.HasPreviousPage ? "" : "disabled")">
                <a class="page-link"
                   asp-page="Index"
                   asp-route-pageNumber="@(Model.Employees.PageIndex - 1)"
                   asp-route-search="@Model.Search"
                   asp-route-departmentId="@Model.DepartmentId"
                   asp-route-employmentType="@Model.EmploymentType"
                   asp-route-status="@Model.Status">Previous</a>
            </li>
            @for (int i = 1; i <= Model.Employees.TotalPages; i++)
            {
                <li class="page-item @(i == Model.Employees.PageIndex ? "active" : "")">
                    <a class="page-link"
                       asp-page="Index"
                       asp-route-pageNumber="@i"
                       asp-route-search="@Model.Search"
                       asp-route-departmentId="@Model.DepartmentId"
                       asp-route-employmentType="@Model.EmploymentType"
                       asp-route-status="@Model.Status">@i</a>
                </li>
            }
            <li class="page-item @(Model.Employees.HasNextPage ? "" : "disabled")">
                <a class="page-link"
                   asp-page="Index"
                   asp-route-pageNumber="@(Model.Employees.PageIndex + 1)"
                   asp-route-search="@Model.Search"
                   asp-route-departmentId="@Model.DepartmentId"
                   asp-route-employmentType="@Model.EmploymentType"
                   asp-route-status="@Model.Status">Next</a>
            </li>
        </ul>
    </nav>
}
