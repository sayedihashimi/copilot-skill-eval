@page
@model HorizonHR.Pages.Leave.IndexModel
@{
    ViewData["Title"] = "Leave Requests";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Leave Requests</h1>
    <div>
        <a asp-page="Balances" class="btn btn-outline-secondary me-2">Leave Balances</a>
        <a asp-page="Create" class="btn btn-primary">Submit Leave Request</a>
    </div>
</div>

<form method="get" class="card mb-4">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label asp-for="Status" class="form-label">Status</label>
                <select asp-for="Status" asp-items="Model.StatusOptions" class="form-select">
                    <option value="">All Statuses</option>
                </select>
            </div>
            <div class="col-md-3">
                <label asp-for="EmployeeId" class="form-label">Employee</label>
                <select asp-for="EmployeeId" asp-items="Model.EmployeeOptions" class="form-select">
                    <option value="">All Employees</option>
                </select>
            </div>
            <div class="col-md-3">
                <label asp-for="LeaveTypeId" class="form-label">Leave Type</label>
                <select asp-for="LeaveTypeId" asp-items="Model.LeaveTypeOptions" class="form-select">
                    <option value="">All Types</option>
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-secondary me-2">Filter</button>
                <a asp-page="Index" class="btn btn-outline-secondary">Clear</a>
            </div>
        </div>
    </div>
</form>

@if (!Model.LeaveRequests.Any())
{
    <div class="alert alert-info">No leave requests found matching the selected filters.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Employee</th>
                    <th>Leave Type</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Days</th>
                    <th>Status</th>
                    <th>Submitted</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var request in Model.LeaveRequests)
                {
                    <tr>
                        <td>
                            <a asp-page="Employee" asp-route-id="@request.EmployeeId">@request.Employee.FullName</a>
                        </td>
                        <td>@request.LeaveType.Name</td>
                        <td>@request.StartDate.ToString("MMM dd, yyyy")</td>
                        <td>@request.EndDate.ToString("MMM dd, yyyy")</td>
                        <td>@request.TotalDays</td>
                        <td>
                            <partial name="_StatusBadge" model="@request.Status.ToString()" />
                        </td>
                        <td>@request.SubmittedDate.ToString("MMM dd, yyyy")</td>
                        <td>
                            <a asp-page="Details" asp-route-id="@request.Id" class="btn btn-sm btn-outline-primary">Details</a>
                            @if (request.Status == LeaveRequestStatus.Submitted)
                            {
                                <a asp-page="Review" asp-route-id="@request.Id" class="btn btn-sm btn-outline-warning">Review</a>
                                <a asp-page="Cancel" asp-route-id="@request.Id" class="btn btn-sm btn-outline-danger">Cancel</a>
                            }
                            @if (request.Status == LeaveRequestStatus.Approved)
                            {
                                <a asp-page="Cancel" asp-route-id="@request.Id" class="btn btn-sm btn-outline-danger">Cancel</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.LeaveRequests.TotalPages > 1)
    {
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.LeaveRequests.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link"
                       asp-route-pageNumber="@(Model.LeaveRequests.PageIndex - 1)"
                       asp-route-status="@Model.Status"
                       asp-route-employeeId="@Model.EmployeeId"
                       asp-route-leaveTypeId="@Model.LeaveTypeId">Previous</a>
                </li>
                @for (int i = 1; i <= Model.LeaveRequests.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.LeaveRequests.PageIndex ? "active" : "")">
                        <a class="page-link"
                           asp-route-pageNumber="@i"
                           asp-route-status="@Model.Status"
                           asp-route-employeeId="@Model.EmployeeId"
                           asp-route-leaveTypeId="@Model.LeaveTypeId">@i</a>
                    </li>
                }
                <li class="page-item @(Model.LeaveRequests.HasNextPage ? "" : "disabled")">
                    <a class="page-link"
                       asp-route-pageNumber="@(Model.LeaveRequests.PageIndex + 1)"
                       asp-route-status="@Model.Status"
                       asp-route-employeeId="@Model.EmployeeId"
                       asp-route-leaveTypeId="@Model.LeaveTypeId">Next</a>
                </li>
            </ul>
        </nav>
    }

    <p class="text-muted text-center">
        Showing page @Model.LeaveRequests.PageIndex of @Model.LeaveRequests.TotalPages
        (@Model.LeaveRequests.TotalCount total requests)
    </p>
}
