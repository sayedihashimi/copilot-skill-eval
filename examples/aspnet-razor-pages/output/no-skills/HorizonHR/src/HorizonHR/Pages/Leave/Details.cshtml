@page "{id:int}"
@model HorizonHR.Pages.Leave.DetailsModel
@{
    ViewData["Title"] = "Leave Request Details";
}

<h1>Leave Request Details</h1>

<div class="row">
    <div class="col-md-8">
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">Request Information</h5>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Employee</dt>
                    <dd class="col-sm-8">
                        <a asp-page="Employee" asp-route-id="@Model.LeaveRequest.EmployeeId">
                            @Model.LeaveRequest.Employee.FullName
                        </a>
                    </dd>

                    <dt class="col-sm-4">Department</dt>
                    <dd class="col-sm-8">@Model.LeaveRequest.Employee.Department.Name</dd>

                    <dt class="col-sm-4">Leave Type</dt>
                    <dd class="col-sm-8">@Model.LeaveRequest.LeaveType.Name</dd>

                    <dt class="col-sm-4">Start Date</dt>
                    <dd class="col-sm-8">@Model.LeaveRequest.StartDate.ToString("MMMM dd, yyyy")</dd>

                    <dt class="col-sm-4">End Date</dt>
                    <dd class="col-sm-8">@Model.LeaveRequest.EndDate.ToString("MMMM dd, yyyy")</dd>

                    <dt class="col-sm-4">Total Days</dt>
                    <dd class="col-sm-8">@Model.LeaveRequest.TotalDays</dd>

                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">
                        <partial name="_StatusBadge" model="@Model.LeaveRequest.Status.ToString()" />
                    </dd>

                    <dt class="col-sm-4">Reason</dt>
                    <dd class="col-sm-8">@Model.LeaveRequest.Reason</dd>

                    <dt class="col-sm-4">Submitted Date</dt>
                    <dd class="col-sm-8">@Model.LeaveRequest.SubmittedDate.ToString("MMMM dd, yyyy HH:mm")</dd>
                </dl>
            </div>
        </div>

        @if (Model.LeaveRequest.ReviewedBy != null)
        {
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Review Information</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Reviewed By</dt>
                        <dd class="col-sm-8">@Model.LeaveRequest.ReviewedBy.FullName</dd>

                        <dt class="col-sm-4">Review Date</dt>
                        <dd class="col-sm-8">@Model.LeaveRequest.ReviewDate?.ToString("MMMM dd, yyyy HH:mm")</dd>

                        <dt class="col-sm-4">Review Notes</dt>
                        <dd class="col-sm-8">@(Model.LeaveRequest.ReviewNotes ?? "—")</dd>
                    </dl>
                </div>
            </div>
        }
    </div>

    <div class="col-md-4">
        @if (Model.CurrentBalance != null)
        {
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Balance: @Model.LeaveRequest.LeaveType.Name</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-6">Total Days</dt>
                        <dd class="col-sm-6">@Model.CurrentBalance.TotalDays</dd>

                        <dt class="col-sm-6">Used Days</dt>
                        <dd class="col-sm-6">@Model.CurrentBalance.UsedDays</dd>

                        <dt class="col-sm-6">Carried Over</dt>
                        <dd class="col-sm-6">@Model.CurrentBalance.CarriedOverDays</dd>

                        <dt class="col-sm-6">Remaining</dt>
                        <dd class="col-sm-6 fw-bold">@Model.CurrentBalance.RemainingDays</dd>
                    </dl>
                </div>
            </div>
        }

        <div class="d-grid gap-2">
            @if (Model.LeaveRequest.Status == LeaveRequestStatus.Submitted)
            {
                <a asp-page="Review" asp-route-id="@Model.LeaveRequest.Id" class="btn btn-warning">Review Request</a>
                <a asp-page="Cancel" asp-route-id="@Model.LeaveRequest.Id" class="btn btn-outline-danger">Cancel Request</a>
            }
            @if (Model.LeaveRequest.Status == LeaveRequestStatus.Approved)
            {
                <a asp-page="Cancel" asp-route-id="@Model.LeaveRequest.Id" class="btn btn-outline-danger">Cancel Request</a>
            }
            <a asp-page="Index" class="btn btn-outline-secondary">Back to List</a>
        </div>
    </div>
</div>
