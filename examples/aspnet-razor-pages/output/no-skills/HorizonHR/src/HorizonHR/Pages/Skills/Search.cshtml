@page
@using HorizonHR.Models
@model HorizonHR.Pages.Skills.SearchModel
@{
    ViewData["Title"] = "Search by Skill";
}

<h1>Search by Skill</h1>

<div class="row mb-4">
    <div class="col-md-8">
        <form method="get" class="card">
            <div class="card-body">
                <div class="row g-3 align-items-end">
                    <div class="col-md-5">
                        <label for="SkillId" class="form-label">Skill</label>
                        <select asp-for="SkillId" asp-items="Model.SkillOptions" class="form-select">
                            <option value="">-- Select a skill --</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label for="MinLevel" class="form-label">Minimum Proficiency</label>
                        <select asp-for="MinLevel" asp-items="Model.ProficiencyOptions" class="form-select">
                            <option value="">-- Any level --</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <button type="submit" class="btn btn-primary w-100">Search</button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@if (Model.SearchPerformed)
{
    @if (Model.Results.Any())
    {
        <h2 class="h5 mb-3">Results (@Model.Results.Count employee(s))</h2>
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Employee Name</th>
                        <th>Department</th>
                        <th>Proficiency</th>
                        <th>Years of Experience</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var employee in Model.Results)
                    {
                        var es = employee.EmployeeSkills.FirstOrDefault(e => e.SkillId == Model.SkillId);
                        <tr>
                            <td>@employee.FullName</td>
                            <td>@employee.Department?.Name</td>
                            <td>
                                @if (es != null)
                                {
                                    <partial name="_StatusBadge" model="@es.ProficiencyLevel.ToString()" />
                                }
                            </td>
                            <td>@(es?.YearsOfExperience?.ToString() ?? "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            No employees found matching the selected criteria.
        </div>
    }
}

<div class="mt-3">
    <a asp-page="Index" class="btn btn-outline-secondary">Back to Skills</a>
</div>
