@page
@model ErrorModel
@{
    ViewData["Title"] = "Error";
}

<section class="text-center py-5">
    <h1 class="text-danger display-4">Oops!</h1>
    <h2 class="text-muted">An error occurred while processing your request.</h2>
    <p class="lead mt-3">We're sorry for the inconvenience. Please try again or go back to the dashboard.</p>

    @if (Model.ShowRequestId)
    {
        <p class="mt-3">
            <strong>Request ID:</strong> <code>@Model.RequestId</code>
        </p>
    }

    <a asp-page="/Index" class="btn btn-primary mt-3">Back to Dashboard</a>
</section>
