@page
@model HorizonHR.Pages.Skills.IndexModel
@{
    ViewData["Title"] = "Skills";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Skills</h1>
    <div>
        <a asp-page="Search" class="btn btn-outline-primary me-2">
            <i class="bi bi-search"></i> Search by Skill
        </a>
        <a asp-page="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Add Skill
        </a>
    </div>
</div>

@if (!Model.SkillsByCategory.Any())
{
    <div class="alert alert-info" role="alert">
        No skills have been added yet. <a asp-page="Create" class="alert-link">Create the first skill</a>.
    </div>
}
else
{
    @foreach (var category in Model.SkillsByCategory)
    {
        <section class="mb-4">
            <h2 class="h5 text-muted border-bottom pb-2 mb-3">@category.Key</h2>
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
                @foreach (var skill in category.Value)
                {
                    <div class="col">
                        <div class="card h-100">
                            <div class="card-body">
                                <h5 class="card-title">@skill.Name</h5>
                                @if (!string.IsNullOrWhiteSpace(skill.Description))
                                {
                                    <p class="card-text text-muted small">@skill.Description</p>
                                }
                                <p class="card-text">
                                    <span class="badge bg-secondary">@skill.EmployeeSkills.Count employee(s)</span>
                                </p>
                            </div>
                            <div class="card-footer bg-transparent">
                                <a asp-page="Edit" asp-route-id="@skill.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </section>
    }
}
