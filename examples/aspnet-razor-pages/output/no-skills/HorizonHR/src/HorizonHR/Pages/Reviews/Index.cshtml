@page
@model HorizonHR.Pages.Reviews.IndexModel
@{
    ViewData["Title"] = "Performance Reviews";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Performance Reviews</h1>
    <a asp-page="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> New Review
    </a>
</div>

<form method="get" class="card mb-4">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label for="Status" class="form-label">Status</label>
                <select asp-for="Status" asp-items="Model.StatusOptions" class="form-select" id="Status">
                    <option value="">All Statuses</option>
                </select>
            </div>
            <div class="col-md-3">
                <label for="Rating" class="form-label">Rating</label>
                <select asp-for="Rating" asp-items="Model.RatingOptions" class="form-select" id="Rating">
                    <option value="">All Ratings</option>
                </select>
            </div>
            <div class="col-md-3">
                <label for="DepartmentId" class="form-label">Department</label>
                <select asp-for="DepartmentId" asp-items="Model.DepartmentOptions" class="form-select" id="DepartmentId">
                    <option value="">All Departments</option>
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-outline-primary me-2">Filter</button>
                <a asp-page="Index" class="btn btn-outline-secondary">Clear</a>
            </div>
        </div>
    </div>
</form>

@if (Model.Reviews.Count == 0)
{
    <div class="alert alert-info">No reviews found matching the selected filters.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Employee</th>
                    <th>Reviewer</th>
                    <th>Period</th>
                    <th>Status</th>
                    <th>Rating</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var review in Model.Reviews)
                {
                    <tr>
                        <td>@review.Employee.FullName</td>
                        <td>@review.Reviewer.FullName</td>
                        <td>@review.ReviewPeriodStart.ToString("MMM d, yyyy") &ndash; @review.ReviewPeriodEnd.ToString("MMM d, yyyy")</td>
                        <td>
                            <partial name="_StatusBadge" model="@review.Status.ToString()" />
                        </td>
                        <td>
                            @if (review.OverallRating.HasValue)
                            {
                                <partial name="_StatusBadge" model="@review.OverallRating.Value.ToString()" />
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>
                            <a asp-page="Details" asp-route-id="@review.Id" class="btn btn-sm btn-outline-primary">Details</a>
                            @if (review.Status == HorizonHR.Models.ReviewStatus.SelfAssessmentPending)
                            {
                                <a asp-page="SelfAssessment" asp-route-id="@review.Id" class="btn btn-sm btn-outline-info">Self-Assessment</a>
                            }
                            @if (review.Status == HorizonHR.Models.ReviewStatus.ManagerReviewPending)
                            {
                                <a asp-page="ManagerReview" asp-route-id="@review.Id" class="btn btn-sm btn-outline-warning">Manager Review</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.Reviews.TotalPages > 1)
    {
        <nav aria-label="Reviews pagination">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.Reviews.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link"
                       asp-route-pageNumber="@(Model.Reviews.PageIndex - 1)"
                       asp-route-status="@Model.Status"
                       asp-route-rating="@Model.Rating"
                       asp-route-departmentId="@Model.DepartmentId">Previous</a>
                </li>
                @for (int i = 1; i <= Model.Reviews.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Reviews.PageIndex ? "active" : "")">
                        <a class="page-link"
                           asp-route-pageNumber="@i"
                           asp-route-status="@Model.Status"
                           asp-route-rating="@Model.Rating"
                           asp-route-departmentId="@Model.DepartmentId">@i</a>
                    </li>
                }
                <li class="page-item @(Model.Reviews.HasNextPage ? "" : "disabled")">
                    <a class="page-link"
                       asp-route-pageNumber="@(Model.Reviews.PageIndex + 1)"
                       asp-route-status="@Model.Status"
                       asp-route-rating="@Model.Rating"
                       asp-route-departmentId="@Model.DepartmentId">Next</a>
                </li>
            </ul>
        </nav>
    }

    <p class="text-muted text-center">
        Showing page @Model.Reviews.PageIndex of @Model.Reviews.TotalPages (@Model.Reviews.TotalCount total reviews)
    </p>
}
