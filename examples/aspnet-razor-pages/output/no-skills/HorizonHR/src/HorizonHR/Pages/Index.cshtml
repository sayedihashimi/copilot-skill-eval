@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<h1 class="mb-4">Dashboard</h1>

<!-- Summary Cards -->
<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card text-white bg-primary h-100">
            <div class="card-body">
                <h5 class="card-title">Total Employees</h5>
                <p class="display-6 mb-0">@Model.TotalEmployees</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-success h-100">
            <div class="card-body">
                <h5 class="card-title">Departments</h5>
                <p class="display-6 mb-0">@Model.DepartmentCount</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-dark bg-warning h-100">
            <div class="card-body">
                <h5 class="card-title">Pending Leave Requests</h5>
                <p class="display-6 mb-0">@Model.PendingLeaveRequests</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-info h-100">
            <div class="card-body">
                <h5 class="card-title">Upcoming Reviews</h5>
                <p class="display-6 mb-0">@Model.UpcomingReviews</p>
            </div>
        </div>
    </div>
</div>

<!-- Recent Hires & On Leave -->
<div class="row g-4 mb-4">
    <div class="col-lg-7">
        <div class="card h-100">
            <div class="card-header">
                <h5 class="mb-0">Recent Hires (Last 30 Days)</h5>
            </div>
            <div class="card-body">
                @if (Model.RecentHires.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Employee #</th>
                                    <th>Name</th>
                                    <th>Department</th>
                                    <th>Job Title</th>
                                    <th>Hire Date</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.RecentHires)
                                {
                                    <tr>
                                        <td>@item.EmployeeNumber</td>
                                        <td>@item.FullName</td>
                                        <td>@item.Department?.Name</td>
                                        <td>@item.JobTitle</td>
                                        <td>@item.HireDate.ToString("MMM dd, yyyy")</td>
                                        <td><partial name="_StatusBadge" model="@item.Status.ToString()" /></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">No recent hires in the last 30 days.</p>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card h-100">
            <div class="card-header">
                <h5 class="mb-0">Employees Currently on Leave</h5>
            </div>
            <div class="card-body">
                @if (Model.OnLeaveEmployees.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Department</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.OnLeaveEmployees)
                                {
                                    <tr>
                                        <td>@item.FullName</td>
                                        <td>@item.Department?.Name</td>
                                        <td><partial name="_StatusBadge" model="@item.Status.ToString()" /></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">No employees currently on leave.</p>
                }
            </div>
        </div>
    </div>
</div>

<!-- Headcount by Department -->
<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Headcount by Department</h5>
            </div>
            <div class="card-body">
                @if (Model.Departments.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Department</th>
                                    <th>Code</th>
                                    <th>Headcount</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var dept in Model.Departments)
                                {
                                    <tr>
                                        <td>@dept.Name</td>
                                        <td>@dept.Code</td>
                                        <td>@dept.Employees.Count</td>
                                        <td>
                                            @if (dept.IsActive)
                                            {
                                                <span class="badge bg-success">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Inactive</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">No departments found.</p>
                }
            </div>
        </div>
    </div>
</div>
