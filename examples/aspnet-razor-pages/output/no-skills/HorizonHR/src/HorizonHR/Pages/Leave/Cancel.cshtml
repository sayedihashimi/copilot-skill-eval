@page "{id:int}"
@model HorizonHR.Pages.Leave.CancelModel
@{
    ViewData["Title"] = "Cancel Leave Request";
}

<h1>Cancel Leave Request</h1>

<div class="row">
    <div class="col-md-8">
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">Request Details</h5>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Employee</dt>
                    <dd class="col-sm-8">@Model.LeaveRequest.Employee.FullName</dd>

                    <dt class="col-sm-4">Leave Type</dt>
                    <dd class="col-sm-8">@Model.LeaveRequest.LeaveType.Name</dd>

                    <dt class="col-sm-4">Start Date</dt>
                    <dd class="col-sm-8">@Model.LeaveRequest.StartDate.ToString("MMMM dd, yyyy")</dd>

                    <dt class="col-sm-4">End Date</dt>
                    <dd class="col-sm-8">@Model.LeaveRequest.EndDate.ToString("MMMM dd, yyyy")</dd>

                    <dt class="col-sm-4">Total Days</dt>
                    <dd class="col-sm-8">@Model.LeaveRequest.TotalDays</dd>

                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">
                        <partial name="_StatusBadge" model="@Model.LeaveRequest.Status.ToString()" />
                    </dd>

                    <dt class="col-sm-4">Reason</dt>
                    <dd class="col-sm-8">@Model.LeaveRequest.Reason</dd>
                </dl>
            </div>
        </div>

        @if (Model.WasApproved)
        {
            <div class="alert alert-warning">
                <strong>Note:</strong> This request was already approved. Cancelling it will restore the used leave
                balance of <strong>@Model.LeaveRequest.TotalDays day(s)</strong> back to the employee's
                <strong>@Model.LeaveRequest.LeaveType.Name</strong> balance.
            </div>
        }

        <div class="card border-danger">
            <div class="card-body">
                <h5 class="card-title text-danger">Confirm Cancellation</h5>
                <p>Are you sure you want to cancel this leave request? This action cannot be undone.</p>

                <form method="post" asp-route-id="@Model.LeaveRequest.Id">
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger">Yes, Cancel Request</button>
                        <a asp-page="Details" asp-route-id="@Model.LeaveRequest.Id" class="btn btn-outline-secondary">Go Back</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
