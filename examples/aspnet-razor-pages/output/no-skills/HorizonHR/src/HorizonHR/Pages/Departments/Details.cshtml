@page "{id:int}"
@model HorizonHR.Pages.Departments.DetailsModel
@{
    ViewData["Title"] = Model.Department.Name;
}

<section>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>@Model.Department.Name</h1>
        <div>
            <a asp-page="Edit" asp-route-id="@Model.Department.Id" class="btn btn-outline-secondary">Edit</a>
            <a asp-page="Index" class="btn btn-outline-primary">Back to List</a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">Department Information</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Code</dt>
                        <dd class="col-sm-8">@Model.Department.Code</dd>

                        <dt class="col-sm-4">Description</dt>
                        <dd class="col-sm-8">@(Model.Department.Description ?? "—")</dd>

                        <dt class="col-sm-4">Manager</dt>
                        <dd class="col-sm-8">@(Model.Department.Manager?.FullName ?? "—")</dd>

                        <dt class="col-sm-4">Parent Department</dt>
                        <dd class="col-sm-8">
                            @if (Model.Department.ParentDepartment != null)
                            {
                                <a asp-page="Details" asp-route-id="@Model.Department.ParentDepartment.Id">
                                    @Model.Department.ParentDepartment.Name
                                </a>
                            }
                            else
                            {
                                <span>—</span>
                            }
                        </dd>

                        <dt class="col-sm-4">Status</dt>
                        <dd class="col-sm-8">
                            <partial name="_StatusBadge" model="@(Model.Department.IsActive ? "Active" : "Terminated")" />
                        </dd>
                    </dl>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">Child Departments</h5>
                </div>
                <div class="card-body">
                    @if (Model.Department.ChildDepartments.Any())
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var child in Model.Department.ChildDepartments)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <a asp-page="Details" asp-route-id="@child.Id">@child.Name</a>
                                    <span class="badge bg-secondary">@child.Code</span>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted mb-0">No child departments.</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <section>
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">Employees (@Model.Department.Employees.Count)</h5>
            </div>
            <div class="card-body p-0">
                @if (Model.Department.Employees.Any())
                {
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Name</th>
                                <th>Job Title</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var employee in Model.Department.Employees)
                            {
                                <tr>
                                    <td>@employee.FullName</td>
                                    <td>@employee.JobTitle</td>
                                    <td>
                                        <partial name="_StatusBadge" model="@employee.Status.ToString()" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted p-3 mb-0">No employees in this department.</p>
                }
            </div>
        </div>
    </section>
</section>
