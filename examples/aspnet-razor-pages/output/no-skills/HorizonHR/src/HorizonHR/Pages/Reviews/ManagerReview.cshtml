@page "{id:int}"
@model HorizonHR.Pages.Reviews.ManagerReviewModel
@{
    ViewData["Title"] = "Manager Review";
}

<h1 class="mb-4">Manager Review</h1>

<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0">Review Information</h5>
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Employee</dt>
            <dd class="col-sm-9">@Model.Review.Employee.FullName</dd>

            <dt class="col-sm-3">Reviewer</dt>
            <dd class="col-sm-9">@Model.Review.Reviewer.FullName</dd>

            <dt class="col-sm-3">Review Period</dt>
            <dd class="col-sm-9">
                @Model.Review.ReviewPeriodStart.ToString("MMM d, yyyy") &ndash; @Model.Review.ReviewPeriodEnd.ToString("MMM d, yyyy")
            </dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                <partial name="_StatusBadge" model="@Model.Review.Status.ToString()" />
            </dd>
        </dl>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Review.SelfAssessment))
{
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0">Employee Self-Assessment</h5>
        </div>
        <div class="card-body">
            <p class="mb-0" style="white-space: pre-wrap;">@Model.Review.SelfAssessment</p>
        </div>
    </div>
}

<div class="row">
    <div class="col-md-10">
        <form method="post">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Input.ManagerAssessment" class="form-label"></label>
                <textarea asp-for="Input.ManagerAssessment" class="form-control" rows="6"
                          placeholder="Provide your assessment of the employee's performance..."></textarea>
                <span asp-validation-for="Input.ManagerAssessment" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.OverallRating" class="form-label"></label>
                <select asp-for="Input.OverallRating" asp-items="Model.RatingOptions" class="form-select">
                    <option value="">-- Select Rating --</option>
                </select>
                <span asp-validation-for="Input.OverallRating" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.StrengthsNoted" class="form-label"></label>
                <textarea asp-for="Input.StrengthsNoted" class="form-control" rows="4"
                          placeholder="Note the employee's key strengths..."></textarea>
                <span asp-validation-for="Input.StrengthsNoted" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.AreasForImprovement" class="form-label"></label>
                <textarea asp-for="Input.AreasForImprovement" class="form-control" rows="4"
                          placeholder="Identify areas where the employee can improve..."></textarea>
                <span asp-validation-for="Input.AreasForImprovement" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Goals" class="form-label"></label>
                <textarea asp-for="Input.Goals" class="form-control" rows="4"
                          placeholder="Set goals for the next review period..."></textarea>
                <span asp-validation-for="Input.Goals" class="text-danger"></span>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">Complete Review</button>
                <a asp-page="Details" asp-route-id="@Model.Review.Id" class="btn btn-outline-secondary ms-2">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
