@baseUrl = http://localhost:5000

### ==========================================
### MEMBERSHIP PLANS
### ==========================================

### List all active plans
GET {{baseUrl}}/api/membership-plans

### Get plan by ID
GET {{baseUrl}}/api/membership-plans/1

### Create a new plan
POST {{baseUrl}}/api/membership-plans
Content-Type: application/json

{
  "name": "Student",
  "description": "Discounted plan for students with valid ID",
  "durationMonths": 3,
  "price": 19.99,
  "maxClassBookingsPerWeek": 2,
  "allowsPremiumClasses": false
}

### Update a plan
PUT {{baseUrl}}/api/membership-plans/1
Content-Type: application/json

{
  "name": "Basic",
  "description": "Access to standard classes with limited weekly bookings - Updated",
  "durationMonths": 1,
  "price": 34.99,
  "maxClassBookingsPerWeek": 3,
  "allowsPremiumClasses": false,
  "isActive": true
}

### Deactivate a plan (soft delete)
DELETE {{baseUrl}}/api/membership-plans/1

### ==========================================
### MEMBERS
### ==========================================

### List members (with pagination)
GET {{baseUrl}}/api/members?page=1&pageSize=5

### Search members by name
GET {{baseUrl}}/api/members?search=alice

### Filter active members
GET {{baseUrl}}/api/members?isActive=true&page=1&pageSize=10

### Get member by ID (includes active membership info)
GET {{baseUrl}}/api/members/1

### Register a new member
POST {{baseUrl}}/api/members
Content-Type: application/json

{
  "firstName": "Sophie",
  "lastName": "Martinez",
  "email": "sophie.martinez@email.com",
  "phone": "555-0901",
  "dateOfBirth": "1998-06-20",
  "emergencyContactName": "Luis Martinez",
  "emergencyContactPhone": "555-0902"
}

### Update member profile
PUT {{baseUrl}}/api/members/1
Content-Type: application/json

{
  "firstName": "Alice",
  "lastName": "Johnson",
  "email": "alice.johnson@email.com",
  "phone": "555-0103",
  "emergencyContactName": "Bob Johnson",
  "emergencyContactPhone": "555-0104"
}

### Deactivate member (fails if they have future bookings)
DELETE {{baseUrl}}/api/members/8

### Get member's bookings (with filters)
GET {{baseUrl}}/api/members/1/bookings?page=1&pageSize=10

### Get member's bookings filtered by status
GET {{baseUrl}}/api/members/1/bookings?status=Confirmed

### Get member's upcoming confirmed bookings
GET {{baseUrl}}/api/members/1/bookings/upcoming

### Get member's membership history
GET {{baseUrl}}/api/members/1/memberships

### ==========================================
### MEMBERSHIPS
### ==========================================

### Create a new membership (purchase)
POST {{baseUrl}}/api/memberships
Content-Type: application/json

{
  "memberId": 8,
  "membershipPlanId": 1,
  "startDate": "2025-03-20",
  "paymentStatus": "Paid"
}

### Get membership by ID
GET {{baseUrl}}/api/memberships/1

### Cancel a membership
POST {{baseUrl}}/api/memberships/1/cancel

### Freeze a membership (7-30 days)
POST {{baseUrl}}/api/memberships/2/freeze
Content-Type: application/json

{
  "durationDays": 14
}

### Unfreeze a membership (extends end date)
POST {{baseUrl}}/api/memberships/7/unfreeze

### Renew an expired membership
POST {{baseUrl}}/api/memberships/8/renew

### ==========================================
### INSTRUCTORS
### ==========================================

### List all active instructors
GET {{baseUrl}}/api/instructors?isActive=true

### Filter by specialization
GET {{baseUrl}}/api/instructors?specialization=Yoga

### Get instructor by ID
GET {{baseUrl}}/api/instructors/1

### Create a new instructor
POST {{baseUrl}}/api/instructors
Content-Type: application/json

{
  "firstName": "Lena",
  "lastName": "Fischer",
  "email": "lena.fischer@zenithfitness.com",
  "phone": "555-1005",
  "bio": "Certified personal trainer with expertise in functional fitness",
  "specializations": "HIIT,Pilates",
  "hireDate": "2025-01-15"
}

### Update an instructor
PUT {{baseUrl}}/api/instructors/1
Content-Type: application/json

{
  "firstName": "Maria",
  "lastName": "Garcia",
  "email": "maria.garcia@zenithfitness.com",
  "phone": "555-1001",
  "bio": "Certified yoga instructor with 10+ years of experience in Hatha and Vinyasa yoga.",
  "specializations": "Yoga,Pilates,Meditation,Barre",
  "isActive": true
}

### Get instructor's schedule
GET {{baseUrl}}/api/instructors/1/schedule

### Get instructor's schedule (filtered by date range)
GET {{baseUrl}}/api/instructors/1/schedule?from=2025-03-18&to=2025-03-25

### ==========================================
### CLASS TYPES
### ==========================================

### List all class types
GET {{baseUrl}}/api/class-types

### Filter by difficulty level
GET {{baseUrl}}/api/class-types?difficulty=Advanced

### Filter premium classes
GET {{baseUrl}}/api/class-types?isPremium=true

### Get class type by ID
GET {{baseUrl}}/api/class-types/1

### Create a new class type
POST {{baseUrl}}/api/class-types
Content-Type: application/json

{
  "name": "Barre",
  "description": "Ballet-inspired workout combining strength and flexibility",
  "defaultDurationMinutes": 45,
  "defaultCapacity": 18,
  "isPremium": false,
  "caloriesPerSession": 300,
  "difficultyLevel": "Intermediate"
}

### Update a class type
PUT {{baseUrl}}/api/class-types/1
Content-Type: application/json

{
  "name": "Yoga",
  "description": "Traditional Hatha yoga for flexibility, relaxation, and mindfulness",
  "defaultDurationMinutes": 60,
  "defaultCapacity": 22,
  "isPremium": false,
  "caloriesPerSession": 220,
  "difficultyLevel": "AllLevels",
  "isActive": true
}

### ==========================================
### CLASS SCHEDULES
### ==========================================

### List all classes (paginated)
GET {{baseUrl}}/api/classes?page=1&pageSize=10

### Filter by class type
GET {{baseUrl}}/api/classes?classTypeId=1

### Filter by instructor
GET {{baseUrl}}/api/classes?instructorId=1

### Filter classes with availability
GET {{baseUrl}}/api/classes?hasAvailability=true

### Get class by ID
GET {{baseUrl}}/api/classes/1

### Schedule a new class
POST {{baseUrl}}/api/classes
Content-Type: application/json

{
  "classTypeId": 1,
  "instructorId": 3,
  "startTime": "2025-03-25T10:00:00",
  "endTime": "2025-03-25T11:00:00",
  "capacity": 20,
  "room": "Studio A"
}

### Update a class
PUT {{baseUrl}}/api/classes/1
Content-Type: application/json

{
  "instructorId": 1,
  "startTime": "2025-03-20T07:30:00",
  "endTime": "2025-03-20T08:30:00",
  "capacity": 25,
  "room": "Studio A"
}

### Cancel a class (cascades to all bookings)
PATCH {{baseUrl}}/api/classes/2/cancel
Content-Type: application/json

{
  "reason": "Instructor called in sick"
}

### Get class roster (confirmed members)
GET {{baseUrl}}/api/classes/1/roster

### Get class waitlist
GET {{baseUrl}}/api/classes/5/waitlist

### Get available classes (next 7 days with open spots)
GET {{baseUrl}}/api/classes/available

### ==========================================
### BOOKINGS
### ==========================================

### Book a class (enforces all business rules)
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 4,
  "memberId": 1
}

### Get booking by ID
GET {{baseUrl}}/api/bookings/1

### Cancel a booking
POST {{baseUrl}}/api/bookings/1/cancel
Content-Type: application/json

{
  "reason": "Changed my plans"
}

### Check in to a class (only within 15 min window around start)
POST {{baseUrl}}/api/bookings/1/check-in

### Mark as no-show (only after 15 min past start)
POST {{baseUrl}}/api/bookings/1/no-show

### ==========================================
### BUSINESS RULE TEST SCENARIOS
### ==========================================

### Test: Book a premium class with Basic plan (should fail - rule 4)
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 2,
  "memberId": 3
}

### Test: Book when class is full (should go to waitlist - rule 2)
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 5,
  "memberId": 3
}

### Test: Freeze membership with invalid duration (should fail - rule 9)
POST {{baseUrl}}/api/memberships/1/freeze
Content-Type: application/json

{
  "durationDays": 5
}

### Test: Create member under 16 (should fail)
POST {{baseUrl}}/api/members
Content-Type: application/json

{
  "firstName": "Young",
  "lastName": "Person",
  "email": "young@email.com",
  "phone": "555-9999",
  "dateOfBirth": "2015-01-01",
  "emergencyContactName": "Parent Person",
  "emergencyContactPhone": "555-9998"
}

### Test: Duplicate email registration (should fail)
POST {{baseUrl}}/api/members
Content-Type: application/json

{
  "firstName": "Duplicate",
  "lastName": "User",
  "email": "alice.johnson@email.com",
  "phone": "555-8888",
  "dateOfBirth": "1990-01-01",
  "emergencyContactName": "Contact Name",
  "emergencyContactPhone": "555-8887"
}
