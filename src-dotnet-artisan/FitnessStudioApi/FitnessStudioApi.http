@baseUrl = http://localhost:5137

### ============================================================
### MEMBERSHIP PLANS
### ============================================================

### List all active membership plans
GET {{baseUrl}}/api/membership-plans

### Get a specific membership plan (Basic)
GET {{baseUrl}}/api/membership-plans/1

### Create a new membership plan
POST {{baseUrl}}/api/membership-plans
Content-Type: application/json

{
  "name": "Student",
  "description": "Discounted plan for students with valid ID",
  "durationMonths": 3,
  "price": 19.99,
  "maxClassBookingsPerWeek": 2,
  "allowsPremiumClasses": false
}

### Update a membership plan
PUT {{baseUrl}}/api/membership-plans/1
Content-Type: application/json

{
  "name": "Basic",
  "description": "Access to standard classes, 3 bookings per week - Updated",
  "durationMonths": 1,
  "price": 34.99,
  "maxClassBookingsPerWeek": 3,
  "allowsPremiumClasses": false
}

### Deactivate a membership plan
DELETE {{baseUrl}}/api/membership-plans/1

### ============================================================
### MEMBERS
### ============================================================

### List all members (with pagination)
GET {{baseUrl}}/api/members?page=1&pageSize=5

### Search members by name
GET {{baseUrl}}/api/members?search=alice

### Filter active members
GET {{baseUrl}}/api/members?isActive=true&page=1&pageSize=10

### Get member details (Alice Johnson)
GET {{baseUrl}}/api/members/1

### Register a new member
POST {{baseUrl}}/api/members
Content-Type: application/json

{
  "firstName": "Olivia",
  "lastName": "Martinez",
  "email": "olivia.martinez@email.com",
  "phone": "555-0120",
  "dateOfBirth": "1998-04-22",
  "emergencyContactName": "Miguel Martinez",
  "emergencyContactPhone": "555-0121"
}

### Update a member
PUT {{baseUrl}}/api/members/1
Content-Type: application/json

{
  "firstName": "Alice",
  "lastName": "Johnson",
  "email": "alice.johnson@email.com",
  "phone": "555-0101-updated",
  "dateOfBirth": "1990-03-15",
  "emergencyContactName": "Bob Johnson",
  "emergencyContactPhone": "555-0102"
}

### Deactivate a member (will fail if has future bookings)
DELETE {{baseUrl}}/api/members/7

### Get member's bookings (Alice)
GET {{baseUrl}}/api/members/1/bookings?page=1&pageSize=10

### Get member's bookings filtered by status
GET {{baseUrl}}/api/members/1/bookings?status=Confirmed&page=1&pageSize=10

### Get member's upcoming bookings
GET {{baseUrl}}/api/members/1/bookings/upcoming

### Get member's membership history
GET {{baseUrl}}/api/members/1/memberships

### ============================================================
### MEMBERSHIPS
### ============================================================

### Create a new membership (for Elena who has expired membership)
POST {{baseUrl}}/api/memberships
Content-Type: application/json

{
  "memberId": 7,
  "membershipPlanId": 2,
  "startDate": "2026-03-20",
  "paymentStatus": "Paid"
}

### Get membership details
GET {{baseUrl}}/api/memberships/1

### Cancel a membership
POST {{baseUrl}}/api/memberships/1/cancel

### Freeze a membership (member 2, Marcus - Premium)
POST {{baseUrl}}/api/memberships/2/freeze
Content-Type: application/json

{
  "freezeDays": 14
}

### Unfreeze a membership
POST {{baseUrl}}/api/memberships/2/unfreeze

### Renew an expired membership (Elena's expired membership, id=7)
POST {{baseUrl}}/api/memberships/7/renew

### ============================================================
### INSTRUCTORS
### ============================================================

### List all instructors
GET {{baseUrl}}/api/instructors

### Filter instructors by specialization
GET {{baseUrl}}/api/instructors?specialization=yoga

### Filter active instructors
GET {{baseUrl}}/api/instructors?isActive=true

### Get instructor details
GET {{baseUrl}}/api/instructors/1

### Create a new instructor
POST {{baseUrl}}/api/instructors
Content-Type: application/json

{
  "firstName": "Alex",
  "lastName": "Morgan",
  "email": "alex.morgan@zenithfitness.com",
  "phone": "555-0205",
  "bio": "Certified CrossFit and functional training specialist",
  "specializations": "CrossFit, Functional Training, HIIT",
  "hireDate": "2026-01-15"
}

### Update an instructor
PUT {{baseUrl}}/api/instructors/1
Content-Type: application/json

{
  "firstName": "Maya",
  "lastName": "Thompson",
  "email": "maya.thompson@zenithfitness.com",
  "phone": "555-0201",
  "bio": "Certified yoga and meditation instructor with 12 years of experience",
  "specializations": "Yoga, Meditation, Pilates, Breathwork",
  "hireDate": "2020-01-15"
}

### Get instructor's schedule
GET {{baseUrl}}/api/instructors/1/schedule

### Get instructor's schedule with date range
GET {{baseUrl}}/api/instructors/2/schedule?from=2026-03-20&to=2026-03-30

### ============================================================
### CLASS TYPES
### ============================================================

### List all class types
GET {{baseUrl}}/api/class-types

### Filter by difficulty
GET {{baseUrl}}/api/class-types?difficulty=Beginner

### Filter premium classes
GET {{baseUrl}}/api/class-types?isPremium=true

### Get class type details
GET {{baseUrl}}/api/class-types/1

### Create a new class type
POST {{baseUrl}}/api/class-types
Content-Type: application/json

{
  "name": "Zumba",
  "description": "Dance-based fitness class combining Latin rhythms with cardio",
  "defaultDurationMinutes": 60,
  "defaultCapacity": 30,
  "isPremium": false,
  "caloriesPerSession": 400,
  "difficultyLevel": "AllLevels"
}

### Update a class type
PUT {{baseUrl}}/api/class-types/1
Content-Type: application/json

{
  "name": "Yoga",
  "description": "Vinyasa flow yoga for all levels - now with hot yoga option",
  "defaultDurationMinutes": 75,
  "defaultCapacity": 20,
  "isPremium": false,
  "caloriesPerSession": 300,
  "difficultyLevel": "AllLevels"
}

### ============================================================
### CLASS SCHEDULES
### ============================================================

### List all scheduled classes
GET {{baseUrl}}/api/classes?page=1&pageSize=20

### Filter classes by date range
GET {{baseUrl}}/api/classes?from=2026-03-21&to=2026-03-23&page=1&pageSize=10

### Filter classes by class type
GET {{baseUrl}}/api/classes?classTypeId=1&page=1&pageSize=10

### Filter classes by instructor
GET {{baseUrl}}/api/classes?instructorId=2&page=1&pageSize=10

### Filter classes with availability
GET {{baseUrl}}/api/classes?hasAvailability=true&page=1&pageSize=10

### Get class details
GET {{baseUrl}}/api/classes/1

### Schedule a new class
POST {{baseUrl}}/api/classes
Content-Type: application/json

{
  "classTypeId": 1,
  "instructorId": 1,
  "startTime": "2026-03-25T14:00:00",
  "endTime": "2026-03-25T15:00:00",
  "capacity": 20,
  "room": "Studio A"
}

### Update a class
PUT {{baseUrl}}/api/classes/1
Content-Type: application/json

{
  "classTypeId": 1,
  "instructorId": 1,
  "startTime": "2026-03-21T07:30:00",
  "endTime": "2026-03-21T08:30:00",
  "capacity": 25,
  "room": "Studio A"
}

### Cancel a class (cascade cancels all bookings)
PATCH {{baseUrl}}/api/classes/2/cancel
Content-Type: application/json

{
  "reason": "Instructor called in sick"
}

### Get class roster (confirmed/attended members)
GET {{baseUrl}}/api/classes/1/roster

### Get class waitlist
GET {{baseUrl}}/api/classes/9/waitlist

### Get available classes in the next 7 days
GET {{baseUrl}}/api/classes/available

### ============================================================
### BOOKINGS
### ============================================================

### Book a class (Alice for Pilates class)
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 4,
  "memberId": 1
}

### Book a class (will be waitlisted if class full - try class 9)
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 9,
  "memberId": 5
}

### Get booking details
GET {{baseUrl}}/api/bookings/1

### Cancel a booking (promotes waitlist)
POST {{baseUrl}}/api/bookings/5/cancel
Content-Type: application/json

{
  "reason": "Schedule conflict"
}

### Check in for a class (use a booking for a class starting soon)
POST {{baseUrl}}/api/bookings/1/check-in

### Mark a booking as no-show
POST {{baseUrl}}/api/bookings/1/no-show

### ============================================================
### BUSINESS RULE TESTS
### ============================================================

### Try to book a premium class with Basic membership (Sofia, member 3 has Basic)
### Should fail with tier access error
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 5,
  "memberId": 3
}

### Try to book without active membership (Elena, member 7 has expired)
### Should fail with membership error
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 1,
  "memberId": 7
}

### Try to register underage member (should fail - under 16)
POST {{baseUrl}}/api/members
Content-Type: application/json

{
  "firstName": "Young",
  "lastName": "Person",
  "email": "young.person@email.com",
  "phone": "555-0199",
  "dateOfBirth": "2015-01-01",
  "emergencyContactName": "Parent Person",
  "emergencyContactPhone": "555-0198"
}

### Try to freeze membership with invalid duration (should fail - must be 7-30 days)
POST {{baseUrl}}/api/memberships/1/freeze
Content-Type: application/json

{
  "freezeDays": 60
}

### Try to create duplicate email member
POST {{baseUrl}}/api/members
Content-Type: application/json

{
  "firstName": "Alice",
  "lastName": "Duplicate",
  "email": "alice.johnson@email.com",
  "phone": "555-0999",
  "dateOfBirth": "1990-03-15",
  "emergencyContactName": "Test Contact",
  "emergencyContactPhone": "555-0998"
}
