@baseUrl = http://localhost:5000

### ============================================================
### OWNERS
### ============================================================

### List all owners
GET {{baseUrl}}/api/owners?page=1&pageSize=10

### Search owners by name
GET {{baseUrl}}/api/owners?search=Johnson

### Get owner by ID (with pets)
GET {{baseUrl}}/api/owners/1

### Create a new owner
POST {{baseUrl}}/api/owners
Content-Type: application/json

{
  "firstName": "David",
  "lastName": "Miller",
  "email": "david.miller@email.com",
  "phone": "555-0106",
  "address": "100 Walnut Court",
  "city": "Chicago",
  "state": "IL",
  "zipCode": "60601"
}

### Update owner
PUT {{baseUrl}}/api/owners/1
Content-Type: application/json

{
  "firstName": "Sarah",
  "lastName": "Johnson",
  "email": "sarah.johnson@email.com",
  "phone": "555-0101",
  "address": "123 Oak Street, Apt 2B",
  "city": "Springfield",
  "state": "IL",
  "zipCode": "62701"
}

### Delete owner (will fail if has active pets)
DELETE {{baseUrl}}/api/owners/5

### Get owner's pets
GET {{baseUrl}}/api/owners/1/pets

### Get owner's appointment history
GET {{baseUrl}}/api/owners/1/appointments?page=1&pageSize=10

### ============================================================
### PETS
### ============================================================

### List all active pets
GET {{baseUrl}}/api/pets?page=1&pageSize=10

### Search pets by name
GET {{baseUrl}}/api/pets?search=Buddy

### Filter pets by species
GET {{baseUrl}}/api/pets?species=Dog

### Include inactive pets
GET {{baseUrl}}/api/pets?includeInactive=true

### Get pet by ID (with owner)
GET {{baseUrl}}/api/pets/1

### Create a new pet
POST {{baseUrl}}/api/pets
Content-Type: application/json

{
  "name": "Rocky",
  "species": "Dog",
  "breed": "Bulldog",
  "dateOfBirth": "2022-06-15",
  "weight": 25.0,
  "color": "Brindle",
  "microchipNumber": "MC-009-2022",
  "ownerId": 1
}

### Update pet (including owner transfer)
PUT {{baseUrl}}/api/pets/1
Content-Type: application/json

{
  "name": "Buddy",
  "species": "Dog",
  "breed": "Golden Retriever",
  "dateOfBirth": "2020-05-15",
  "weight": 33.0,
  "color": "Golden",
  "microchipNumber": "MC-001-2020",
  "ownerId": 1
}

### Soft delete a pet
DELETE {{baseUrl}}/api/pets/8

### Get pet's medical records
GET {{baseUrl}}/api/pets/1/medical-records

### Get pet's vaccinations
GET {{baseUrl}}/api/pets/1/vaccinations

### Get pet's upcoming/overdue vaccinations
GET {{baseUrl}}/api/pets/3/vaccinations/upcoming

### Get pet's active prescriptions
GET {{baseUrl}}/api/pets/5/prescriptions/active

### ============================================================
### VETERINARIANS
### ============================================================

### List all veterinarians
GET {{baseUrl}}/api/veterinarians?page=1&pageSize=10

### Filter by specialization
GET {{baseUrl}}/api/veterinarians?specialization=Surgery

### Filter by availability
GET {{baseUrl}}/api/veterinarians?isAvailable=true

### Get veterinarian by ID
GET {{baseUrl}}/api/veterinarians/1

### Create a new veterinarian
POST {{baseUrl}}/api/veterinarians
Content-Type: application/json

{
  "firstName": "Dr. Patricia",
  "lastName": "Lee",
  "email": "patricia.lee@happypaws.com",
  "phone": "555-0204",
  "specialization": "Emergency Medicine",
  "licenseNumber": "VET-2023-004",
  "hireDate": "2023-06-01"
}

### Update veterinarian
PUT {{baseUrl}}/api/veterinarians/1
Content-Type: application/json

{
  "firstName": "Dr. Amanda",
  "lastName": "Foster",
  "email": "amanda.foster@happypaws.com",
  "phone": "555-0201",
  "specialization": "General Practice",
  "licenseNumber": "VET-2019-001",
  "isAvailable": true
}

### Get veterinarian's schedule for a specific date
GET {{baseUrl}}/api/veterinarians/1/schedule?date=2025-07-20

### Get veterinarian's appointments
GET {{baseUrl}}/api/veterinarians/1/appointments?page=1&pageSize=10

### Get veterinarian's completed appointments
GET {{baseUrl}}/api/veterinarians/1/appointments?status=Completed

### ============================================================
### APPOINTMENTS
### ============================================================

### List all appointments
GET {{baseUrl}}/api/appointments?page=1&pageSize=10

### Filter by status
GET {{baseUrl}}/api/appointments?status=Scheduled

### Filter by date range
GET {{baseUrl}}/api/appointments?dateFrom=2025-06-01&dateTo=2025-08-01

### Filter by veterinarian
GET {{baseUrl}}/api/appointments?vetId=1

### Filter by pet
GET {{baseUrl}}/api/appointments?petId=1

### Get appointment by ID (with details)
GET {{baseUrl}}/api/appointments/1

### Get today's appointments
GET {{baseUrl}}/api/appointments/today

### Schedule a new appointment
POST {{baseUrl}}/api/appointments
Content-Type: application/json

{
  "petId": 2,
  "veterinarianId": 2,
  "appointmentDate": "2025-08-15T10:00:00Z",
  "durationMinutes": 30,
  "reason": "Annual dental cleaning",
  "notes": "Cat may need sedation"
}

### Update an appointment
PUT {{baseUrl}}/api/appointments/7
Content-Type: application/json

{
  "petId": 1,
  "veterinarianId": 1,
  "appointmentDate": "2025-08-20T09:00:00Z",
  "durationMinutes": 45,
  "reason": "Follow-up wellness check - extended",
  "notes": "Include blood work"
}

### Check in an appointment
PATCH {{baseUrl}}/api/appointments/7/status
Content-Type: application/json

{
  "status": "CheckedIn"
}

### Start appointment
PATCH {{baseUrl}}/api/appointments/7/status
Content-Type: application/json

{
  "status": "InProgress"
}

### Complete appointment
PATCH {{baseUrl}}/api/appointments/7/status
Content-Type: application/json

{
  "status": "Completed"
}

### Cancel an appointment
PATCH {{baseUrl}}/api/appointments/8/status
Content-Type: application/json

{
  "status": "Cancelled",
  "cancellationReason": "Pet owner is traveling"
}

### ============================================================
### MEDICAL RECORDS
### ============================================================

### Get medical record by ID (with prescriptions)
GET {{baseUrl}}/api/medical-records/1

### Create medical record (for a completed appointment)
POST {{baseUrl}}/api/medical-records
Content-Type: application/json

{
  "appointmentId": 1,
  "diagnosis": "Healthy - annual exam complete",
  "treatment": "Routine physical examination. All vitals within normal range.",
  "notes": "Recommend continued heartworm prevention.",
  "followUpDate": "2026-01-15"
}

### Update medical record
PUT {{baseUrl}}/api/medical-records/1
Content-Type: application/json

{
  "diagnosis": "Healthy - annual exam complete (updated)",
  "treatment": "Routine physical examination. All vitals within normal range. Blood work normal.",
  "notes": "Recommend continued heartworm prevention. Added dental cleaning recommendation.",
  "followUpDate": "2026-01-15"
}

### ============================================================
### PRESCRIPTIONS
### ============================================================

### Get prescription by ID
GET {{baseUrl}}/api/prescriptions/1

### Create a new prescription
POST {{baseUrl}}/api/prescriptions
Content-Type: application/json

{
  "medicalRecordId": 3,
  "medicationName": "Glucosamine Supplement",
  "dosage": "500mg once daily",
  "durationDays": 60,
  "startDate": "2025-07-17",
  "instructions": "Mix with food. May take 2-3 weeks to show improvement."
}

### ============================================================
### VACCINATIONS
### ============================================================

### Get vaccination by ID
GET {{baseUrl}}/api/vaccinations/1

### Record a new vaccination
POST {{baseUrl}}/api/vaccinations
Content-Type: application/json

{
  "petId": 3,
  "vaccineName": "DHPP Booster",
  "dateAdministered": "2025-07-17",
  "expirationDate": "2026-07-17",
  "batchNumber": "DHPP-2025-7001",
  "administeredByVetId": 1,
  "notes": "Annual booster - dog tolerated well"
}
