@baseUrl = http://localhost:5222/api

### ========================
### OWNERS
### ========================

### List all owners
GET {{baseUrl}}/owners?page=1&pageSize=10
Accept: application/json

###

### Search owners by name
GET {{baseUrl}}/owners?search=Johnson&page=1&pageSize=10
Accept: application/json

###

### Get owner by ID (includes pets)
GET {{baseUrl}}/owners/1
Accept: application/json

###

### Create a new owner
POST {{baseUrl}}/owners
Content-Type: application/json

{
  "firstName": "Alice",
  "lastName": "Thompson",
  "email": "alice.thompson@email.com",
  "phone": "555-0199",
  "address": "999 Birch Court",
  "city": "Seattle",
  "state": "WA",
  "zipCode": "98101"
}

###

### Update an owner
PUT {{baseUrl}}/owners/1
Content-Type: application/json

{
  "firstName": "Sarah",
  "lastName": "Johnson",
  "email": "sarah.johnson@email.com",
  "phone": "555-0101",
  "address": "123 Oak Street Updated",
  "city": "Springfield",
  "state": "IL",
  "zipCode": "62701"
}

###

### Delete an owner (will fail if owner has active pets)
DELETE {{baseUrl}}/owners/6
Accept: application/json

###

### Get all pets for an owner
GET {{baseUrl}}/owners/1/pets
Accept: application/json

###

### Get appointment history for an owner's pets
GET {{baseUrl}}/owners/1/appointments
Accept: application/json

###

### ========================
### PETS
### ========================

### List all active pets
GET {{baseUrl}}/pets?page=1&pageSize=10
Accept: application/json

###

### Search pets by name
GET {{baseUrl}}/pets?search=Buddy&page=1&pageSize=10
Accept: application/json

###

### Filter pets by species
GET {{baseUrl}}/pets?species=Cat&page=1&pageSize=10
Accept: application/json

###

### Include inactive pets
GET {{baseUrl}}/pets?includeInactive=true&page=1&pageSize=10
Accept: application/json

###

### Get pet by ID (includes owner info)
GET {{baseUrl}}/pets/1
Accept: application/json

###

### Create a new pet
POST {{baseUrl}}/pets
Content-Type: application/json

{
  "name": "Rocky",
  "species": "Dog",
  "breed": "Bulldog",
  "dateOfBirth": "2022-06-15",
  "weight": 25.5,
  "color": "Brindle",
  "microchipNumber": "MC-009-2022",
  "ownerId": 1
}

###

### Update a pet (including owner transfer)
PUT {{baseUrl}}/pets/1
Content-Type: application/json

{
  "name": "Buddy",
  "species": "Dog",
  "breed": "Golden Retriever",
  "dateOfBirth": "2020-03-15",
  "weight": 33.0,
  "color": "Golden",
  "microchipNumber": "MC-001-2020",
  "ownerId": 1
}

###

### Soft-delete a pet (set IsActive = false)
DELETE {{baseUrl}}/pets/1
Accept: application/json

###

### Get medical records for a pet
GET {{baseUrl}}/pets/1/medical-records
Accept: application/json

###

### Get all vaccinations for a pet
GET {{baseUrl}}/pets/1/vaccinations
Accept: application/json

###

### Get upcoming/overdue vaccinations for a pet
GET {{baseUrl}}/pets/3/vaccinations/upcoming
Accept: application/json

###

### Get active prescriptions for a pet
GET {{baseUrl}}/pets/8/prescriptions/active
Accept: application/json

###

### ========================
### VETERINARIANS
### ========================

### List all veterinarians
GET {{baseUrl}}/veterinarians?page=1&pageSize=10
Accept: application/json

###

### Filter by specialization
GET {{baseUrl}}/veterinarians?specialization=Surgery&page=1&pageSize=10
Accept: application/json

###

### Filter by availability
GET {{baseUrl}}/veterinarians?isAvailable=true&page=1&pageSize=10
Accept: application/json

###

### Get vet details
GET {{baseUrl}}/veterinarians/1
Accept: application/json

###

### Create a new veterinarian
POST {{baseUrl}}/veterinarians
Content-Type: application/json

{
  "firstName": "Dr. Emily",
  "lastName": "Park",
  "email": "e.park@happypaws.com",
  "phone": "555-0204",
  "specialization": "Cardiology",
  "licenseNumber": "VET-2023-004",
  "hireDate": "2023-09-01"
}

###

### Update a veterinarian
PUT {{baseUrl}}/veterinarians/1
Content-Type: application/json

{
  "firstName": "Dr. Robert",
  "lastName": "Smith",
  "email": "r.smith@happypaws.com",
  "phone": "555-0201",
  "specialization": "General Practice & Emergency",
  "licenseNumber": "VET-2015-001",
  "isAvailable": true
}

###

### Get vet's schedule for a specific date (use today's date)
GET {{baseUrl}}/veterinarians/1/schedule?date=2025-07-21
Accept: application/json

###

### Get all appointments for a vet (with pagination and status filter)
GET {{baseUrl}}/veterinarians/1/appointments?page=1&pageSize=10
Accept: application/json

###

### Get completed appointments for a vet
GET {{baseUrl}}/veterinarians/1/appointments?status=Completed&page=1&pageSize=10
Accept: application/json

###

### ========================
### APPOINTMENTS
### ========================

### List all appointments
GET {{baseUrl}}/appointments?page=1&pageSize=10
Accept: application/json

###

### Filter appointments by date range
GET {{baseUrl}}/appointments?fromDate=2025-07-01&toDate=2025-08-01&page=1&pageSize=10
Accept: application/json

###

### Filter by status
GET {{baseUrl}}/appointments?status=Scheduled&page=1&pageSize=10
Accept: application/json

###

### Get appointment details (includes pet, vet, medical record)
GET {{baseUrl}}/appointments/1
Accept: application/json

###

### Schedule a new appointment
POST {{baseUrl}}/appointments
Content-Type: application/json

{
  "petId": 1,
  "veterinarianId": 1,
  "appointmentDate": "2025-12-15T10:00:00",
  "durationMinutes": 30,
  "reason": "Annual wellness exam",
  "notes": "Owner requested morning appointment"
}

###

### Update an appointment
PUT {{baseUrl}}/appointments/9
Content-Type: application/json

{
  "petId": 1,
  "veterinarianId": 2,
  "appointmentDate": "2025-12-16T14:00:00",
  "durationMinutes": 45,
  "reason": "Dental cleaning - rescheduled",
  "notes": "Moved to afternoon slot"
}

###

### Update appointment status - Check In
PATCH {{baseUrl}}/appointments/7/status
Content-Type: application/json

{
  "status": "CheckedIn"
}

###

### Update appointment status - Cancel (requires reason)
PATCH {{baseUrl}}/appointments/9/status
Content-Type: application/json

{
  "status": "Cancelled",
  "cancellationReason": "Owner needs to reschedule"
}

###

### Get today's appointments
GET {{baseUrl}}/appointments/today
Accept: application/json

###

### ========================
### MEDICAL RECORDS
### ========================

### Get medical record with prescriptions
GET {{baseUrl}}/medical-records/1
Accept: application/json

###

### Create a medical record (appointment must be Completed or InProgress)
POST {{baseUrl}}/medical-records
Content-Type: application/json

{
  "appointmentId": 8,
  "diagnosis": "Mild overgrown nails, otherwise healthy",
  "treatment": "Nails trimmed. General health check performed.",
  "notes": "Rabbit is in good condition. Recommend regular nail trims every 6-8 weeks.",
  "followUpDate": "2025-09-15"
}

###

### Update a medical record
PUT {{baseUrl}}/medical-records/1
Content-Type: application/json

{
  "diagnosis": "Healthy - no concerns found (updated)",
  "treatment": "Routine physical exam completed. All vitals normal. Blood work ordered.",
  "notes": "Weight is appropriate for age and breed. Follow up on blood work results.",
  "followUpDate": "2026-01-15"
}

###

### ========================
### PRESCRIPTIONS
### ========================

### Get prescription details
GET {{baseUrl}}/prescriptions/1
Accept: application/json

###

### Create a prescription
POST {{baseUrl}}/prescriptions
Content-Type: application/json

{
  "medicalRecordId": 1,
  "medicationName": "Flea Prevention",
  "dosage": "1 topical application monthly",
  "durationDays": 90,
  "startDate": "2025-07-21",
  "instructions": "Apply between shoulder blades on dry skin"
}

###

### ========================
### VACCINATIONS
### ========================

### Record a new vaccination
POST {{baseUrl}}/vaccinations
Content-Type: application/json

{
  "petId": 1,
  "vaccineName": "Leptospirosis",
  "dateAdministered": "2025-07-21",
  "expirationDate": "2026-07-21",
  "batchNumber": "LEP-2025-G7",
  "administeredByVetId": 1,
  "notes": "Annual booster"
}

###

### Get vaccination details
GET {{baseUrl}}/vaccinations/1
Accept: application/json

###
