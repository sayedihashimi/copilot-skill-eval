@baseUrl = http://localhost:5000

### ============================================================
### AUTHORS
### ============================================================

### List all authors
GET {{baseUrl}}/api/authors?page=1&pageSize=10

### Search authors
GET {{baseUrl}}/api/authors?search=orwell

### Get author by ID (George Orwell)
GET {{baseUrl}}/api/authors/1

### Create a new author
POST {{baseUrl}}/api/authors
Content-Type: application/json

{
  "firstName": "Agatha",
  "lastName": "Christie",
  "biography": "English writer known for her detective novels.",
  "birthDate": "1890-09-15",
  "country": "United Kingdom"
}

### Update an author
PUT {{baseUrl}}/api/authors/1
Content-Type: application/json

{
  "firstName": "George",
  "lastName": "Orwell",
  "biography": "English novelist, essayist, journalist and critic, best known for 1984 and Animal Farm.",
  "birthDate": "1903-06-25",
  "country": "United Kingdom"
}

### Delete an author (will fail — has books)
DELETE {{baseUrl}}/api/authors/1

### ============================================================
### CATEGORIES
### ============================================================

### List all categories
GET {{baseUrl}}/api/categories

### Get category by ID (Fiction)
GET {{baseUrl}}/api/categories/1

### Create a new category
POST {{baseUrl}}/api/categories
Content-Type: application/json

{
  "name": "Philosophy",
  "description": "Works exploring fundamental questions about existence and knowledge"
}

### Update a category
PUT {{baseUrl}}/api/categories/1
Content-Type: application/json

{
  "name": "Fiction",
  "description": "Narrative works of creative and imaginative storytelling"
}

### Delete a category (will fail — has books)
DELETE {{baseUrl}}/api/categories/1

### ============================================================
### BOOKS
### ============================================================

### List all books
GET {{baseUrl}}/api/books?page=1&pageSize=10

### Search books by title
GET {{baseUrl}}/api/books?search=1984

### Search books by author name
GET {{baseUrl}}/api/books?search=asimov

### Filter by category
GET {{baseUrl}}/api/books?category=Science%20Fiction

### Filter available books only
GET {{baseUrl}}/api/books?available=true

### Filter unavailable books
GET {{baseUrl}}/api/books?available=false

### Sort by title descending
GET {{baseUrl}}/api/books?sortBy=title&sortDir=desc

### Get book by ID (1984)
GET {{baseUrl}}/api/books/1

### Create a new book
POST {{baseUrl}}/api/books
Content-Type: application/json

{
  "title": "Brave New World",
  "isbn": "978-0060850524",
  "publisher": "Harper Perennial",
  "publicationYear": 1932,
  "description": "A dystopian novel about a technologically advanced future society.",
  "pageCount": 288,
  "language": "English",
  "totalCopies": 3,
  "authorIds": [1],
  "categoryIds": [1, 2]
}

### Update a book
PUT {{baseUrl}}/api/books/1
Content-Type: application/json

{
  "title": "1984",
  "isbn": "978-0451524935",
  "publisher": "Signet Classics",
  "publicationYear": 1949,
  "description": "A dystopian novel about totalitarian surveillance and thought control.",
  "pageCount": 328,
  "language": "English",
  "totalCopies": 6
}

### Delete a book (will fail — has active loans)
DELETE {{baseUrl}}/api/books/1

### Get loan history for a book
GET {{baseUrl}}/api/books/1/loans

### Get active reservations for a book
GET {{baseUrl}}/api/books/12/reservations

### ============================================================
### PATRONS
### ============================================================

### List all patrons
GET {{baseUrl}}/api/patrons?page=1&pageSize=10

### Search patrons
GET {{baseUrl}}/api/patrons?search=alice

### Filter by membership type
GET {{baseUrl}}/api/patrons?membershipType=Premium

### Get patron by ID (Alice Johnson — Premium)
GET {{baseUrl}}/api/patrons/1

### Create a new patron
POST {{baseUrl}}/api/patrons
Content-Type: application/json

{
  "firstName": "Grace",
  "lastName": "Hopper",
  "email": "grace.hopper@email.com",
  "phone": "555-0201",
  "address": "100 Navy Yard",
  "membershipType": "Premium"
}

### Update a patron
PUT {{baseUrl}}/api/patrons/2
Content-Type: application/json

{
  "firstName": "Bob",
  "lastName": "Smith",
  "email": "bob.smith@email.com",
  "phone": "555-0102",
  "address": "456 Oak Ave, Apt 2B",
  "membershipType": "Premium"
}

### Deactivate a patron (will fail — has active loans)
DELETE {{baseUrl}}/api/patrons/1

### Deactivate inactive patron (Frank Miller — already inactive, no active loans)
DELETE {{baseUrl}}/api/patrons/6

### Get patron's loans
GET {{baseUrl}}/api/patrons/1/loans

### Get patron's loans filtered by status
GET {{baseUrl}}/api/patrons/2/loans?status=Overdue

### Get patron's reservations
GET {{baseUrl}}/api/patrons/3/reservations

### Get patron's fines
GET {{baseUrl}}/api/patrons/2/fines

### Get patron's unpaid fines
GET {{baseUrl}}/api/patrons/4/fines?status=Unpaid

### ============================================================
### LOANS
### ============================================================

### List all loans
GET {{baseUrl}}/api/loans?page=1&pageSize=10

### List active loans
GET {{baseUrl}}/api/loans?status=Active

### List returned loans
GET {{baseUrl}}/api/loans?status=Returned

### Get loan by ID
GET {{baseUrl}}/api/loans/1

### Checkout a book (valid — Book 7 has copies, Patron 3 is Student with few loans)
POST {{baseUrl}}/api/loans
Content-Type: application/json

{
  "bookId": 7,
  "patronId": 3
}

### Checkout — should fail: book 12 has no available copies
POST {{baseUrl}}/api/loans
Content-Type: application/json

{
  "bookId": 12,
  "patronId": 4
}

### Checkout — should fail: inactive patron
POST {{baseUrl}}/api/loans
Content-Type: application/json

{
  "bookId": 7,
  "patronId": 6
}

### Return a loan (loan #2 — Active)
POST {{baseUrl}}/api/loans/2/return

### Renew a loan (loan #1 — Active, Alice is Premium)
POST {{baseUrl}}/api/loans/1/renew

### Renew — should fail: overdue loan
POST {{baseUrl}}/api/loans/7/renew

### Get all overdue loans
GET {{baseUrl}}/api/loans/overdue

### ============================================================
### RESERVATIONS
### ============================================================

### List all reservations
GET {{baseUrl}}/api/reservations?page=1&pageSize=10

### List pending reservations
GET {{baseUrl}}/api/reservations?status=Pending

### Get reservation by ID
GET {{baseUrl}}/api/reservations/1

### Create a reservation (Book 1 — has copies but patron wants to reserve)
POST {{baseUrl}}/api/reservations
Content-Type: application/json

{
  "bookId": 1,
  "patronId": 5
}

### Cancel a reservation
POST {{baseUrl}}/api/reservations/2/cancel

### Fulfill a ready reservation (reservation #3 is Ready)
POST {{baseUrl}}/api/reservations/3/fulfill

### ============================================================
### FINES
### ============================================================

### List all fines
GET {{baseUrl}}/api/fines?page=1&pageSize=10

### List unpaid fines
GET {{baseUrl}}/api/fines?status=Unpaid

### Get fine by ID
GET {{baseUrl}}/api/fines/1

### Pay a fine
POST {{baseUrl}}/api/fines/1/pay

### Waive a fine
POST {{baseUrl}}/api/fines/3/waive
