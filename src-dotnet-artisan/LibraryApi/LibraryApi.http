@LibraryApi_HostAddress = http://localhost:5000

### ============================================================
### AUTHORS
### ============================================================

### List authors
GET {{LibraryApi_HostAddress}}/api/authors?page=1&pageSize=10

### Search authors by name
GET {{LibraryApi_HostAddress}}/api/authors?search=Orwell

### Get author by ID (George Orwell)
GET {{LibraryApi_HostAddress}}/api/authors/1

### Create a new author
POST {{LibraryApi_HostAddress}}/api/authors
Content-Type: application/json

{
  "firstName": "Gabriel",
  "lastName": "García Márquez",
  "biography": "Colombian novelist and Nobel Prize laureate, author of One Hundred Years of Solitude.",
  "birthDate": "1927-03-06",
  "country": "Colombia"
}

### Update an author
PUT {{LibraryApi_HostAddress}}/api/authors/1
Content-Type: application/json

{
  "firstName": "George",
  "lastName": "Orwell",
  "biography": "English novelist, essayist, journalist, and critic. Best known for Nineteen Eighty-Four and Animal Farm.",
  "birthDate": "1903-06-25",
  "country": "United Kingdom"
}

### Delete an author (will fail if author has books)
DELETE {{LibraryApi_HostAddress}}/api/authors/1

### ============================================================
### CATEGORIES
### ============================================================

### List all categories
GET {{LibraryApi_HostAddress}}/api/categories

### Get category by ID
GET {{LibraryApi_HostAddress}}/api/categories/1

### Create a new category
POST {{LibraryApi_HostAddress}}/api/categories
Content-Type: application/json

{
  "name": "Philosophy",
  "description": "Books exploring fundamental questions about existence, knowledge, and ethics"
}

### Update a category
PUT {{LibraryApi_HostAddress}}/api/categories/1
Content-Type: application/json

{
  "name": "Fiction",
  "description": "Literary works created from the imagination"
}

### Delete a category
DELETE {{LibraryApi_HostAddress}}/api/categories/6

### ============================================================
### BOOKS
### ============================================================

### List all books
GET {{LibraryApi_HostAddress}}/api/books?page=1&pageSize=10

### Search books by title
GET {{LibraryApi_HostAddress}}/api/books?search=Foundation

### Filter by category
GET {{LibraryApi_HostAddress}}/api/books?category=Science%20Fiction

### Filter by availability
GET {{LibraryApi_HostAddress}}/api/books?available=true

### Sort by title descending
GET {{LibraryApi_HostAddress}}/api/books?sortBy=title&sortDir=desc

### Get book by ID (Nineteen Eighty-Four)
GET {{LibraryApi_HostAddress}}/api/books/1

### Create a new book
POST {{LibraryApi_HostAddress}}/api/books
Content-Type: application/json

{
  "title": "One Hundred Years of Solitude",
  "isbn": "978-0060883287",
  "publisher": "Harper Perennial",
  "publicationYear": 1967,
  "description": "The multi-generational story of the Buendía family in Macondo.",
  "pageCount": 417,
  "language": "English",
  "totalCopies": 3,
  "authorIds": [1],
  "categoryIds": [1, 6]
}

### Update a book
PUT {{LibraryApi_HostAddress}}/api/books/1
Content-Type: application/json

{
  "title": "Nineteen Eighty-Four",
  "isbn": "978-0451524935",
  "publisher": "Signet Classics",
  "publicationYear": 1949,
  "description": "A dystopian novel set in a totalitarian society ruled by Big Brother.",
  "pageCount": 328,
  "language": "English",
  "totalCopies": 5,
  "authorIds": [1],
  "categoryIds": [1, 2, 6]
}

### Delete a book (will fail if active loans exist)
DELETE {{LibraryApi_HostAddress}}/api/books/4

### Get book loan history
GET {{LibraryApi_HostAddress}}/api/books/1/loans

### Get book reservation queue
GET {{LibraryApi_HostAddress}}/api/books/5/reservations

### ============================================================
### PATRONS
### ============================================================

### List all patrons
GET {{LibraryApi_HostAddress}}/api/patrons?page=1&pageSize=10

### Search patrons
GET {{LibraryApi_HostAddress}}/api/patrons?search=Alice

### Filter by membership type
GET {{LibraryApi_HostAddress}}/api/patrons?membershipType=Premium

### Get patron by ID
GET {{LibraryApi_HostAddress}}/api/patrons/1

### Create a new patron
POST {{LibraryApi_HostAddress}}/api/patrons
Content-Type: application/json

{
  "firstName": "Grace",
  "lastName": "Lee",
  "email": "grace.lee@email.com",
  "phone": "555-0107",
  "address": "111 Willow Way",
  "membershipType": "Standard"
}

### Update a patron
PUT {{LibraryApi_HostAddress}}/api/patrons/2
Content-Type: application/json

{
  "firstName": "Bob",
  "lastName": "Smith",
  "email": "bob.smith@email.com",
  "phone": "555-0102",
  "address": "456 Oak Ave, Apt 2B",
  "membershipType": "Premium"
}

### Deactivate a patron (soft delete)
DELETE {{LibraryApi_HostAddress}}/api/patrons/6

### Get patron's loans
GET {{LibraryApi_HostAddress}}/api/patrons/1/loans

### Get patron's loans filtered by status
GET {{LibraryApi_HostAddress}}/api/patrons/1/loans?status=Active

### Get patron's reservations
GET {{LibraryApi_HostAddress}}/api/patrons/3/reservations

### Get patron's fines
GET {{LibraryApi_HostAddress}}/api/patrons/4/fines

### Get patron's unpaid fines
GET {{LibraryApi_HostAddress}}/api/patrons/4/fines?status=Unpaid

### ============================================================
### LOANS
### ============================================================

### List all loans
GET {{LibraryApi_HostAddress}}/api/loans?page=1&pageSize=10

### List active loans
GET {{LibraryApi_HostAddress}}/api/loans?status=Active

### List overdue loans
GET {{LibraryApi_HostAddress}}/api/loans/overdue

### Get loan by ID
GET {{LibraryApi_HostAddress}}/api/loans/1

### Check out a book (create a loan)
POST {{LibraryApi_HostAddress}}/api/loans
Content-Type: application/json

{
  "bookId": 4,
  "patronId": 2
}

### Return a book
POST {{LibraryApi_HostAddress}}/api/loans/3/return

### Renew a loan
POST {{LibraryApi_HostAddress}}/api/loans/1/renew

### ============================================================
### RESERVATIONS
### ============================================================

### List all reservations
GET {{LibraryApi_HostAddress}}/api/reservations?page=1&pageSize=10

### List pending reservations
GET {{LibraryApi_HostAddress}}/api/reservations?status=Pending

### Get reservation by ID
GET {{LibraryApi_HostAddress}}/api/reservations/1

### Create a reservation
POST {{LibraryApi_HostAddress}}/api/reservations
Content-Type: application/json

{
  "bookId": 1,
  "patronId": 5
}

### Cancel a reservation
POST {{LibraryApi_HostAddress}}/api/reservations/1/cancel

### Fulfill a ready reservation
POST {{LibraryApi_HostAddress}}/api/reservations/1/fulfill

### ============================================================
### FINES
### ============================================================

### List all fines
GET {{LibraryApi_HostAddress}}/api/fines?page=1&pageSize=10

### List unpaid fines
GET {{LibraryApi_HostAddress}}/api/fines?status=Unpaid

### Get fine by ID
GET {{LibraryApi_HostAddress}}/api/fines/1

### Pay a fine
POST {{LibraryApi_HostAddress}}/api/fines/1/pay

### Waive a fine
POST {{LibraryApi_HostAddress}}/api/fines/2/waive
