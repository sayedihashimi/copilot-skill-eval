@baseUrl = http://localhost:5260

### ==================== OWNERS ====================

### List all owners
GET {{baseUrl}}/api/owners?page=1&pageSize=10

### Search owners by name
GET {{baseUrl}}/api/owners?search=johnson

### Get owner by ID
GET {{baseUrl}}/api/owners/1

### Create a new owner
POST {{baseUrl}}/api/owners
Content-Type: application/json

{
  "firstName": "Robert",
  "lastName": "Garcia",
  "email": "robert.garcia@email.com",
  "phone": "555-0201",
  "address": "100 Cedar Court",
  "city": "Miami",
  "state": "FL",
  "zipCode": "33101"
}

### Update an owner
PUT {{baseUrl}}/api/owners/1
Content-Type: application/json

{
  "firstName": "Sarah",
  "lastName": "Johnson-Smith",
  "email": "sarah.johnson@email.com",
  "phone": "555-0101",
  "address": "123 Oak Street",
  "city": "Springfield",
  "state": "IL",
  "zipCode": "62701"
}

### Delete an owner (will fail if has active pets)
DELETE {{baseUrl}}/api/owners/5

### Get owner's pets
GET {{baseUrl}}/api/owners/1/pets

### Get owner's appointment history
GET {{baseUrl}}/api/owners/1/appointments?page=1&pageSize=10

### Get non-existent owner (404)
GET {{baseUrl}}/api/owners/999

### ==================== PETS ====================

### List all active pets
GET {{baseUrl}}/api/pets?page=1&pageSize=10

### Search pets by name
GET {{baseUrl}}/api/pets?search=buddy

### Filter pets by species
GET {{baseUrl}}/api/pets?species=Cat

### Include inactive pets
GET {{baseUrl}}/api/pets?includeInactive=true

### Get pet by ID
GET {{baseUrl}}/api/pets/1

### Create a new pet
POST {{baseUrl}}/api/pets
Content-Type: application/json

{
  "name": "Rocky",
  "species": "Dog",
  "breed": "Labrador",
  "dateOfBirth": "2023-04-10",
  "weight": 28.5,
  "color": "Chocolate",
  "microchipNumber": "MC-NEW-001",
  "ownerId": 2
}

### Update a pet (transfer ownership)
PUT {{baseUrl}}/api/pets/1
Content-Type: application/json

{
  "name": "Buddy",
  "species": "Dog",
  "breed": "Golden Retriever",
  "dateOfBirth": "2020-03-15",
  "weight": 33.0,
  "color": "Golden",
  "microchipNumber": "MC-001-2020",
  "ownerId": 1
}

### Soft delete a pet
DELETE {{baseUrl}}/api/pets/8

### Get pet's medical records
GET {{baseUrl}}/api/pets/1/medical-records

### Get pet's vaccinations
GET {{baseUrl}}/api/pets/1/vaccinations

### Get upcoming/overdue vaccinations
GET {{baseUrl}}/api/pets/3/vaccinations/upcoming

### Get active prescriptions for pet
GET {{baseUrl}}/api/pets/1/prescriptions/active

### ==================== VETERINARIANS ====================

### List all veterinarians
GET {{baseUrl}}/api/veterinarians?page=1&pageSize=10

### Filter by specialization
GET {{baseUrl}}/api/veterinarians?specialization=Surgery

### Filter by availability
GET {{baseUrl}}/api/veterinarians?isAvailable=true

### Get veterinarian by ID
GET {{baseUrl}}/api/veterinarians/1

### Create a new veterinarian
POST {{baseUrl}}/api/veterinarians
Content-Type: application/json

{
  "firstName": "Dr. James",
  "lastName": "Wilson",
  "email": "james.wilson@happypaws.com",
  "phone": "555-0204",
  "specialization": "Dentistry",
  "licenseNumber": "VET-2023-004",
  "hireDate": "2023-06-15"
}

### Update a veterinarian
PUT {{baseUrl}}/api/veterinarians/1
Content-Type: application/json

{
  "firstName": "Dr. Amanda",
  "lastName": "Foster",
  "email": "amanda.foster@happypaws.com",
  "phone": "555-0201",
  "specialization": "General Practice",
  "licenseNumber": "VET-2015-001",
  "isAvailable": true
}

### Get veterinarian schedule for a date
GET {{baseUrl}}/api/veterinarians/1/schedule?date=2025-08-15

### Get veterinarian appointments with status filter
GET {{baseUrl}}/api/veterinarians/1/appointments?status=Completed&page=1&pageSize=10

### ==================== APPOINTMENTS ====================

### List all appointments
GET {{baseUrl}}/api/appointments?page=1&pageSize=10

### Filter appointments by date range
GET {{baseUrl}}/api/appointments?dateFrom=2025-01-01&dateTo=2025-12-31

### Filter appointments by status
GET {{baseUrl}}/api/appointments?status=Scheduled

### Filter appointments by vet
GET {{baseUrl}}/api/appointments?vetId=1

### Get appointment by ID (includes medical record)
GET {{baseUrl}}/api/appointments/1

### Schedule a new appointment
POST {{baseUrl}}/api/appointments
Content-Type: application/json

{
  "petId": 4,
  "veterinarianId": 1,
  "appointmentDate": "2025-12-01T10:00:00Z",
  "durationMinutes": 30,
  "reason": "Annual wellness exam",
  "notes": "Owner reports cat seems healthy"
}

### Update an appointment
PUT {{baseUrl}}/api/appointments/7
Content-Type: application/json

{
  "petId": 1,
  "veterinarianId": 1,
  "appointmentDate": "2025-08-16T09:00:00Z",
  "durationMinutes": 45,
  "reason": "Follow-up wellness checkup - extended",
  "notes": "Need extra time for blood work"
}

### Update appointment status - Check In
PATCH {{baseUrl}}/api/appointments/7/status
Content-Type: application/json

{
  "status": "CheckedIn"
}

### Update appointment status - Cancel (requires reason)
PATCH {{baseUrl}}/api/appointments/9/status
Content-Type: application/json

{
  "status": "Cancelled",
  "cancellationReason": "Pet owner is traveling"
}

### Get today's appointments
GET {{baseUrl}}/api/appointments/today

### ==================== MEDICAL RECORDS ====================

### Get medical record by ID (with prescriptions)
GET {{baseUrl}}/api/medical-records/1

### Create a medical record (for completed/in-progress appointment)
POST {{baseUrl}}/api/medical-records
Content-Type: application/json

{
  "appointmentId": 1,
  "diagnosis": "Healthy - annual checkup complete",
  "treatment": "No treatment needed. All vitals within normal range.",
  "notes": "Recommend dental cleaning at next visit",
  "followUpDate": "2026-01-10"
}

### Update a medical record
PUT {{baseUrl}}/api/medical-records/1
Content-Type: application/json

{
  "diagnosis": "Healthy - no issues detected (updated)",
  "treatment": "No treatment required. Continue regular exercise and balanced diet.",
  "notes": "Weight is ideal for breed and age. Updated notes.",
  "followUpDate": "2025-07-10"
}

### ==================== PRESCRIPTIONS ====================

### Get prescription by ID
GET {{baseUrl}}/api/prescriptions/1

### Create a prescription
POST {{baseUrl}}/api/prescriptions
Content-Type: application/json

{
  "medicalRecordId": 1,
  "medicationName": "Flea Prevention (NexGard)",
  "dosage": "1 chewable monthly",
  "durationDays": 90,
  "startDate": "2025-07-01",
  "instructions": "Give with food on the 1st of each month."
}

### ==================== VACCINATIONS ====================

### Record a new vaccination
POST {{baseUrl}}/api/vaccinations
Content-Type: application/json

{
  "petId": 5,
  "vaccineName": "Rabies",
  "dateAdministered": "2025-07-01",
  "expirationDate": "2026-07-01",
  "batchNumber": "RAB-2025-050",
  "administeredByVetId": 2,
  "notes": "Annual rabies booster"
}

### Get vaccination by ID
GET {{baseUrl}}/api/vaccinations/1

### Get non-existent vaccination (404)
GET {{baseUrl}}/api/vaccinations/999
