@baseUrl = http://localhost:5075

### ============================================================
### Owners
### ============================================================

### List all owners
GET {{baseUrl}}/api/owners?page=1&pageSize=10

### Search owners by name
GET {{baseUrl}}/api/owners?search=johnson&page=1&pageSize=10

### Get owner by ID (includes pets)
GET {{baseUrl}}/api/owners/1

### Create a new owner
POST {{baseUrl}}/api/owners
Content-Type: application/json

{
  "firstName": "David",
  "lastName": "Martinez",
  "email": "david.martinez@email.com",
  "phone": "555-0106",
  "address": "987 Willow Drive",
  "city": "Miami",
  "state": "FL",
  "zipCode": "33101"
}

### Update an existing owner
PUT {{baseUrl}}/api/owners/1
Content-Type: application/json

{
  "firstName": "Sarah",
  "lastName": "Johnson-Smith",
  "email": "sarah.johnson@email.com",
  "phone": "555-0101",
  "address": "123 Maple Street",
  "city": "Springfield",
  "state": "IL",
  "zipCode": "62701"
}

### Delete an owner (will fail if owner has active pets)
DELETE {{baseUrl}}/api/owners/5

### Get all pets for an owner
GET {{baseUrl}}/api/owners/1/pets

### Get appointment history for an owner's pets
GET {{baseUrl}}/api/owners/1/appointments?page=1&pageSize=10

### ============================================================
### Pets
### ============================================================

### List all active pets
GET {{baseUrl}}/api/pets?page=1&pageSize=10

### Search pets by name
GET {{baseUrl}}/api/pets?name=buddy&page=1&pageSize=10

### Search pets by species
GET {{baseUrl}}/api/pets?species=cat&page=1&pageSize=10

### List all pets including inactive
GET {{baseUrl}}/api/pets?includeInactive=true&page=1&pageSize=10

### Get pet by ID (includes owner info)
GET {{baseUrl}}/api/pets/1

### Create a new pet
POST {{baseUrl}}/api/pets
Content-Type: application/json

{
  "name": "Mittens",
  "species": "Cat",
  "breed": "Persian",
  "dateOfBirth": "2023-06-15",
  "weight": 4.5,
  "color": "White",
  "microchipNumber": "MC-009-2023",
  "ownerId": 2
}

### Update a pet (transfer ownership by changing ownerId)
PUT {{baseUrl}}/api/pets/1
Content-Type: application/json

{
  "name": "Buddy",
  "species": "Dog",
  "breed": "Golden Retriever",
  "dateOfBirth": "2020-03-15",
  "weight": 33.0,
  "color": "Golden",
  "microchipNumber": "MC-001-2020",
  "ownerId": 1
}

### Soft-delete a pet (set inactive)
DELETE {{baseUrl}}/api/pets/8

### Get medical records for a pet
GET {{baseUrl}}/api/pets/1/medical-records

### Get vaccinations for a pet
GET {{baseUrl}}/api/pets/1/vaccinations

### Get upcoming/overdue vaccinations for a pet
GET {{baseUrl}}/api/pets/1/vaccinations/upcoming

### Get active prescriptions for a pet
GET {{baseUrl}}/api/pets/1/prescriptions/active

### ============================================================
### Veterinarians
### ============================================================

### List all veterinarians
GET {{baseUrl}}/api/veterinarians?page=1&pageSize=10

### Filter veterinarians by specialization
GET {{baseUrl}}/api/veterinarians?specialization=surgery&page=1&pageSize=10

### Filter veterinarians by availability
GET {{baseUrl}}/api/veterinarians?isAvailable=true&page=1&pageSize=10

### Get veterinarian by ID
GET {{baseUrl}}/api/veterinarians/1

### Create a new veterinarian
POST {{baseUrl}}/api/veterinarians
Content-Type: application/json

{
  "firstName": "Dr. Jennifer",
  "lastName": "Park",
  "email": "jennifer.park@happypaws.com",
  "phone": "555-0204",
  "specialization": "Dermatology",
  "licenseNumber": "VET-2022-004",
  "isAvailable": true,
  "hireDate": "2022-07-01"
}

### Update a veterinarian
PUT {{baseUrl}}/api/veterinarians/1
Content-Type: application/json

{
  "firstName": "Dr. Amanda",
  "lastName": "Wilson",
  "email": "amanda.wilson@happypaws.com",
  "phone": "555-0201",
  "specialization": "General Practice",
  "licenseNumber": "VET-2015-001",
  "isAvailable": true,
  "hireDate": "2015-06-01"
}

### Get vet's schedule for a specific date
GET {{baseUrl}}/api/veterinarians/1/schedule?date=2025-07-20

### Get all appointments for a vet (with pagination and status filter)
GET {{baseUrl}}/api/veterinarians/1/appointments?page=1&pageSize=10

### Get completed appointments for a vet
GET {{baseUrl}}/api/veterinarians/1/appointments?status=Completed&page=1&pageSize=10

### ============================================================
### Appointments
### ============================================================

### List all appointments
GET {{baseUrl}}/api/appointments?page=1&pageSize=10

### Filter appointments by date range
GET {{baseUrl}}/api/appointments?fromDate=2025-01-01T00:00:00Z&toDate=2025-12-31T23:59:59Z&page=1&pageSize=10

### Filter appointments by status
GET {{baseUrl}}/api/appointments?status=Scheduled&page=1&pageSize=10

### Filter appointments by vet
GET {{baseUrl}}/api/appointments?vetId=1&page=1&pageSize=10

### Filter appointments by pet
GET {{baseUrl}}/api/appointments?petId=1&page=1&pageSize=10

### Get today's appointments
GET {{baseUrl}}/api/appointments/today

### Get appointment by ID (includes medical record)
GET {{baseUrl}}/api/appointments/1

### Schedule a new appointment
POST {{baseUrl}}/api/appointments
Content-Type: application/json

{
  "petId": 2,
  "veterinarianId": 3,
  "appointmentDate": "2025-08-15T14:00:00Z",
  "durationMinutes": 30,
  "reason": "Annual dental checkup",
  "notes": "Owner requested teeth cleaning evaluation"
}

### Update an appointment
PUT {{baseUrl}}/api/appointments/6
Content-Type: application/json

{
  "petId": 1,
  "veterinarianId": 1,
  "appointmentDate": "2025-07-21T09:00:00Z",
  "durationMinutes": 45,
  "reason": "Follow-up wellness check - extended",
  "notes": "Include blood work"
}

### Update appointment status - Check in
PATCH {{baseUrl}}/api/appointments/6/status
Content-Type: application/json

{
  "status": "CheckedIn"
}

### Update appointment status - Start
PATCH {{baseUrl}}/api/appointments/6/status
Content-Type: application/json

{
  "status": "InProgress"
}

### Update appointment status - Complete
PATCH {{baseUrl}}/api/appointments/6/status
Content-Type: application/json

{
  "status": "Completed"
}

### Update appointment status - Cancel (requires reason)
PATCH {{baseUrl}}/api/appointments/9/status
Content-Type: application/json

{
  "status": "Cancelled",
  "cancellationReason": "Vet unavailable due to emergency surgery"
}

### ============================================================
### Medical Records
### ============================================================

### Get medical record by ID (includes prescriptions)
GET {{baseUrl}}/api/medical-records/1

### Create a medical record (appointment must be Completed or InProgress)
POST {{baseUrl}}/api/medical-records
Content-Type: application/json

{
  "appointmentId": 6,
  "petId": 1,
  "veterinarianId": 1,
  "diagnosis": "Mild ear infection in left ear",
  "treatment": "Prescribed ear drops and oral antibiotics. Clean ears daily for 7 days.",
  "notes": "Follow up in 2 weeks if symptoms persist",
  "followUpDate": "2025-08-04"
}

### Update a medical record
PUT {{baseUrl}}/api/medical-records/1
Content-Type: application/json

{
  "diagnosis": "Healthy - no issues found. Weight stable.",
  "treatment": "No treatment required. Recommended continued current diet and exercise regimen.",
  "notes": "Weight is ideal. Coat in excellent condition. Updated dental records.",
  "followUpDate": "2025-07-10"
}

### ============================================================
### Prescriptions
### ============================================================

### Get prescription by ID
GET {{baseUrl}}/api/prescriptions/1

### Create a prescription
POST {{baseUrl}}/api/prescriptions
Content-Type: application/json

{
  "medicalRecordId": 1,
  "medicationName": "Apoquel",
  "dosage": "16mg once daily",
  "durationDays": 30,
  "startDate": "2025-01-15",
  "instructions": "Administer with food. Do not exceed recommended dose."
}

### ============================================================
### Vaccinations
### ============================================================

### Record a new vaccination
POST {{baseUrl}}/api/vaccinations
Content-Type: application/json

{
  "petId": 3,
  "vaccineName": "DHPP",
  "dateAdministered": "2025-01-15",
  "expirationDate": "2026-01-15",
  "batchNumber": "DHPP-2025-G7",
  "administeredByVetId": 2,
  "notes": "Annual booster administered"
}

### Get vaccination by ID
GET {{baseUrl}}/api/vaccinations/1

### Get vaccination details (expired one)
GET {{baseUrl}}/api/vaccinations/4

### Get vaccination details (recent one)
GET {{baseUrl}}/api/vaccinations/3
