@baseUrl = http://localhost:5000

### =============================================
### Membership Plans
### =============================================

### List all active membership plans
GET {{baseUrl}}/api/membership-plans?page=1&pageSize=20

### Get membership plan details (Basic)
GET {{baseUrl}}/api/membership-plans/1

### Get membership plan details (Premium)
GET {{baseUrl}}/api/membership-plans/2

### Get membership plan details (Elite)
GET {{baseUrl}}/api/membership-plans/3

### Create a new membership plan
POST {{baseUrl}}/api/membership-plans
Content-Type: application/json

{
  "name": "Student",
  "description": "Discounted plan for students, 2 classes per week",
  "durationMonths": 6,
  "price": 19.99,
  "maxClassBookingsPerWeek": 2,
  "allowsPremiumClasses": false,
  "isActive": true
}

### Update a membership plan
PUT {{baseUrl}}/api/membership-plans/1
Content-Type: application/json

{
  "name": "Basic",
  "description": "Access to standard classes, 3 bookings per week - Updated",
  "durationMonths": 1,
  "price": 34.99,
  "maxClassBookingsPerWeek": 3,
  "allowsPremiumClasses": false,
  "isActive": true
}

### Deactivate a membership plan
DELETE {{baseUrl}}/api/membership-plans/1

### =============================================
### Members
### =============================================

### List all members
GET {{baseUrl}}/api/members?page=1&pageSize=20

### List active members only
GET {{baseUrl}}/api/members?isActive=true&page=1&pageSize=20

### Search members by name
GET {{baseUrl}}/api/members?search=alice&page=1&pageSize=20

### Search members by email
GET {{baseUrl}}/api/members?search=marcus.chen&page=1&pageSize=20

### Get member details (Alice Johnson - Elite member)
GET {{baseUrl}}/api/members/1

### Get member details (Sophia Williams - Basic member)
GET {{baseUrl}}/api/members/3

### Register a new member
POST {{baseUrl}}/api/members
Content-Type: application/json

{
  "firstName": "Noah",
  "lastName": "Wilson",
  "email": "noah.wilson@email.com",
  "phone": "555-0901",
  "dateOfBirth": "2000-05-20",
  "emergencyContactName": "Grace Wilson",
  "emergencyContactPhone": "555-0902"
}

### Update member profile
PUT {{baseUrl}}/api/members/1
Content-Type: application/json

{
  "firstName": "Alice",
  "lastName": "Johnson",
  "email": "alice.johnson@email.com",
  "phone": "555-0103",
  "dateOfBirth": "1990-03-15",
  "emergencyContactName": "Bob Johnson",
  "emergencyContactPhone": "555-0102"
}

### Deactivate a member (will fail if they have active bookings)
DELETE {{baseUrl}}/api/members/8

### Get member's bookings
GET {{baseUrl}}/api/members/1/bookings?page=1&pageSize=20

### Get member's bookings filtered by status
GET {{baseUrl}}/api/members/1/bookings?status=Confirmed&page=1&pageSize=20

### Get member's upcoming confirmed bookings
GET {{baseUrl}}/api/members/1/bookings/upcoming

### Get membership history for a member
GET {{baseUrl}}/api/members/1/memberships

### Get membership history for member with expired membership
GET {{baseUrl}}/api/members/7/memberships

### =============================================
### Memberships
### =============================================

### Purchase a membership for a member without one (member 7 has expired)
POST {{baseUrl}}/api/memberships
Content-Type: application/json

{
  "memberId": 7,
  "membershipPlanId": 1,
  "startDate": "2025-07-01",
  "paymentStatus": "Paid"
}

### Get membership details
GET {{baseUrl}}/api/memberships/1

### Get membership details (expired)
GET {{baseUrl}}/api/memberships/7

### Cancel a membership
POST {{baseUrl}}/api/memberships/3/cancel

### Freeze a membership (14 days)
POST {{baseUrl}}/api/memberships/2/freeze
Content-Type: application/json

{
  "freezeDurationDays": 14
}

### Unfreeze a membership (run after freezing membership 2)
POST {{baseUrl}}/api/memberships/2/unfreeze

### Renew an expired membership
POST {{baseUrl}}/api/memberships/7/renew

### =============================================
### Instructors
### =============================================

### List all instructors
GET {{baseUrl}}/api/instructors?page=1&pageSize=20

### List active instructors
GET {{baseUrl}}/api/instructors?isActive=true&page=1&pageSize=20

### Filter instructors by specialization
GET {{baseUrl}}/api/instructors?specialization=Yoga&page=1&pageSize=20

### Get instructor details
GET {{baseUrl}}/api/instructors/1

### Create a new instructor
POST {{baseUrl}}/api/instructors
Content-Type: application/json

{
  "firstName": "Lisa",
  "lastName": "Wong",
  "email": "lisa.wong@zenithfitness.com",
  "phone": "555-1005",
  "bio": "Certified dance fitness instructor with 5 years of experience",
  "specializations": "Dance, Cardio, HIIT",
  "hireDate": "2025-01-15",
  "isActive": true
}

### Update an instructor
PUT {{baseUrl}}/api/instructors/1
Content-Type: application/json

{
  "firstName": "Sarah",
  "lastName": "Miller",
  "email": "sarah.miller@zenithfitness.com",
  "phone": "555-1001",
  "bio": "Senior certified yoga and pilates instructor with 10+ years of experience",
  "specializations": "Yoga, Pilates, Meditation, Stretching",
  "hireDate": "2022-01-15",
  "isActive": true
}

### Get instructor's schedule
GET {{baseUrl}}/api/instructors/1/schedule

### Get instructor's schedule with date range
GET {{baseUrl}}/api/instructors/2/schedule?fromDate=2025-07-21&toDate=2025-07-27

### =============================================
### Class Types
### =============================================

### List all class types
GET {{baseUrl}}/api/class-types?page=1&pageSize=20

### Filter by difficulty
GET {{baseUrl}}/api/class-types?difficulty=Beginner&page=1&pageSize=20

### Filter premium classes only
GET {{baseUrl}}/api/class-types?isPremium=true&page=1&pageSize=20

### Get class type details (Yoga)
GET {{baseUrl}}/api/class-types/1

### Get class type details (Boxing - premium)
GET {{baseUrl}}/api/class-types/5

### Create a new class type
POST {{baseUrl}}/api/class-types
Content-Type: application/json

{
  "name": "Zumba",
  "description": "Latin-inspired dance fitness class",
  "defaultDurationMinutes": 60,
  "defaultCapacity": 20,
  "isPremium": false,
  "caloriesPerSession": 400,
  "difficultyLevel": "AllLevels",
  "isActive": true
}

### Update a class type
PUT {{baseUrl}}/api/class-types/1
Content-Type: application/json

{
  "name": "Yoga",
  "description": "Traditional yoga focusing on flexibility, mindfulness and balance",
  "defaultDurationMinutes": 75,
  "defaultCapacity": 25,
  "isPremium": false,
  "caloriesPerSession": 300,
  "difficultyLevel": "AllLevels",
  "isActive": true
}

### =============================================
### Class Schedules
### =============================================

### List all scheduled classes
GET {{baseUrl}}/api/classes?page=1&pageSize=20

### Filter by date range
GET {{baseUrl}}/api/classes?fromDate=2025-07-21&toDate=2025-07-23&page=1&pageSize=20

### Filter by class type (Yoga = 1)
GET {{baseUrl}}/api/classes?classTypeId=1&page=1&pageSize=20

### Filter by instructor
GET {{baseUrl}}/api/classes?instructorId=1&page=1&pageSize=20

### Filter by availability
GET {{baseUrl}}/api/classes?hasAvailability=true&page=1&pageSize=20

### Get class details (Yoga Monday - has availability)
GET {{baseUrl}}/api/classes/1

### Get class details (Spin Friday - FULL with waitlist)
GET {{baseUrl}}/api/classes/9

### Get class details (Cancelled class)
GET {{baseUrl}}/api/classes/12

### Schedule a new class
POST {{baseUrl}}/api/classes
Content-Type: application/json

{
  "classTypeId": 1,
  "instructorId": 1,
  "startTime": "2025-07-27T16:00:00",
  "endTime": "2025-07-27T17:00:00",
  "capacity": 20,
  "room": "Studio A"
}

### Update class details
PUT {{baseUrl}}/api/classes/1
Content-Type: application/json

{
  "classTypeId": 1,
  "instructorId": 1,
  "startTime": "2025-07-21T08:30:00",
  "endTime": "2025-07-21T09:30:00",
  "capacity": 25,
  "room": "Studio A"
}

### Cancel a class (cascades to all bookings)
PATCH {{baseUrl}}/api/classes/11/cancel
Content-Type: application/json

{
  "reason": "Instructor illness"
}

### Get class roster
GET {{baseUrl}}/api/classes/1/roster

### Get class roster for full class
GET {{baseUrl}}/api/classes/9/roster

### Get class waitlist
GET {{baseUrl}}/api/classes/9/waitlist

### Get available classes in next 7 days
GET {{baseUrl}}/api/classes/available

### =============================================
### Bookings
### =============================================

### Book a class (Yoga Monday for member 5 - Basic plan, non-premium class)
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 1,
  "memberId": 5
}

### Book a premium class as a Premium member (Spin Tuesday for member 2)
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 3,
  "memberId": 2
}

### BUSINESS RULE TEST: Book a premium class as Basic member (should fail - member 3 is Basic)
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 3,
  "memberId": 3
}

### BUSINESS RULE TEST: Book a full class (should go to waitlist - class 9 is full)
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 9,
  "memberId": 5
}

### Get booking details
GET {{baseUrl}}/api/bookings/1

### Get booking details (waitlisted)
GET {{baseUrl}}/api/bookings/18

### Get booking details (cancelled)
GET {{baseUrl}}/api/bookings/19

### Cancel a booking
POST {{baseUrl}}/api/bookings/3/cancel
Content-Type: application/json

{
  "reason": "Schedule conflict"
}

### Check in for a class (only works within check-in window)
POST {{baseUrl}}/api/bookings/1/check-in

### Mark booking as no-show (only works after 15 min past class start)
POST {{baseUrl}}/api/bookings/1/no-show
