@baseUrl = http://localhost:5188

### ===================== AUTHORS =====================

### List all authors
GET {{baseUrl}}/api/authors?page=1&pageSize=10

### Search authors by name
GET {{baseUrl}}/api/authors?search=orwell

### Get author by ID (with books)
GET {{baseUrl}}/api/authors/1

### Get non-existent author (404)
GET {{baseUrl}}/api/authors/999

### Create an author
POST {{baseUrl}}/api/authors
Content-Type: application/json

{
  "firstName": "Margaret",
  "lastName": "Atwood",
  "biography": "Canadian poet, novelist, literary critic, essayist, and environmental activist.",
  "birthDate": "1939-11-18",
  "country": "Canada"
}

### Update an author
PUT {{baseUrl}}/api/authors/1
Content-Type: application/json

{
  "firstName": "George",
  "lastName": "Orwell",
  "biography": "English novelist, essayist, journalist, and critic. Author of 1984 and Animal Farm.",
  "birthDate": "1903-06-25",
  "country": "United Kingdom"
}

### Delete an author (will fail if has books)
DELETE {{baseUrl}}/api/authors/1

### ===================== CATEGORIES =====================

### List all categories
GET {{baseUrl}}/api/categories

### Get category by ID (with book count)
GET {{baseUrl}}/api/categories/1

### Create a category
POST {{baseUrl}}/api/categories
Content-Type: application/json

{
  "name": "Philosophy",
  "description": "Works exploring fundamental questions about existence, knowledge, and ethics"
}

### Update a category
PUT {{baseUrl}}/api/categories/1
Content-Type: application/json

{
  "name": "Fiction",
  "description": "Literary works of imaginative narration and storytelling"
}

### Delete a category (will fail if has books)
DELETE {{baseUrl}}/api/categories/6

### ===================== BOOKS =====================

### List all books (paginated)
GET {{baseUrl}}/api/books?page=1&pageSize=10

### Search books by title
GET {{baseUrl}}/api/books?search=foundation

### Search books by author name
GET {{baseUrl}}/api/books?search=christie

### Filter books by category
GET {{baseUrl}}/api/books?category=Science Fiction

### Filter available books only
GET {{baseUrl}}/api/books?available=true

### Sort books by publication year descending
GET {{baseUrl}}/api/books?sortBy=year&sortDirection=desc

### Combined search with filters
GET {{baseUrl}}/api/books?search=orwell&available=true&sortBy=title&page=1&pageSize=5

### Get book by ID (with authors, categories, availability)
GET {{baseUrl}}/api/books/1

### Create a book
POST {{baseUrl}}/api/books
Content-Type: application/json

{
  "title": "Brave New World",
  "isbn": "978-0-06-085052-4",
  "publisher": "Chatto & Windus",
  "publicationYear": 1932,
  "description": "A dystopian novel set in a futuristic World State.",
  "pageCount": 311,
  "language": "English",
  "totalCopies": 3,
  "authorIds": [1],
  "categoryIds": [1, 2]
}

### Update a book
PUT {{baseUrl}}/api/books/1
Content-Type: application/json

{
  "title": "1984",
  "isbn": "978-0-451-52493-5",
  "publisher": "Secker & Warburg",
  "publicationYear": 1949,
  "description": "A dystopian novel set in a totalitarian society ruled by Big Brother.",
  "pageCount": 328,
  "language": "English",
  "totalCopies": 6,
  "authorIds": [1],
  "categoryIds": [1, 2]
}

### Delete a book (will fail if has active loans)
DELETE {{baseUrl}}/api/books/12

### Get book loan history
GET {{baseUrl}}/api/books/1/loans?page=1&pageSize=10

### Get book active reservations
GET {{baseUrl}}/api/books/5/reservations

### ===================== PATRONS =====================

### List all patrons
GET {{baseUrl}}/api/patrons?page=1&pageSize=10

### Search patrons by name
GET {{baseUrl}}/api/patrons?search=alice

### Filter patrons by membership type
GET {{baseUrl}}/api/patrons?membershipType=Premium

### Get patron by ID (with active loans count and unpaid fines)
GET {{baseUrl}}/api/patrons/1

### Create a patron
POST {{baseUrl}}/api/patrons
Content-Type: application/json

{
  "firstName": "Grace",
  "lastName": "Lee",
  "email": "grace.lee@email.com",
  "phone": "555-0201",
  "address": "100 Library Way, Springfield",
  "membershipType": "Student"
}

### Update a patron
PUT {{baseUrl}}/api/patrons/2
Content-Type: application/json

{
  "firstName": "Bob",
  "lastName": "Smith",
  "email": "bob.smith@email.com",
  "phone": "555-0102",
  "address": "456 Oak Ave, Springfield",
  "membershipType": "Premium"
}

### Deactivate a patron (will fail if has active loans)
DELETE {{baseUrl}}/api/patrons/6

### Get patron loans
GET {{baseUrl}}/api/patrons/1/loans?page=1&pageSize=10

### Get patron loans filtered by status
GET {{baseUrl}}/api/patrons/1/loans?status=Active

### Get patron reservations
GET {{baseUrl}}/api/patrons/4/reservations

### Get patron fines
GET {{baseUrl}}/api/patrons/2/fines

### Get patron fines filtered by status
GET {{baseUrl}}/api/patrons/2/fines?status=Unpaid

### ===================== LOANS =====================

### List all loans
GET {{baseUrl}}/api/loans?page=1&pageSize=10

### Filter loans by status
GET {{baseUrl}}/api/loans?status=Active

### Filter overdue loans
GET {{baseUrl}}/api/loans?overdue=true

### Filter loans by date range
GET {{baseUrl}}/api/loans?fromDate=2024-05-01&toDate=2024-06-01

### Get loan by ID
GET {{baseUrl}}/api/loans/1

### Checkout a book (create loan)
POST {{baseUrl}}/api/loans
Content-Type: application/json

{
  "bookId": 3,
  "patronId": 2
}

### Return a book
POST {{baseUrl}}/api/loans/1/return

### Renew a loan
POST {{baseUrl}}/api/loans/9/renew

### Get overdue loans
GET {{baseUrl}}/api/loans/overdue

### ===================== RESERVATIONS =====================

### List all reservations
GET {{baseUrl}}/api/reservations?page=1&pageSize=10

### Filter reservations by status
GET {{baseUrl}}/api/reservations?status=Pending

### Get reservation by ID
GET {{baseUrl}}/api/reservations/1

### Create a reservation
POST {{baseUrl}}/api/reservations
Content-Type: application/json

{
  "bookId": 1,
  "patronId": 4
}

### Cancel a reservation
POST {{baseUrl}}/api/reservations/3/cancel

### Fulfill a ready reservation (creates a loan)
POST {{baseUrl}}/api/reservations/1/fulfill

### ===================== FINES =====================

### List all fines
GET {{baseUrl}}/api/fines?page=1&pageSize=10

### Filter fines by status
GET {{baseUrl}}/api/fines?status=Unpaid

### Get fine by ID
GET {{baseUrl}}/api/fines/1

### Pay a fine
POST {{baseUrl}}/api/fines/1/pay

### Waive a fine
POST {{baseUrl}}/api/fines/3/waive
